---
const { title = "NPM" } = Astro.props;
import TypewriterText from "@astroanimate/core/TypewriterText";
---

<div class="code-block-card">
  <div class="accent-bar"></div>
  <div class="card-content">
    <div class="card-header">
      <span class="header-title">{title}</span>
    </div>

    <div class="card-body">
      <div class="code-content">
        <span class="code-prefix">$</span>
        <span class="code-text">
          <TypewriterText
            texts={["npm install @astroanimate/core"]}
            typeSpeed={50}
            pauseAfter={1500}
            enhance
            loop={false}
            erase={false}
          />
        </span>
      </div>

      <button class="copy-button" aria-label="Copy to clipboard">
        <svg
          class="copy-icon"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <g class="icon-copy-state">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
            ></path>
          </g>

          <g class="icon-check-state" style="display: none;">
            <polyline points="20 6 9 17 4 12"></polyline>
          </g>
        </svg>
      </button>
    </div>
  </div>
</div>

<style>
  .code-block-card {
    background-color: #000000;
    border: 1px solid #374151;
    position: relative;
    display: flex;
    overflow: hidden;
    width: 100%;
    max-width: 600px;
    min-width: min(500px, 100%);
  }

  .accent-bar {
    width: 4px;
    background-color: #ff7f1f;
    flex-shrink: 0;
  }

  .card-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .card-header {
    padding: 12px 20px;
    border-bottom: 1px solid #374151;
  }

  .header-title {
    color: #ff7f1f;
    font-family: "JetBrains Mono", monospace;
    font-size: 14px;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .card-body {
    /* padding: 20px; */
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    min-height: 66px;
    min-width: 0;
  }

  .code-content {
    display: flex;
    gap: 12px;
    align-items: center;
    font-family: "JetBrains Mono", monospace;
    font-size: 16px;
    flex: 1;
    min-width: 0;
  }

  .code-prefix {
    color: #9ca3af;
    user-select: none;
  }

  .code-text {
    color: #9ca3af;
    flex: 1 1 350px;
    width: 350px;
    max-width: 100%;
    min-width: 0;
    display: inline-block;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .copy-button {
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 4px;
    color: #9ca3af;
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
  }

  .copy-button:hover {
    color: #9ca3af;
  }

  .copy-button.success {
    color: #4ade80 !important;
  }

  @media (max-width: 520px) {
    .card-header {
      padding: 10px 14px;
    }

    .card-body {
      /* padding: 14px; */
      gap: 12px;
      min-height: 58px;
    }

    .code-content {
      gap: 8px;
      font-size: 13px;
    }

    .code-text {
      flex-basis: auto;
      width: auto;
    }
  }
</style>

<script>
  function setupCopyFunctionality() {
    const copyButtons = document.querySelectorAll(".copy-button");

    copyButtons.forEach((btn) => {
      btn.addEventListener("click", async () => {
const cardBody = btn.closest(".card-body");
        // const codeText =
        //   cardBody?.querySelector(".code-text")?.textContent ?? "";
          const codeText = "npm install @astroanimate/core";

        // Get reference to the two states within the SVG
        const copyState = btn.querySelector<HTMLElement>(".icon-copy-state");
        const checkState = btn.querySelector<HTMLElement>(".icon-check-state");

        try {
          // 1. Perform the copy operation
          await navigator.clipboard.writeText(codeText);

          // 2. Visual Feedback Loop
          btn.classList.add("success"); // Triggers green color (CSS)

          if (copyState && checkState) {
            copyState.style.display = "none"; // Hide standard icon
            checkState.style.display = "block"; // Show checkmark
          }

          // 3. Reset after delay
          setTimeout(() => {
            btn.classList.remove("success");
            if (copyState && checkState) {
              copyState.style.display = "block";
              checkState.style.display = "none";
            }
          }, 2000);
        } catch (err) {
          console.error("Failed to copy code: ", err);
          // Optional: Add basic fallback copy here if necessary
        }
      });
    });
  }

  // Run on initial load
  setupCopyFunctionality();

  // Re-run after view transitions (if enabled in Astro)
  document.addEventListener("astro:after-swap", setupCopyFunctionality);
</script>
