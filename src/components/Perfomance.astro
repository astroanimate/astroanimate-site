<section class="features-section">
    <div class="badge-border"></div>
    <div class="badge">PERFOMANCE</div>

    <div class="features-header">
        <p class="mini">// PERFORMANCE</p>
        <h2>
            Measured Performance
            <span>Characteristics</span>
        </h2>
        <p class="desc">
            The following metrics are measured from static demo builds and
            documented test environments.
        </p>
    </div>

    <div class="perf-grid">
        <!-- ROW 1 -->
        <div class="perf-cell has-content border-right border-bottom">
            <h3>Bundle size:</h3>
            <ul class="perf-list">
                <li>
                    <span class="icon-check"></span> Core library: ~12KB gzipped (base
                    components)
                </li>
                <li>
                    <span class="icon-check"></span> Individual components: 2-5KB
                    gzipped each
                </li>
                <li>
                    <span class="icon-check"></span> Tree-shakable: Only imported
                    components are bundled
                </li>
            </ul>
        </div>
        <div class="perf-cell border-bottom">
            <img src="/images/Bundle size.png" alt="" class="perf-cell-bundle">
        </div>

        <!-- ROW 2 -->
        <div class="perf-cell border-right border-bottom"></div>
        <div class="perf-cell has-content border-bottom">
            <h3>Lighthouse Scores:</h3>
            <ul class="perf-list">
                <li>
                    <span class="icon-check"></span> Demo site: 98+ Performance, 100
                    Accessibility, 100 Best Practices
                </li>
                <li>
                    <span class="icon-check"></span> Tested on Astro 4.x static builds
                </li>
            </ul>
        </div>
     
        <!-- ROW 3 -->
        <div class="perf-cell has-content border-right border-bottom">
            <h3>Browser Compatibility:</h3>
            <ul class="perf-list">
                <li>
                    <span class="icon-check"></span> Chrome 90+, Firefox 88+, Safari
                    14+, Edge 90+
                </li>
                <li>
                    <span class="icon-check"></span> Graceful degradation for older
                    browsers (animations disabled, layout preserved)
                </li>
            </ul>
        </div>
        <div class="perf-cell border-bottom">
                        <img src="/images/Browser  compactibility.png" alt="" class="perf-cell-bundle">

        </div>

        <!-- ROW 4 -->
        <div class="perf-cell border-right"></div>
        <div class="perf-cell has-content">
            <h3>CSS Scope:</h3>
            <ul class="perf-list">
                <li>
                    <span class="icon-check"></span> Component-scoped animation styles
                </li>
                <li>
                    <span class="icon-check"></span> No global resets or conflicting
                    selectors
                </li>
                <li>
                    <span class="icon-check"></span> ~50 lines of CSS per animated
                    component (average)
                </li>
            </ul>
        </div>
      
    </div>
</section>
