---
import "../styles/Global.css";
import { allNewComponentDocs } from "../data/newComponentDocs";
const { pathname } = Astro.url;

const normalizedPath = pathname.replace(/\/$/, "") || "/";
const isLatestDocsVersion = Astro.url.searchParams.get("version") !== "0.1.1";
const versionQuery = isLatestDocsVersion ? "" : "?version=0.1.1";
const componentDocPaths = new Set([
  "/docs/all-components",
  "/docs/fade-in-text",
  "/docs/typewriter",
  "/docs/scale-in",
  "/docs/reveal-image",
  "/docs/expandable-card",
  "/docs/animated-card",
  "/docs/glass-card",
  "/docs/loader",
  "/docs/progress-bar",
  "/docs/animated-button",
  "/docs/tooltip",
  ...allNewComponentDocs.map((component) => `/docs/${component.slug}`),
]);
const isComponentsActive = componentDocPaths.has(normalizedPath);
const isDocsActive =
  (normalizedPath === "/docs" || normalizedPath.startsWith("/docs/")) &&
  !isComponentsActive;
---

<script is:inline>
  function syncNavDocsVersionClass() {
    const isOldDocsVersion = new URLSearchParams(window.location.search).get(
      "version",
    ) === "0.1.1";
    document.documentElement.classList.toggle(
      "docs-version-old",
      isOldDocsVersion,
    );
    document.documentElement.classList.toggle(
      "docs-version-latest",
      !isOldDocsVersion,
    );
  }

  syncNavDocsVersionClass();
  document.addEventListener("astro:page-load", syncNavDocsVersionClass);
</script>

<nav class="nav" aria-label="Main navigation">
  <div class="nav-item nav-logo">
    <a href="/" class="nav-logo-link" aria-label="AstroAnimate home">
      <img
        src="/images/Logo.png"
        alt="AstroAnimate logo"
        class="logo-icon"
        width="24"
        height="24"
        loading="eager"
      />
    </a>
    <details class="version-dropdown">
      <summary class="version">
        <span class="version-label-latest">VER 0.1.2</span>
        <span class="version-label-old">VER 0.1.1</span>
        <svg
          width="12"
          height="12"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"><path d="m6 9 6 6 6-6"></path></svg
        >
      </summary>
      <div class="version-menu">
        <a
          href="/docs/all-components/"
          class:list={["version-option", { active: isLatestDocsVersion }]}
        >
          VER 0.1.2
        </a>
        <a
          href="/docs/all-components/?version=0.1.1"
          class:list={["version-option", { active: !isLatestDocsVersion }]}
        >
          VER 0.1.1
        </a>
      </div>
    </details>
  </div>

  <!-- TOGGLE FOR MOBILE -->
  <input type="checkbox" id="nav-toggle" class="nav-toggle" hidden />
  <label for="nav-toggle" class="hamburger" aria-label="Toggle Navigation">
    <span></span>
    <span></span>
    <span></span>
  </label>

  <div class="nav-content">
    <div class="nav-item nav-empty-left"></div>

    <a
      href="/"
      class:list={["nav-item nav-link", { active: pathname === "/" }]}
      aria-current={pathname === "/" ? "page" : undefined}>HOME</a
    >
    <a
      href={`/docs/${versionQuery}`}
      class:list={["nav-item nav-link", { active: isDocsActive }]}>DOCS</a
    >
    <!-- <a
            href="/playground"
            class:list={[
                "nav-item nav-link",
                { active: pathname === "/playground" },
            ]}
            aria-current={pathname === "/playground" ? "page" : undefined}
            >PLAYGROUND</a> -->

    <a
      href={`/docs/all-components/${versionQuery}`}
      class:list={["nav-item nav-link", { active: isComponentsActive }]}
      aria-current={isComponentsActive ? "page" : undefined}
    >
      COMPONENTS</a
    >
    <!-- <a href="/pricing" class="nav-item nav-link">PRICING</a> -->
    <a
      href="/blog/"
      class:list={["nav-item nav-link", { active: pathname === "/blog/" }]}
      aria-current={pathname === "/blog/" ? "page" : undefined}>BLOG</a
    >

    <div class="nav-item nav-empty-right"></div>

    <div class="nav-social-wrap">
      <a
        class="nav-item nav-social"
        href="https://github.com/astroanimate/astroanimate"
        target="_blank"
      >
        <img
          class="icon"
          src="/images/github-new.png"
          alt="GitHub"
          width="24"
          height="24"
          loading="lazy"
          decoding="async"
          fetchpriority="low"
        />
        <!-- <span class="social-count">1.5K</span> -->
      </a>
      <a
        class="nav-item nav-social border-none"
        href="https://x.com/astroanimate"
        target="_blank"
      >
        <img
          class="icon"
          src="/images/twitter-new.png"
          alt="X (Twitter)"
          width="24"
          height="24"
          loading="lazy"
          decoding="async"
          fetchpriority="low"
        />
        <!-- <span class="social-count">1.5K</span> -->
      </a>
    </div>

    <a href="/docs/installation" class="install-btn nav-item install">INSTALL</a
    >
  </div>
</nav>
