---

---

<div class="features-section">
    <div class="badge">COMPONENT PREVIEW</div>

    <div class="features-header">
        <p class="mini">// COMPONENT PREVIEW</p>
        <h2>
            Astro Animation
            <span>Component Library</span>
        </h2>
        <p class="desc">
            Prebuilt motion components for common UI patterns. Focused on
            clarity and reuse.
        </p>
    </div>

    <section class="grid-section">
        <div class="preview-grid">
            <div class="preview-card">
                <div class="preview-icon-box">
                    <svg
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                    >
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"
                        ></rect>
                        <line x1="15" y1="3" x2="15" y2="21"></line>
                        <path d="M7 10l3 2-3 2"></path>
                    </svg>
                </div>
                <span class="preview-text">slide in</span>
            </div>

            <div class="preview-card">
                <div class="preview-icon-box">
                    <svg
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                    >
                        <circle cx="12" cy="12" r="10"></circle>
                        <polyline points="12 6 12 12 16 14"></polyline>
                        <path d="M12 2v2"></path>
                    </svg>
                </div>
                <span class="preview-text">Stagger</span>
            </div>

            <div class="preview-card">
                <div class="preview-icon-box">
                    <svg
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                    >
                        <circle cx="9" cy="12" r="6"></circle>
                        <circle cx="15" cy="12" r="6"></circle>
                    </svg>
                </div>
                <span class="preview-text">MorphShape</span>
            </div>

            <div class="preview-card">
                <div class="preview-icon-box">
                    <svg
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                    >
                        <rect x="5" y="2" width="14" height="20" rx="7" ry="7"
                        ></rect>
                        <line x1="12" y1="6" x2="12" y2="10"></line>
                    </svg>
                </div>
                <span class="preview-text">RevealOnScroll</span>
            </div>

            <div class="preview-card">
                <div class="preview-icon-box">
                    <svg
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                    >
                        <path d="M3 3l7.07 16.97 2.51-7.39 7.39-2.51L3 3z"
                        ></path>
                        <path d="M13 13l6 6"></path>
                    </svg>
                </div>
                <span class="preview-text">AnimatedButton</span>
            </div>

            <div class="preview-card">
                <div class="preview-icon-box">
                    <svg
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                    >
                        <polygon points="12 2 2 7 12 12 22 7 12 2"></polygon>
                        <polyline points="2 17 12 22 22 17"></polyline>
                        <polyline points="2 12 12 17 22 12"></polyline>
                    </svg>
                </div>
                <span class="preview-text">Parallax</span>
            </div>
        </div>

        <div class="footer">
            <a
                href="#"
                aria-label="View all components in the AstroAnimate library"
                >View all Components →</a
            >
        </div>
    </section>
    <section class="usecases"></section>
</div>
