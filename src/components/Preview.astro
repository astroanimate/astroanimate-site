---

---

<div class="features-section">
    <div class="badge">COMPONENT PREVIEW</div>

    <div class="features-header">
        <p class="mini">// COMPONENT PREVIEW</p>
        <h2>
            Astro Animation
            <span>Component Library</span>
        </h2>
        <p class="desc">
            Prebuilt motion components for common UI patterns. Focused on
            clarity and reuse.
        </p>
    </div>

    <section class="grid-section">
        <div class="preview-grid">
            <div class="preview-card">
                <div class="preview-icon-box">
                    <svg
                        width="20"
                        height="20"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                    >
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"
                        ></rect>
                        <line x1="15" y1="3" x2="15" y2="21"></line>
                        <path d="M7 10l3 2-3 2"></path>
                    </svg>
                </div>
                <span class="preview-text">slide in</span>
            </div>

            <div class="preview-card">
                <div class="preview-icon-box">
                    <img
                        src="/images/stagger.png"
                        alt=""
                        width="24"
                        height="24"
                    />
                </div>
                <span class="preview-text">Stagger</span>
            </div>

            <div class="preview-card">
                <div class="preview-icon-box">
                    <img
                        src="/images/morphshape.png"
                        alt=""
                        width="24"
                        height="24"
                    />
                </div>
                <span class="preview-text">MorphShape</span>
            </div>

            <div class="preview-card">
                <div class="preview-icon-box">
                    <img
                        src="/images/scroll.png"
                        alt=""
                        width="24"
                        height="24"
                    />
                </div>
                <span class="preview-text">RevealOnScroll</span>
            </div>

            <div class="preview-card">
                <div class="preview-icon-box">
                    <img
                        src="/images/animationbtn.png"
                        alt=""
                        width="24"
                        height="24"
                    />
                </div>
                <span class="preview-text">AnimatedButton</span>
            </div>

            <div class="preview-card">
                <div class="preview-icon-box">
                    <img
                        src="/images/parallax.png"
                        alt=""
                        width="24"
                        height="24"
                    />
                </div>
                <span class="preview-text">Parallax</span>
            </div>
        </div>

        <div class="footer">
            <a
                href="#"
                aria-label="View all components in the AstroAnimate library"
                >View all Components →</a
            >
        </div>
    </section>
    <section class="usecases"></section>
</div>
