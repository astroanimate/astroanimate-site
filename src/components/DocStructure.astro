---

---

<section>
    <div class="features-section">
        <div class="badge-border"></div>
        <div class="badge">DOC'S STRUCTURE</div>

        <div class="features-header">
            <p class="mini">// DOC'S STRUCTURE</p>
            <h2>
                How the Documentation
                <span>Motion Is Structured ?</span>
            </h2>
            <p class="desc">
                Every component and API method follows a consistent
                documentation format.
            </p>
        </div>

        <!-- MAIN BOX -->
        <div class="doc-main-box">
            <!-- LEFT SIDEBAR -->
            <div class="doc-sidebar">
                <div class="sidebar-item active" data-tab="component-docs">
                    <div class="icon-box">
                        <img src="/images/doc.png" alt="" class="mini-icon" />
                    </div>
                    <span>Component Documentation Includes</span>
                </div>

                <div class="sidebar-item" data-tab="install-setup">
                    <div class="icon-box">
                        <img src="/images/setup.png" alt="" class="mini-icon" />
                    </div>
                    <span>Install & Setup</span>
                </div>

                <div class="sidebar-item" data-tab="api-reference">
                    <div class="icon-box">
                        <img src="/images/api.png" alt="" class="mini-icon" />
                    </div>
                    <span>API Reference</span>
                </div>

                <div class="sidebar-item" data-tab="example-library">
                    <div class="icon-box">
                        <img
                            src="/images/example.png"
                            alt=""
                            class="mini-icon"
                        />
                    </div>
                    <span>Example Library</span>
                </div>

                <div class="sidebar-item" data-tab="debugging">
                    <div class="icon-box">
                        <img src="/images/debug.png" alt="" class="mini-icon" />
                    </div>
                    <span>Debugging & Edge Cases</span>
                </div>

                <div class="sidebar-line"></div>
            </div>

            <!-- RIGHT CONTENT -->
            <div class="doc-content">
                <!-- Tab 1: Component Documentation -->
                <div class="tab-content active" id="component-docs">
                    <h3>Component Documentation Includes</h3>
                    <ul class="doc-points">
                        <li>
                            TypeScript type definitions (props, return types,
                            defaults)
                        </li>
                        <li>
                            Minimum two working code examples (basic + advanced)
                        </li>
                        <li>Browser compatibility notes</li>
                        <li>Common mistakes and troubleshooting notes</li>
                        <li>
                            Performance considerations (bundle size, hydration
                            impact)
                        </li>
                    </ul>
                    <div class="watermark-icon">
                        <img
                            src="/images/doc.png"
                            alt=""
                            height="80px"
                            width="80px"
                        />
                    </div>
                </div>

                <!-- Tab 2: Install & Setup -->
                <div class="tab-content" id="install-setup">
                    <h3>Install & Setup</h3>
                    <p class="doc-paragraph">
                        Step-by-step guide from npm install to first working
                        animation. Covers project structure, import patterns,
                        and Astro configuration.
                    </p>
                    <div class="watermark-icon">
                        <img
                            src="/images/setup.png"
                            alt=""
                            height="80px"
                            width="80px"
                        />
                    </div>
                </div>

                <!-- Tab 3: API Reference -->
                <div class="tab-content" id="api-reference">
                    <h3>API Reference</h3>
                    <p class="doc-paragraph">
                        Typed props, default values, and configuration options
                        for each component. Searchable reference organized by
                        animation category.
                    </p>
                    <div class="watermark-icon">
                        <img
                            src="/images/api.png"
                            alt=""
                            height="80px"
                            width="80px"
                        />
                    </div>
                </div>

                <!-- Tab 4: Example Library -->
                <div class="tab-content" id="example-library">
                    <h3>Example Library</h3>
                    <p class="doc-paragraph">Categorized examples covering:</p>
                    <ul class="doc-points">
                        <li>Scroll-triggered animations</li>
                        <li>View Transitions integration</li>
                        <li>Component enter/exit patterns</li>
                        <li>Accessible micro-interactions</li>
                    </ul>
                    <div class="watermark-icon">
                        <img
                            src="/images/example.png"
                            alt=""
                            height="80px"
                            width="80px"
                        />
                    </div>
                </div>

                <!-- Tab 5: Debugging -->
                <div class="tab-content" id="debugging">
                    <h3>Debugging & Edge Cases</h3>
                    <ul class="doc-points">
                        <li>Hydration boundary issues</li>
                        <li>SSR rendering behavior</li>
                        <li>Motion preference conflicts</li>
                        <li>Framework version compatibility</li>
                    </ul>
                    <div class="watermark-icon">
                        <img
                            src="/images/debug.png"
                            alt=""
                            height="80px"
                            width="80px"
                        />
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    // Tab switching functionality
    document.addEventListener("DOMContentLoaded", () => {
        const sidebarItems = document.querySelectorAll(".sidebar-item");
        const tabContents = document.querySelectorAll(".tab-content");

        sidebarItems.forEach((item) => {
            item.addEventListener("click", () => {
                const tabId = item.getAttribute("data-tab");

                // Remove active class from all items and contents
                sidebarItems.forEach((i) => i.classList.remove("active"));
                tabContents.forEach((content) =>
                    content.classList.remove("active"),
                );

                // Add active class to clicked item and corresponding content
                item.classList.add("active");
                const targetContent = document.getElementById(tabId || "");
                if (targetContent) {
                    targetContent.classList.add("active");
                }
            });
        });
    });
</script>
