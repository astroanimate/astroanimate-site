---

---

<div class="features-section">
    <div class="badge">LIVE DEMO</div>

    <div class="features-header">
        <p class="mini">/// LIVE DEMOS</p>
        <h2>
            Live Demos in
            <span>Motion</span>
        </h2>
        <p class="desc">
            Test components running inside Astro. See how animations behave with
            Islands, SSR, and intersection-aware logic.
        </p>
    </div>
    <section class="usecases">
        <section class="showcase">
            <div class="grid">
                <!-- CARD 1 -->
                <div class="demo-card">
                    <div class="demo-tag">NPM-CODE</div>

                    <div class="preview box"></div>

                    <h3 class="active">Scroll Reveal Effects</h3>
                    <p>
                        Reveal content on scroll without forcing full hydration.
                    </p>
                </div>

                <!-- CARD 2 -->
                <div class="demo-card">
                    <div class="demo-tag">NPM-CODE</div>

                    <div class="preview square"></div>

                    <h3>Enter & Exit Motion</h3>
                    <p>
                        Control how UI elements appear and disappear within
                        layouts.
                    </p>
                </div>

                <!-- CARD 3 -->
                <div class="demo-card">
                    <div class="demo-tag">NPM-CODE</div>

                    <div class="preview layers">
                        <div></div>
                        <div></div>
                    </div>

                    <h3>Route Transitions</h3>
                    <p>
                        Animate navigation between pages using Astro’s View
                        Transitions API.
                    </p>
                </div>

                <!-- CARD 4 -->
                <div class="demo-card">
                    <div class="demo-tag">NPM-CODE</div>

                    <div class="preview button">HOVER ME</div>

                    <h3>UI Micro-Motion</h3>
                    <p>
                        Enhance buttons, lists, and cards with accessible motion
                        patterns.
                    </p>
                </div>
            </div>
        </section>
    </section>
</div>
