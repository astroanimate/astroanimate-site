<section class="features-section">
    <div class="badge-border"></div>
    <div class="badge">ARCHITECTURE</div>

    <div class="features-header">
        <p class="mini">// ARCHITECTURE</p>
        <h2>
            Architecture Built for
            <span>Predictable Performance</span>
        </h2>

        <ul class="points">
            <li>
                <img
                    class="check-icon"
                    src="/images/checkmark.png"
                    alt=""
                    width="16"
                    height="16"
                    loading="lazy"
                    decoding="async"
                />
                AstroAnimate aligns with Astro's partial hydration model.
            </li>
            <li>
                <img
                    class="check-icon"
                    src="/images/checkmark.png"
                    alt=""
                    width="16"
                    height="16"
                    loading="lazy"
                    decoding="async"
                />
                Motion is structured to work within Astro's rendering model.
            </li>
        </ul>
    </div>

    <div class="archi-grid">
        <!-- 01 -->
        <div class="archi-card border-right border-bottom">
            <div class="top">
                <span class="num">01</span>
                <svg
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="icon-dim"
                    ><rect x="2" y="6" width="20" height="12" rx="6"
                    ></rect><circle cx="17" cy="12" r="3"></circle></svg
                >
            </div>
            <h3>No Forced Hydration</h3>
            <p>
                Components do not trigger global hydration. Client directives
                are opt-in.
            </p>
        </div>

        <!-- 02 -->
        <div class="archi-card border-right border-bottom">
            <div class="top">
                <span class="num">02</span>
                <svg
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="icon-dim"
                    ><path d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5z"
                    ></path><line x1="16" y1="8" x2="2" y2="22"></line><line
                        x1="17.5"
                        y1="15"
                        x2="9"
                        y2="15"></line></svg
                >
            </div>
            <h3>Minimal CSS Footprint</h3>
            <p>
                Animation styles are scoped to components. No global CSS resets.
            </p>
        </div>

        <!-- 05 (SPANNING) -->
        <div class="archi-card span-vertical border-bottom">
            <div class="top">
                <span class="num">05</span>
                <svg
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="icon-dim"
                    ><path
                        d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5s-3 3.5-3 5.5a7 7 0 0 0 7 7z"
                    ></path></svg
                >
            </div>
            <h3>Hydration Impact</h3>
            <p>
                CSS-only animations add zero JavaScript to the client bundle.
                Optional JavaScript-based animations load only when explicitly
                enabled via client directives.
            </p>
            <ul class="stats-list">
                <li>• CSS-only FadeIn component: 0KB JavaScript added</li>
                <li>
                    • GSAP-based timeline component: ~45KB JavaScript (opt-in
                    only)
                </li>
            </ul>
        </div>

        <!-- 03 -->
        <div class="archi-card border-right">
            <div class="top">
                <span class="num">03</span>
                <svg
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="icon-dim"
                    ><polyline points="16 18 22 12 16 6"></polyline><polyline
                        points="8 6 2 12 8 18"></polyline></svg
                >
            </div>
            <h3>Static-First Rendering</h3>
            <p>
                Animations render correctly in fully static builds. No runtime
                dependency required for basic effects.
            </p>
        </div>

        <!-- 04 -->
        <div class="archi-card border-right">
            <div class="top">
                <span class="num">04</span>
                <svg
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="icon-dim"
                    ><circle cx="12" cy="12" r="10"></circle><line
                        x1="10"
                        y1="15"
                        x2="10"
                        y2="9"></line><line x1="14" y1="15" x2="14" y2="9"
                    ></line></svg
                >
            </div>
            <h3>Reduced Motion Support</h3>
            <p>
                Animations automatically disable when users prefer reduced
                motion. Accessibility is built into default behavior.
            </p>
        </div>
    </div>
</section>
