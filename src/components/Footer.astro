---

---

<footer class="footer-section">
    <div class="footer-grid">
        <!-- LEFT COLUMN: LOGO & NEWSLETTER -->
        <div class="footer-main">
            <div class="footer-logo">
                <img
                    src="/images/text-logo.png"
                    alt="AstroAnimate feature visualization"
                    class="logo-bolt"
                    loading="lazy"
                />
                <span class="logo-text"> <span>Animate</span></span>
            </div>

            <p class="last-updated">
                // Last Updated [<span>21-Mar-2026</span>]
                <span class="dot"></span>
            </p>

            <div class="newsletter">
                <p>Subscribe for newsletter</p>
                <div class="subscribe-box">
                    <input
                        type="email"
                        placeholder="Your email address"
                        aria-label="Email for newsletter"
                    />
                    <button type="button">Subscribe</button>
                </div>
            </div>
        </div>

        <!-- PRODUCT SECTION -->
        <div class="footer-column border-left">
            <h3 class="column-title">PRODUCT</h3>
            <ul class="footer-links">
                <li><a href="/docs" class="active">Docs</a></li>
                <li><a href="/playground">Playground</a></li>
                <li><a href="/docs/components">Components</a></li>
                <li><a href="/pricing">Pricing</a></li>
                <li><a href="/changelog">Changelog</a></li>
                <li><a href="/docs/support">Support</a></li>
                <li><a href="/contributing">Contributing</a></li>
            </ul>
        </div>

        <!-- COMPANY SECTION -->
        <div class="footer-column border-left">
            <h3 class="column-title">COMPANY</h3>
            <ul class="footer-links">
                <li><a href="/About">About us</a></li>
                <li><a href="/Contact">Contact us</a></li>
                <li><a href="/Blog">Blog</a></li>
            </ul>
        </div>

        <!-- LEGAL SECTION -->
        <div class="footer-column border-left border-top">
            <h3 class="column-title">LEGAL</h3>
            <ul class="footer-links">
                <li><a href="#">MIT License</a></li>
                <li><a href="/Privacy">Privacy Policy</a></li>
                <li><a href="/terms">Terms of service</a></li>
            </ul>
        </div>

        <!-- COMMUNITY SECTION -->
        <div class="footer-column border-left border-top">
            <h3 class="column-title">COMMUNITY</h3>
            <ul class="footer-links">
                <li><a href="https://github.com">GitHub</a></li>
                <li><a href="https://x.com">X.com</a></li>
                <li><a href="https://discord.com">Discord</a></li>
            </ul>
        </div>
    </div>
</footer>

<!-- BOTTOM BAR -->
<div class="footer-bottom">
    <div class="bottom-content">
        <p>© 2026 AstroAnimate. All Rights Reserved.</p>

        <div class="built-by">
            <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
                ><path
                    d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l8.84-8.84 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"
                ></path></svg
            >
            Built for Astro developers
        </div>

        <div class="utc-time">
            <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
                ><circle cx="12" cy="12" r="10"></circle><polyline
                    points="12 6 12 12 16 14"></polyline></svg
            >
            <span>19:56:24 UTC</span>
            <span class="dot-green"></span>
        </div>
    </div>
</div>
