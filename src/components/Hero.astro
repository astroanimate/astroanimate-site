---
import InstallCard from "./InstallCard.astro";
import Loader from "@astroanimate/core/Loader";
---

<section class="hero">
    <!-- LEFT -->
    <div class="hero-left">
        <div class="status">
            // SYSTEM ONLINE
            <Loader type="pulse" color="#4ADE80" size={14} />
        </div>

        <h1>
            Astro Animation Library <br />
            <span>Built for Astro</span>
        </h1>

        <div class="description-wrap">
            <p class="description">
                Add CSS and Web Animations API–based transitions to Astro
                components. JavaScript is only added when explicitly enabled.
                Optimized for Astro Islands architecture and compatible with the
                View Transitions API.
            </p>
        </div>

        <ul class="features">
            <li>Designed for Astro Islands architecture</li>
            <li>No runtime JavaScript unless opt-in</li>
            <li>Respects prefers-reduced-motion and accessibility standards</li>
        </ul>

        <div class="actions">
            <button
                class="btn-primary"
                aria-label="Install AstroAnimate via NPM"
                >INSTALL VIA NPM</button
            >
            <button
                class="btn-secondary"
                aria-label="Open documentation for AstroAnimate library"
            >
                VIEW DOCUMENTATION
                <svg
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                >
                    <path
                        d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"
                    ></path>
                    <polyline points="14 2 14 8 20 8"></polyline>
                    <line x1="16" y1="13" x2="8" y2="13"></line>
                    <line x1="16" y1="17" x2="8" y2="17"></line>
                    <polyline points="10 9 9 9 8 9"></polyline>
                </svg>
            </button>
        </div>
    </div>

    <!-- RIGHT -->
    <div class="hero-right">
        <InstallCard title="NPM" />
        <!-- <InstallCard title="INSTALL COMMAND" variant="terminal" /> -->
    </div>

    <!-- GLOW VIDEO -->
    <div class="hero-video-wrap">
        <video
            src="/videos/hole-wb-2.mp4"
            autoplay
            loop
            muted
            playsinline
            aria-hidden="true"
            title="AstroAnimate hero glow background"
            width="1200"
            height="600"
            class="hero-video"
            preload="auto"
        >
            <track kind="captions" />
        </video>
    </div>
</section>
