---

---

<section class="how-it-works">
    <div class="badge-border badge-border-noline"></div>

    <div class="badge">HOW IT WORKS</div>
    <div class="section-border-container">
        <!-- CORNER ACCENTS -->
        <div class="corner-accent top-left"></div>
        <div class="corner-accent top-right"></div>
        <div class="corner-accent bottom-left"></div>
        <div class="corner-accent bottom-right"></div>

        <!-- HEADER -->
        <div class="features-header how-it-works-header">
            <div class="header-left">
                <p class="mini">// LETS SEE HOW ASTROANIMATE WORKS</p>
                <h2>How AstroAnimate Works?</h2>
                <p class="desc">
                    Install the core package, import a component, and apply it
                    to your markup. AstroAnimate follows Astro's component
                    model, so animations are added at the component level
                    without changing your rendering setup.
                </p>
            </div>
        </div>

        <!-- VIDEO SECTION -->
        <div class="video-preview">
            <div class="video-container">
                <video
                    src="/videos/demo-vid-v2.mp4"
                    controls
                    autoplay
                    muted
                    loop
                    playsinline
                    class="demo-video"></video>
            </div>
        </div>

        <!-- STEPS GRID -->
        <div class="steps-grid">
            <div class="step-card">
                <div class="num-box">01</div>
                <h3>Step 1 - Install the Core Package</h3>
                <p>
                    The core package provides CSS-first animation components. No
                    JavaScript is included unless you explicitly install
                    additional engine packages.
                </p>
            </div>
            <div class="step-card">
                <div class="num-box">02</div>
                <h3>Step 2 - Import an Animation Component</h3>
                <p>
                    Components are imported directly into your Astro files. Each
                    component represents a specific animation pattern.
                </p>
            </div>
            <div class="step-card">
                <div class="num-box">03</div>
                <h3>Step 3 - Apply It to Your Markup</h3>
                <p>
                    Wrap your elements with animation components. Animations are
                    applied declaratively without modifying your layout
                    structure.
                </p>
            </div>
        </div>
    </div>
</section>

<style>
.video-preview {
    height: auto;
    display: block;
    overflow: hidden;
    background: #020617;
    border-bottom: 1px solid #1f2937;
}

.video-container {
    width: 100%;
    height: auto;
    overflow: hidden;
    background: #000;
}

.demo-video {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
}
</style>
