    </section>

    <!-- BLOG LIST -->
    <section class="blog-list">
      <article class="blog-item" data-category="animations">
        <div class="item-image-box">
          <a
            href="/blog/why-astro-needs-animation-library/"
            class="item-image"
            aria-label="Read Why Astro Needs a Dedicated Animation Library"
          >
            <img
              src="/images/blog-1.png"
              alt="Astro Needs a Dedicated Animation Library"
              loading="lazy"
              decoding="async"
              width="800"
              height="400"
            />
          </a>
        </div>
        <div class="item-content">
          <div class="item-header">
            <span class="category-tag category-animations">// Animations</span>
            <div class="item-meta">
              <span>MAY 04, 2026</span>
              <span class="read-time">(4min read)</span>
            </div>
          </div>
          <h3>
            <a
              href="/blog/why-astro-needs-animation-library/"
              style="color: inherit; text-decoration: none;"
            >
              Why Astro Needs a Dedicated Animation Library (And How
              AstroAnimate Solves It)
            </a>
          </h3>
          <div class="author-simple">
           
              <img
