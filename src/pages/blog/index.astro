              decoding="async"
              width="800"
              height="400"
            />
          </a>
        </div>
        <div class="item-content">
          <div class="item-header">
            <span class="category-tag category-guide">// Guide</span>
            <div class="item-meta">
              <span>MAY 24, 2026</span>
              <span class="read-time">(5min read)</span>
            </div>
          </div>
          <h3>
            <a
              href="/blog/astro-animations-without-runtime-javascript"
              style="color: inherit; text-decoration: none;"
            >
              How to Add Animations in Astro Without Runtime JavaScript
            </a>
          </h3>
          <div class="author-simple">
             <img
                src="/images/prashanth.png"
                alt="Prashanth"
                loading="lazy"
                decoding="async"
                width="40"
                height="40"
                class="author-img"
              />
            <span>Prashanth ks</span>
          </div>
        </div>
      </article>

      <article class="blog-item" data-category="guide">
        <div class="item-image-box">
          <a
            href="/blog/astro-view-transitions-vs-page-animations/"
            class="item-image"
            aria-label="Read Astro View Transitions vs Traditional Page Animations"
          >
            <img
              src="/images/blog-3-cover.png"
              alt="Astro View Transitions cover"
              loading="lazy"
              decoding="async"
              width="800"
              height="400"
            />
          </a>
        </div>
        <div class="item-content">
          <div class="item-header">
            <span class="category-tag category-guide">// Guide</span>
            <div class="item-meta">
              <span>MAY 24, 2026</span>
              <span class="read-time">(6min read)</span>
            </div>
          </div>
          <h3>
            <a
              href="/blog/astro-view-transitions-vs-page-animations/"
              style="color: inherit; text-decoration: none;"
            >
              Astro View Transitions vs Traditional Page Animations
            </a>
          </h3>
          <div class="author-simple">
             <img
                src="/images/prashanth.png"
                alt="Prashanth"
                loading="lazy"
                decoding="async"
                width="40"
                height="40"
                class="author-img"
              />
            <span>Prashanth ks</span>
          </div>
        </div>
      </article>
    </section>
    <!-- 
        <div class="corner b-l"></div>
        <div class="corner b-r"></div> -->
  </main>

  <Footer />
</Layout>

<script>
  function initBlogFilters() {
    const blogContainer =
      document.querySelector<HTMLElement>(".blog-container");
    if (!blogContainer || blogContainer.dataset.blogFiltersReady === "true") return;
    blogContainer.dataset.blogFiltersReady = "true";

    const searchInput = document.getElementById(
      "blog-search",
    ) as HTMLInputElement;
    const categoryButtons = Array.from(
      document.querySelectorAll<HTMLButtonElement>(".category-buttons button"),
    );
    const blogItems = Array.from(
      document.querySelectorAll<HTMLElement>(".blog-list .blog-item"),
    );
    const noResults = document.getElementById("blog-no-results");
    let activeCategory = "all";

    const filterBlogs = () => {
      const query = searchInput?.value.toLowerCase().trim() || "";
      let visibleCount = 0;

      blogItems.forEach((item) => {
        const title =
          item.querySelector("h2, h3")?.textContent?.toLowerCase() || "";
        const category =
          item.querySelector(".category-tag")?.textContent?.toLowerCase() || "";
        const itemCategory = item.dataset.category?.toLowerCase() || "";
        const matchesSearch = !query || title.includes(query) || category.includes(query);
        const matchesCategory =
          activeCategory === "all" || itemCategory === activeCategory;
        const isVisible = matchesSearch && matchesCategory;

        item.style.display = isVisible ? "" : "none";
        if (isVisible) visibleCount += 1;
      });

      if (noResults) {
        noResults.style.display = visibleCount > 0 ? "none" : "block";
      }
    };

    searchInput?.addEventListener("input", filterBlogs);

    categoryButtons.forEach((button) => {
      button.addEventListener("click", () => {
        activeCategory = button.dataset.category || "all";
        categoryButtons.forEach((item) => item.classList.remove("active"));
        button.classList.add("active");
        filterBlogs();
      });
    });

    filterBlogs();
  }

  document.addEventListener("DOMContentLoaded", initBlogFilters);
  document.addEventListener("astro:page-load", initBlogFilters);
</script>

