---
import Layout from "../../layouts/Layout.astro";
import NavBar from "../../components/NavBar.astro";
import Footer from "../../components/Footer.astro";
import "../../styles/Global.css";

const schema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "AstroAnimate Blog",
  description: "Motion design, web performance, and Astro development guides.",
  url: "https://www.astroanimate.com/blog",
  publisher: {
    "@type": "Organization",
    name: "AstroAnimate",
  },
};
---

<Layout
  title="AstroAnimate Blog — Motion Design & Web Performance"
  description="Motion design, web performance, and Astro development guides. Learn how to build faster, more beautiful websites with AstroAnimate."
  schema={schema}
>
  <NavBar />

  <main class="blog-container">
    <!-- HEADER -->
    <header class="standard-header">
      <div class="header-overlay"></div>
      <h1 class="badge-top">BLOG</h1>
    </header>

    <!-- FEATURED SECTION -->
    <section class="featured-grid">
      <div class="page-separator-line"></div>
      <!-- BIG FEATURED -->
      <div class="main-featured">
        <div class="featured-image">
          <img
            src="/images/blog-1.png"
            alt="Astro Needs a Dedicated Animation Library"
            loading="lazy"
            decoding="async"
            width="800"
            height="400"
          />
        </div>
        <div class="featured-content">
          <span class="category-tag">// Blog</span>
          <h2>
            <a
              href="/blog-posts/why-astro-animate"
              style="color: inherit; text-decoration: none;"
            >
              Why Astro Needs a Dedicated Animation Library (And How
              AstroAnimate Solves It)
            </a>
          </h2>
          <p>
            Discover why Astro needs a dedicated Astro animation library and how
            AstroAnimate delivers zero-JS, performance-first animation built for
            Islands Architecture.
          </p>
        </div>
        <div class="featured-footer">
          <span class="read-time">(4min read)</span>
          <div class="author">
            <div class="author-left">
              <img
                src="/images/prashanth.png"
                alt="Prashanth"
                loading="lazy"
                decoding="async"
                width="40"
                height="40"
                class="author-img"
              />
              <span>Prashanth ks</span>
            </div>
            <div class="meta">
              <span>MAR 25, 2026</span>
            </div>
          </div>
        </div>
      </div>

      <!-- SIDE FEATURED -->
      <div class="side-featured">
        <div class="side-card">
          <div class="side-image"></div>
          <div class="side-content">
            <span class="category-tag">// Guide</span>
            <h3>How to add AstroAnimate Animations to your astro projects</h3>
            <div class="side-footer">
              <span>MAR 25, 2026</span>
              <span class="read-time">(4min read)</span>
            </div>
          </div>
        </div>
        <div class="side-card">
          <div class="side-image"></div>
          <div class="side-content">
            <span class="category-tag">// Guide</span>

            <h3>Announcing AstroAnimate Templates</h3>
            <div class="side-footer">
              <span>MAR 26, 2026</span>
              <span class="read-time">(4min read)</span>
            </div>
          </div>
        </div>
      </div>
      <!-- <div class="corner b-l"></div>
            <div class="corner b-r"></div> -->
    </section>

    <!-- SEARCH & CATEGORIES -->
    <section class="filter-section">
      <div class="filter-header">
        <h2>All Blogs</h2>
        <div class="categories-wrap">
          <span class="blog-label">// Categories</span>
          <div class="category-buttons">
            <button class="active">All</button>
            <button>Guide</button>
            <button>Animations</button>
            <button>Updates</button>
            <button>Announcements</button>
          </div>
        </div>
      </div>
      <div class="search-wrap">
        <div class="search-input">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            ><circle cx="11" cy="11" r="8"></circle><line
              x1="21"
              y1="21"
              x2="16.65"
              y2="16.65"></line></svg
          >
          <input type="text" id="blog-search" placeholder="Search" />
        </div>
      </div>
      <div
        id="blog-no-results"
        style="display: none; text-align: center; padding: 40px; color: #9CA3AF;"
      >
        No blog posts found matching your search.
      </div>
    </section>

    <!-- BLOG LIST -->
    <section class="blog-list">
      <article class="blog-item">
        <div class="item-image-box">
          <div class="item-image">
            <img
              src="/images/blog-1.png"
              alt="Astro Needs a Dedicated Animation Library"
              loading="lazy"
              decoding="async"
              width="800"
              height="400"
            />
          </div>
        </div>
        <div class="item-content">
          <div class="item-header">
            <span class="category-tag">// Blog</span>
            <div class="item-meta">
              <span>MAR 25, 2026</span>
              <span class="read-time">(4min read)</span>
            </div>
          </div>
          <h3>
            <a
              href="/blog/why-astro-animate"
              style="color: inherit; text-decoration: none;"
            >
              Why Astro Needs a Dedicated Animation Library (And How
              AstroAnimate Solves It)
            </a>
          </h3>
          <div class="author-simple">
            <div class="author-avatar"></div>
            <span>Prashanth ks</span>
          </div>
        </div>
      </article>

      <article class="blog-item">
        <div class="item-image-box">
          <div class="item-image"></div>
        </div>
        <div class="item-content">
          <div class="item-header">
            <span class="category-tag">// Guide</span>
            <div class="item-meta">
              <span>MAR 25, 2026</span>
              <span class="read-time">(4min read)</span>
            </div>
          </div>
          <h3>How to add AstroAnimate Animations to your astro projects</h3>
          <div class="author-simple">
            <div class="author-avatar"></div>
            <span>Prashanth ks</span>
          </div>
        </div>
      </article>
    </section>
    <!-- 
        <div class="corner b-l"></div>
        <div class="corner b-r"></div> -->
  </main>

  <Footer />
</Layout>

<script>
  function initBlogSearch() {
    const searchInput = document.getElementById(
      "blog-search",
    ) as HTMLInputElement;
    const blogItems = document.querySelectorAll(".blog-item, .main-featured");
    const noResults = document.getElementById("blog-no-results");

    if (!searchInput) return;

    searchInput.addEventListener("input", (e) => {
      const query = (e.target as HTMLInputElement).value.toLowerCase().trim();
      let hasMatch = false;

      blogItems.forEach((item) => {
        const title =
          item.querySelector("h2, h3")?.textContent?.toLowerCase() || "";
        const category =
          item.querySelector(".category-tag")?.textContent?.toLowerCase() || "";
        const isMatch = title.includes(query) || category.includes(query);

        (item as HTMLElement).style.display = isMatch ? "" : "none";
        if (isMatch) hasMatch = true;
      });

      if (noResults) {
        noResults.style.display = hasMatch ? "none" : "block";
      }
    });
  }

  document.addEventListener("DOMContentLoaded", initBlogSearch);
  document.addEventListener("astro:page-load", initBlogSearch);
</script>

