---
import Layout from "../../layouts/Layout.astro";
import NavBar from "../../components/NavBar.astro";
import Footer from "../../components/Footer.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "AstroAnimate Blog",
  description:
    "Articles, release updates, implementation guides, and performance-focused animation content for Astro developers.",
  url: "https://www.astroanimate.com/blog/",
  publisher: {
    "@type": "Organization",
    name: "AstroAnimate",
  },
};
---

<Layout
  title="AstroAnimate Blog — Articles, Updates & Guides"
  description="Articles, release updates, implementation guides, and performance-focused animation content for Astro developers."
  canonical="https://www.astroanimate.com/blog/"
  schema={schema}
>
  <NavBar />

  <main class="blog-container">
    <!-- HEADER -->
    <header class="standard-header">
      <div class="header-overlay"></div>
