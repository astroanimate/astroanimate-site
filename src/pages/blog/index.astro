    </header>

    <!-- FEATURED SECTION -->
    <section class="featured-grid">
      <div class="page-separator-line"></div>
      <!-- BIG FEATURED -->
      <div class="main-featured">
        <div class="featured-image">
          <a
            href="/blog/why-astro-needs-animation-library/"
            aria-label="Read Why Astro Needs a Dedicated Animation Library"
