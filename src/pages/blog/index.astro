              src="/images/blog-1.png"
              alt="Astro Needs a Dedicated Animation Library"
              loading="lazy"
              decoding="async"
              width="800"
              height="400"
            />
          </a>
        </div>
        <div class="featured-content">
          <span class="category-tag">// Blog</span>
          <h2>
            <a
              href="/blog/why-astro-needs-animation-library/"
              style="color: inherit; text-decoration: none;"
            >
              Why Astro Needs a Dedicated Animation Library (And How
              AstroAnimate Solves It)
            </a>
          </h2>
          <p>
            Discover why Astro needs a dedicated Astro animation library and how
            AstroAnimate delivers zero-JS, performance-first animation built for
            Islands Architecture.
          </p>
        </div>
        <div class="featured-footer">
          <span class="read-time">(4min read)</span>
          <div class="author">
            <div class="author-left">
              <img
