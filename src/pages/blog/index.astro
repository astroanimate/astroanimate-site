          <input type="text" id="blog-search" placeholder="Search" />
        </div>
      </div>
      <div
        id="blog-no-results"
        style="display: none; text-align: center; padding: 40px; color: #9CA3AF;"
      >
        No blog posts found matching your search.
      </div>
    </section>

    <!-- BLOG LIST -->
    <section class="blog-list">
      <article class="blog-item" data-category="animations">
        <div class="item-image-box">
          <a
            href="/blog/why-astro-needs-animation-library/"
            class="item-image"
            aria-label="Read Why Astro Needs a Dedicated Animation Library"
          >
            <img
              src="/images/blog-1.png"
              alt="Astro Needs a Dedicated Animation Library"
              loading="lazy"
              decoding="async"
              width="800"
              height="400"
            />
          </a>
        </div>
        <div class="item-content">
          <div class="item-header">
            <span class="category-tag category-animations">// Animations</span>
            <div class="item-meta">
              <span>MAY 04, 2026</span>
              <span class="read-time">(4min read)</span>
            </div>
          </div>
          <h3>
            <a
              href="/blog/why-astro-needs-animation-library/"
              style="color: inherit; text-decoration: none;"
            >
              Why Astro Needs a Dedicated Animation Library (And How
              AstroAnimate Solves It)
            </a>
          </h3>
          <div class="author-simple">
           
              <img
                src="/images/prashanth.png"
                alt="Prashanth"
                loading="lazy"
                decoding="async"
                width="40"
                height="40"
                class="author-img"
              />
            
            <span>Prashanth ks</span>
          </div>
        </div>
      </article>

      <article class="blog-item" data-category="guide">
        <div class="item-image-box">
          <a
            href="/blog/astro-animations-without-runtime-javascript"
            class="item-image"
            aria-label="Read How to Add Animations in Astro Without Runtime JavaScript"
          >
            <img
              src="/images/blog-2-cover.png"
              alt="CSS-first animation component cover"
              loading="lazy"
              decoding="async"
              width="800"
              height="400"
            />
          </a>
        </div>
        <div class="item-content">
          <div class="item-header">
            <span class="category-tag category-guide">// Guide</span>
            <div class="item-meta">
              <span>MAY 24, 2026</span>
              <span class="read-time">(5min read)</span>
            </div>
          </div>
          <h3>
            <a
              href="/blog/astro-animations-without-runtime-javascript"
              style="color: inherit; text-decoration: none;"
            >
              How to Add Animations in Astro Without Runtime JavaScript
            </a>
          </h3>
          <div class="author-simple">
             <img
                src="/images/prashanth.png"
                alt="Prashanth"
                loading="lazy"
                decoding="async"
                width="40"
                height="40"
                class="author-img"
              />
            <span>Prashanth ks</span>
          </div>
        </div>
      </article>

      <article class="blog-item" data-category="guide">
        <div class="item-image-box">
          <a
            href="/blog/astro-view-transitions-vs-page-animations/"
            class="item-image"
            aria-label="Read Astro View Transitions vs Traditional Page Animations"
          >
            <img
              src="/images/blog-3-cover.png"
              alt="Astro View Transitions cover"
              loading="lazy"
              decoding="async"
              width="800"
              height="400"
            />
          </a>
        </div>
        <div class="item-content">
          <div class="item-header">
            <span class="category-tag category-guide">// Guide</span>
            <div class="item-meta">
              <span>MAY 24, 2026</span>
              <span class="read-time">(6min read)</span>
            </div>
          </div>
          <h3>
            <a
              href="/blog/astro-view-transitions-vs-page-animations/"
              style="color: inherit; text-decoration: none;"
            >
              Astro View Transitions vs Traditional Page Animations
            </a>
          </h3>
          <div class="author-simple">
             <img
                src="/images/prashanth.png"
                alt="Prashanth"
                loading="lazy"
                decoding="async"
                width="40"
                height="40"
                class="author-img"
              />
            <span>Prashanth ks</span>
          </div>
        </div>
      </article>
    </section>
    <!-- 
        <div class="corner b-l"></div>
        <div class="corner b-r"></div> -->
  </main>

  <Footer />
</Layout>

<script>
  function initBlogFilters() {
    const blogContainer =
      document.querySelector<HTMLElement>(".blog-container");
    if (!blogContainer || blogContainer.dataset.blogFiltersReady === "true") return;
    blogContainer.dataset.blogFiltersReady = "true";

    const searchInput = document.getElementById(
      "blog-search",
    ) as HTMLInputElement;
    const categoryButtons = Array.from(
      document.querySelectorAll<HTMLButtonElement>(".category-buttons button"),
    );
    const blogItems = Array.from(
      document.querySelectorAll<HTMLElement>(".blog-list .blog-item"),
    );
    const noResults = document.getElementById("blog-no-results");
    let activeCategory = "all";

    const filterBlogs = () => {
      const query = searchInput?.value.toLowerCase().trim() || "";
      let visibleCount = 0;

      blogItems.forEach((item) => {
        const title =
          item.querySelector("h2, h3")?.textContent?.toLowerCase() || "";
        const category =
          item.querySelector(".category-tag")?.textContent?.toLowerCase() || "";
        const itemCategory = item.dataset.category?.toLowerCase() || "";
        const matchesSearch = !query || title.includes(query) || category.includes(query);
        const matchesCategory =
          activeCategory === "all" || itemCategory === activeCategory;
        const isVisible = matchesSearch && matchesCategory;

        item.style.display = isVisible ? "" : "none";
        if (isVisible) visibleCount += 1;
      });

      if (noResults) {
        noResults.style.display = visibleCount > 0 ? "none" : "block";
      }
    };

    searchInput?.addEventListener("input", filterBlogs);

    categoryButtons.forEach((button) => {
      button.addEventListener("click", () => {
        activeCategory = button.dataset.category || "all";
        categoryButtons.forEach((item) => item.classList.remove("active"));
        button.classList.add("active");
        filterBlogs();
      });
    });

    filterBlogs();
  }

  document.addEventListener("DOMContentLoaded", initBlogFilters);
  document.addEventListener("astro:page-load", initBlogFilters);
</script>

<style>
  .blog-container {
    --blog-line: #1F2937;
    max-width: none;
    margin: 0 var(--side-padding);
    padding: 0;
    border-left: 1px solid var(--blog-line);
    border-right: 1px solid var(--blog-line);
    border-bottom: 1px solid var(--blog-line);
  }

  .featured-grid {
    position: relative;
    grid-template-columns: 2fr 1fr;
    border-bottom: 1px solid var(--blog-line);
  }

  .page-separator-line {
    left: 0;
    right: 0;
  }

  .page-separator-line::before,
  .page-separator-line::after {
    top: -5px;
  }

  .main-featured {
    padding: 80px 80px 0;
    border-left: 0;
    border-right: 1px solid var(--blog-line);
    gap: 35px;
  }

  .featured-image,
  .side-image,
  .item-image {
    border: 0;
  }

  .featured-image {
    aspect-ratio: 16 / 8;
  }

  /* .featured-image img,
  .item-image img {
    object-fit: cover;
  } */

  .featured-content {
    padding-bottom: 70px;
  }

  .main-featured h2 {
    margin: 16px 0 0;
    font-size: 30px;
    line-height: 1.18;
  }

  .main-featured p {
    margin: 14px 0 0;
    max-width: 760px;
  }

  .featured-footer {
    margin: 0 -80px;
    padding: 14px 80px;
    border-top: 1px solid var(--blog-line);
  }

  .author {
    padding-top: 0;
  }

  .side-card {
    padding: 40px;
    border-right: 0;
    border-bottom: 1px solid var(--blog-line);
    gap: 18px;
  }

  .side-card h3 {
    margin: 0;
    font-size: 21px;
    line-height: 1.28;
  }

  .side-image {
    aspect-ratio: 16 / 8;
  }

  .filter-section {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 32px;
    padding: 40px;
    border-left: 0;
    border-right: 0;
    border-bottom: 1px solid var(--blog-line);
  }

  .filter-section h2 {
    margin: 0 0 20px;
    line-height: 1.2;
  }

  .categories-wrap {
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
  }

  .category-buttons {
    gap: 8px;
  }

  .category-buttons button {
    border-radius: 0;
    padding: 8px 16px;
  }

  .search-input {
    width: 200px;
    height: 40px;
    border-radius: 0;
  }

  .search-wrap {
    padding-bottom: 0;
  }

  .blog-list {
    border-bottom: 0;
  }

  .blog-item {
    grid-template-columns: 350px minmax(0, 1fr) 164px;
    gap: 0;
    padding: 0;
    border-left: 0;
    border-right: 0;
    border-bottom: 1px solid var(--blog-line);
  }

  .blog-item:last-child {
    border-bottom: 0;
  }

  .item-image-box {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 32px;
    border-right: 1px solid var(--blog-line);
  }

  .item-image {
    display: block;
    width: 100%;
    aspect-ratio: 2 / 1;
  }

  .item-content {
    position: relative;
    min-height: 176px;
    padding: 34px 24px;
    justify-content: center;
  }

  .item-header {
    display: block;
  }

  .item-meta {
    position: static;
    transform: none;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 2px;
    /* padding: 0 24px; */
    text-transform: uppercase;
  }

  .blog-item h3 {
    margin: 12px 0 10px;
    max-width: 720px;
    font-size: 21px;
    line-height: 1.3;
  }

  .author-simple {
    margin-top: 0;
  }

  @media (max-width: 1024px) {
    .featured-grid {
      grid-template-columns: 1fr;
    }

    .main-featured {
      padding: 44px 32px 0;
      border-right: 0;
    }

    .featured-footer {
      margin: 0 -32px;
      padding: 14px 32px;
    }

    .side-featured {
      flex-direction: column;
      border-top: 1px solid var(--blog-line);
    }

    .side-card {
      border-left: 0;
      border-right: 0;
      border-top: 0;
    }

    .filter-section {
      flex-direction: column;
      align-items: stretch;
      padding: 36px 32px;
    }

    .search-wrap,
    .search-input {
      width: 100%;
      box-sizing: border-box;
    }

    .blog-item {
      grid-template-columns: 280px minmax(0, 1fr) 140px;
    }

    .item-image-box {
      padding: 0 24px;
    }
  }

  @media (max-width: 768px) {
    .blog-container {
      margin: 0;
      border-left: 0;
      border-right: 0;
    }

    .featured-grid {
      display: block;
    }

    .main-featured,
    .side-card,
    .filter-section {
      padding-left: 20px;
      padding-right: 20px;
    }

    .main-featured {
      padding-top: 28px;
    }

    .featured-content {
      padding-bottom: 32px;
    }

    .main-featured h2 {
      font-size: 24px;
    }

    .main-featured p {
      font-size: 14px;
    }

    .featured-footer {
      margin: 0 -20px;
      padding-left: 20px;
      padding-right: 20px;
    }

    .categories-wrap {
      align-items: flex-start;
      flex-direction: column;
      width: 100%;
    }

    .category-buttons {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      width: 100%;
    }

    .category-buttons button {
      width: 100%;
      min-width: 0;
    }

    .blog-item {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .item-image-box {
      padding: 20px;
      border-right: 0;
      border-bottom: 1px solid var(--blog-line);
    }

    .item-content {
      min-height: auto;
      padding: 24px 20px;
    }

    .item-meta {
      position: static;
      transform: none;
      flex-direction: row;
      justify-content: flex-start;
      align-items: center;
      padding: 0;
      border-left: 0;
      margin-top: 8px;
    }
  }

  @media (max-width: 520px) {
    .standard-header {
      height: 52px;
    }

    .badge-top {
      font-size: 24px;
    }

    .main-featured,
    .side-card,
    .filter-section {
      padding-left: 16px;
      padding-right: 16px;
    }

    .category-buttons {
      grid-template-columns: 1fr;
    }

    .item-image-box {
      padding: 16px;
    }

    .blog-item h3 {
      font-size: 18px;
    }
  }
</style>
