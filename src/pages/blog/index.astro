                alt="Prashanth"
                loading="lazy"
                decoding="async"
                width="40"
                height="40"
                class="author-img"
              />
              <span>Prashanth ks</span>
            </div>
            <div class="meta">
              <span class="author-date">MAY 04, 2026</span>
            </div>
          </div>
        </div>
      </div>

      <!-- SIDE FEATURED -->
      <div class="side-featured">
        <article class="side-card">
          <a
            href="/blog/astro-animations-without-runtime-javascript"
            class="side-image"
            aria-label="Read Designing CSS-First Animation Components for Astro"
          >
