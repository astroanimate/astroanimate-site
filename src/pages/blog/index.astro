                alt="Prashanth"
                loading="lazy"
                decoding="async"
                width="40"
                height="40"
                class="author-img"
              />
            
            <span>Prashanth ks</span>
          </div>
        </div>
      </article>

      <article class="blog-item" data-category="guide">
        <div class="item-image-box">
          <a
            href="/blog/astro-animations-without-runtime-javascript"
            class="item-image"
            aria-label="Read How to Add Animations in Astro Without Runtime JavaScript"
