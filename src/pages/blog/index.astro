            <img
              src="/images/blog-3-cover.png"
              alt="Astro View Transitions cover"
              loading="lazy"
              decoding="async"
              width="800"
              height="500"
            />
          </a>
          <span class="category-tag category-performance">// Performance</span>
          <h3>
            <a
              href="/blog/astro-view-transitions-vs-page-animations/"
              style="color: inherit; text-decoration: none;"
            >
              Astro View Transitions vs Traditional Page Animations
            </a>
          </h3>
          <div class="side-footer">
            <span>MAY 24, 2026</span>
            <span>(6min read)</span>
          </div>
        </article>
      </div>
      <!-- <div class="corner b-l"></div>
            <div class="corner b-r"></div> -->
    </section>

    <!-- SEARCH & CATEGORIES -->
    <section class="filter-section">
      <div class="filter-header">
        <h2>All Blogs</h2>
        <div class="categories-wrap">
          <span class="blog-label">// Categories</span>
          <div class="category-buttons">
            <button type="button" class="active" data-category="all">All</button>
            <button type="button" data-category="guide">Guide</button>
            <button type="button" data-category="animations">Animations</button>
            <button type="button" data-category="updates">Updates</button>
            <button type="button" data-category="announcements">Announcements</button>
          </div>
        </div>
      </div>
      <div class="search-wrap">
