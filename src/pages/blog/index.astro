---
import Layout from "../../layouts/Layout.astro";
import NavBar from "../../components/NavBar.astro";
import Footer from "../../components/Footer.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "AstroAnimate Blog",
  description:
    "Articles, release updates, implementation guides, and performance-focused animation content for Astro developers.",
  url: "https://www.astroanimate.com/blog/",
  publisher: {
    "@type": "Organization",
    name: "AstroAnimate",
  },
};
---

<Layout
  title="AstroAnimate Blog — Articles, Updates & Guides"
  description="Articles, release updates, implementation guides, and performance-focused animation content for Astro developers."
  canonical="https://www.astroanimate.com/blog/"
  schema={schema}
>
  <NavBar />

  <main class="blog-container">
    <!-- HEADER -->
    <header class="standard-header">
      <div class="header-overlay"></div>
      <h1 class="badge-top">BLOG</h1>
    </header>

    <!-- FEATURED SECTION -->
    <section class="featured-grid">
      <div class="page-separator-line"></div>
      <!-- BIG FEATURED -->
      <div class="main-featured">
        <div class="featured-image">
          <a
            href="/blog/why-astro-needs-animation-library/"
            aria-label="Read Why Astro Needs a Dedicated Animation Library"
          >
            <img
              src="/images/blog-1.png"
              alt="Astro Needs a Dedicated Animation Library"
              loading="lazy"
              decoding="async"
              width="800"
              height="400"
            />
          </a>
        </div>
        <div class="featured-content">
          <span class="category-tag">// Blog</span>
          <h2>
            <a
              href="/blog/why-astro-needs-animation-library/"
              style="color: inherit; text-decoration: none;"
            >
              Why Astro Needs a Dedicated Animation Library (And How
              AstroAnimate Solves It)
            </a>
          </h2>
          <p>
            Discover why Astro needs a dedicated Astro animation library and how
            AstroAnimate delivers zero-JS, performance-first animation built for
            Islands Architecture.
          </p>
        </div>
        <div class="featured-footer">
          <span class="read-time">(4min read)</span>
          <div class="author">
            <div class="author-left">
              <img
                src="/images/prashanth.png"
                alt="Prashanth"
                loading="lazy"
                decoding="async"
                width="40"
                height="40"
                class="author-img"
              />
              <span>Prashanth ks</span>
            </div>
            <div class="meta">
              <span class="author-date">MAY 04, 2026</span>
            </div>
          </div>
        </div>
      </div>

      <!-- SIDE FEATURED -->
      <div class="side-featured">
        <article class="side-card">
          <a
            href="/blog/astro-animations-without-runtime-javascript"
            class="side-image"
            aria-label="Read Designing CSS-First Animation Components for Astro"
          >
            <img
              src="/images/blog-2-cover.png"
              alt="CSS-first animation component cover"
              loading="lazy"
              decoding="async"
              width="800"
              height="500"
            />
          </a>
          <span class="category-tag catgegory-grid-guide">// Guide</span>
          <h3>
            <a
              href="/blog/astro-animations-without-runtime-javascript"
              style="color: inherit; text-decoration: none;"
            >
              How to Add Animations in Astro Without Runtime JavaScript
            </a>
          </h3>
          <div class="side-footer">
            <span>MAY 24, 2026</span>
            <span>(5min read)</span>
          </div>
        </article>
        <article class="side-card">
          <a
            href="/blog/astro-view-transitions-vs-page-animations/"
            class="side-image"
            aria-label="Read Astro View Transitions vs Traditional Page Animations"
          >
            <img
              src="/images/blog-3-cover.png"
              alt="Astro View Transitions cover"
              loading="lazy"
              decoding="async"
              width="800"
              height="500"
            />
          </a>
          <span class="category-tag category-performance">// Performance</span>
          <h3>
            <a
              href="/blog/astro-view-transitions-vs-page-animations/"
              style="color: inherit; text-decoration: none;"
            >
              Astro View Transitions vs Traditional Page Animations
            </a>
          </h3>
          <div class="side-footer">
            <span>MAY 24, 2026</span>
            <span>(6min read)</span>
          </div>
        </article>
      </div>
      <!-- <div class="corner b-l"></div>
            <div class="corner b-r"></div> -->
    </section>

    <!-- SEARCH & CATEGORIES -->
    <section class="filter-section">
      <div class="filter-header">
        <h2>All Blogs</h2>
        <div class="categories-wrap">
          <span class="blog-label">// Categories</span>
          <div class="category-buttons">
            <button type="button" class="active" data-category="all">All</button>
            <button type="button" data-category="guide">Guide</button>
            <button type="button" data-category="animations">Animations</button>
            <button type="button" data-category="updates">Updates</button>
            <button type="button" data-category="announcements">Announcements</button>
          </div>
        </div>
      </div>
      <div class="search-wrap">
        <div class="search-input">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            ><circle cx="11" cy="11" r="8"></circle><line
              x1="21"
              y1="21"
              x2="16.65"
              y2="16.65"></line></svg
