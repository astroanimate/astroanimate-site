<script>
  function initArticleInteractions() {
    const article = document.querySelector<HTMLElement>(".article-container");
    if (!article || article.dataset.articleReady === "true") return;
    article.dataset.articleReady = "true";

    const copyButton =
      document.querySelector<HTMLButtonElement>(".copy-link-btn");
    const tocLinks = Array.from(
      document.querySelectorAll<HTMLAnchorElement>(
        ".table-of-contents .toc-link",
      ),
    );
    const sections = tocLinks
      .map((link) => {
        const id = link.getAttribute("href")?.replace("#", "");
        return id ? document.getElementById(id) : null;
      })
      .filter((section): section is HTMLElement => Boolean(section));

    copyButton?.addEventListener("click", async () => {
      const pageUrl = window.location.href;

      try {
        if (navigator.clipboard?.writeText) {
          await navigator.clipboard.writeText(pageUrl);
        } else {
          throw new Error("Clipboard API unavailable");
        }
      } catch {
        const fallback = document.createElement("textarea");
        fallback.value = pageUrl;
        fallback.setAttribute("readonly", "");
        fallback.style.position = "fixed";
        fallback.style.opacity = "0";
        document.body.appendChild(fallback);
        fallback.select();
        document.execCommand("copy");
        fallback.remove();
      }

      copyButton.classList.add("copied");
      copyButton.textContent = "Copied";

      window.setTimeout(() => {
        copyButton.classList.remove("copied");
        copyButton.textContent = "Copy Link";
      }, 1800);
    });

    tocLinks.forEach((link) => {
      link.addEventListener("click", (event) => {
        const id = link.getAttribute("href")?.replace("#", "");
        const target = id ? document.getElementById(id) : null;
        if (!target) return;

        event.preventDefault();
        tocLinks.forEach((item) => item.classList.remove("active"));
        link.classList.add("active");
        target.scrollIntoView({ behavior: "smooth", block: "start" });
        history.replaceState(null, "", `#${id}`);
      });
    });

    if (!sections.length) return;

    const setActiveTocLink = (activeId: string) => {
      tocLinks.forEach((link) => {
        link.classList.toggle(
          "active",
          link.getAttribute("href") === `#${activeId}`,
        );
      });
    };

    const updateActiveTocLink = () => {
      const activationLine = 160;
      const currentSection =
        sections
          .filter((section) => section.getBoundingClientRect().top <= activationLine)
          .at(-1) || sections[0];

      setActiveTocLink(currentSection.id);
    };

    let ticking = false;
    window.addEventListener(
      "scroll",
      () => {
        if (ticking) return;
        ticking = true;

        requestAnimationFrame(() => {
          updateActiveTocLink();
          ticking = false;
        });
      },
      { passive: true },
    );

    updateActiveTocLink();
  }

  document.addEventListener("DOMContentLoaded", initArticleInteractions);
  document.addEventListener("astro:page-load", initArticleInteractions);
</script>
