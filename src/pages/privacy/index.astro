---
import Layout from "../../layouts/Layout.astro";
import NavBar from "../../components/NavBar.astro";
import Footer from "../../components/Footer.astro";
import "../../styles/Global.css";
---

<Layout title="Privacy Policy - AstroAnimate">
  <NavBar />

  <main class="page-container">
    <!-- HEADER -->
    <header class="standard-header">
      <!-- <div class="badge-border"></div> -->
      <div class="header-overlay"></div>
      <div class="badge-top">Privacy Policy</div>
      <!-- <div class="corner t-l"></div> -->
      <!-- <div class="corner t-r"></div> -->
    </header>

    <!-- CONTENT -->
    <div class="page-separator-line"></div>

    <section class="page-content">
      <div class="content-header">
        <span class="content-meta">// Effective date: March 27, 2026</span>
        <p>
          This Privacy Policy explains how AstroAnimate collects, uses, and
          handles information. AstroAnimate is designed with minimal data
          collection. We do not require user accounts and do not collect
          personal data beyond what is necessary to operate and improve the
          project.
        </p>
      </div>

      <div class="content-row">
        <h2>Information We Collect</h2>
        <p>
          AstroAnimate collects limited information to maintain and improve the
          website and project.
        </p>
        <h3 class="privacy-sub">Analytics Data</h3>
        <p>We use Google Analytics to collect basic usage data such as:</p>
        <div class="takeaway-points">
          <ul>
            <li>
              <span class="diamond"></span>
              Page views
            </li>
            <li>
              <span class="diamond"></span>
              Browser type
            </li>
            <li>
              <span class="diamond"></span>
              Device type
            </li>
            <li>
              <span class="diamond"></span>
              Referrer information
            </li>
          </ul>
          <p>
            Google Analytics may process limited technical data such as IP
            addresses. Where possible, IP anonymization and privacy-focused
            settings are enabled. This data is aggregated and not intended to
            identify individual users. Aggregated data cannot be used to
            identify individual users, and we do not attempt to do so.Google
            Analytics data is governed by Google’s Privacy Policy.
          </p>

          <h3 class="privacy-sub">Contact Information</h3>
          <p>If you contact us via email, we may store:</p>
          <div class="takeaway-points">
            <ul>
              <li>
                <span class="diamond"></span>
                Your email address
              </li>
              <li>
                <span class="diamond"></span>
                The content of your message
              </li>
            </ul>
            <p>This is used only to respond to your request.</p>
            <h3 class="privacy-sub">GitHub Interactions</h3>
            <p>
              If you interact with AstroAnimate via GitHub (issues, pull
              requests, discussions):
            </p>
            <div class="takeaway-points">
              <ul>
                <li>
                  <span class="diamond"></span>
                  Your GitHub username and public activity are visible as part of
                  the GitHub platform
                </li>
                <li>
                  <span class="diamond"></span>
                  This data is governed by GitHub's Privacy Policy
                </li>
              </ul>

              <h3 class="privacy-sub">What We Do Not Collect</h3>

              <div class="takeaway-points">
                <ul>
                  <li>
                    <span class="diamond"></span>
                    No account registration data
                  </li>
                  <li>
                    <span class="diamond"></span>
                    No personal profiles
                  </li>
                  <li>
                    <span class="diamond"></span>
                    No payment information
                  </li>
                  <li>
                    <span class="diamond"></span>
                    No sensitive personal data (such as financial or identity data)
                  </li>
                </ul>
              </div>
            </div>

            <div class="content-row">
              <h2>How We Use Information</h2>
              <p>Collected information is used for the following purposes:</p>

              <div class="takeaway-points">
                <ul>
                  <li>
                    <span class="diamond"></span>
                    To understand how the website and documentation are used
                  </li>
                  <li>
                    <span class="diamond"></span>
                    To improve components, documentation, and developer experience
                  </li>
                  <li>
                    <span class="diamond"></span>
                    To respond to support requests or inquiries
                  </li>
                  <li>
                    <span class="diamond"></span>
                    To maintain the reliability and performance of the site
                  </li>
                </ul>
                <p>
                  We do not use collected data for advertising or profiling.
                </p>
              </div>
            </div>

            <div class="content-row">
              <h2>Data Controller</h2>
              <p>
                AstroAnimate acts as the data controller for the limited data
                collected through the website.
              </p>
            </div>

            <div class="content-row">
              <h2>Data Retention</h2>
              <p>
                We retain data only as long as necessary to fulfill its original
                purpose:
              </p>
              <div class="takeaway-points">
                <ul>
                  <li>
                    <span class="diamond"></span>
                    Analytics data — retention is configured within Google Analytics
                    settings and limited to the minimum necessary duration
                  </li>
                  <li>
                    <span class="diamond"></span>
                    Email communications — retained only as long as needed to resolve
                    your inquiry, then deleted
                  </li>
                  <li>
                    <span class="diamond"></span>
                    GitHub activity — governed by GitHub's own retention policies
                  </li>
                </ul>
                <p>
                  You may request deletion of email communications at any time
                  by contacting us.
                </p>
              </div>
            </div>

            <div class="content-row">
              <h2>Cookies and Tracking</h2>
              <p>
                AstroAnimate uses Google Analytics for basic usage insights.
              </p>
              <p>This includes, but is not limited to:</p>
              <div class="takeaway-points">
                <ul>
                  <li>
                    <span class="diamond"></span>
                    Cookies may be used for analytics functionality
                  </li>
                  <li>
                    <span class="diamond"></span>
                    We do not use cookies for advertising or cross-site tracking
                  </li>
                  <li>
                    <span class="diamond"></span>
                    We do not track users across different websites
                  </li>
                  <li>
                    <span class="diamond"></span>
                    Where required by applicable law, analytics cookies are used only
                    with user consent
                  </li>
                  <li>
                    <span class="diamond"></span>
                    You can disable cookies at any time through your browser settings
                  </li>
                </ul>
              </div>
              <p>
                Analytics is configured to collect aggregated data and does not
                intentionally collect personally identifiable information.
              </p>
            </div>

            <div class="content-row">
              <h2>Third-Party Services</h2>
              <p>
                AstroAnimate relies on third-party services to operate. These
                services may collect data independently according to their own
                policies:
              </p>

              <div class="takeaway-points">
                <ul>
                  <li>
                    <span class="diamond"></span>
                    GitHub — repository hosting, issues, and contributions
                  </li>
                  <li>
                    <span class="diamond"></span>
                    Cloudflare Pages — hosting and content delivery
                  </li>
                  <li>
                    <span class="diamond"></span>
                    Google Analytics — usage analytics
                  </li>
                </ul>
              </div>
              <p>
                We do not control how these services collect or use data outside
                of our configuration.
              </p>
            </div>

            <div class="content-row">
              <h2>International Data Transfers</h2>
              <p>
                Data may be processed in countries outside your own, depending
                on the infrastructure of third-party service providers such as
                GitHub, Cloudflare, and Google Analytics.
              </p>

              <p>
                These providers may store or process data in multiple regions.
              </p>
            </div>

            <div class="content-row">
              <h2>Data Sharing</h2>
              <p>
                We do not sell, rent, or share user data with advertisers or
                third parties for marketing purposes.
              </p>
              <p>Data may be shared only in the following cases:</p>
              <div class="takeaway-points">
                <ul>
                  <li>
                    <span class="diamond"></span>
                    With service providers required to operate the website
                  </li>
                  <li>
                    <span class="diamond"></span>
                    When required by applicable law or legal process
                  </li>
                </ul>
              </div>
            </div>

            <div class="content-row">
              <h2>Data Security</h2>
              <p>
                We implement reasonable technical measures to protect
                information handled by the website.
              </p>
              <p>However:</p>

              <div class="takeaway-points">
                <ul>
                  <li>
                    <span class="diamond"></span>
                    No method of transmission over the internet is completely secure
                  </li>
                  <li>
                    <span class="diamond"></span>
                    We cannot guarantee the absolute security of data in transit or
                    at rest
                  </li>
                </ul>
              </div>
            </div>

            <div class="content-row">
              <h2>Your Rights</h2>
              <p>Depending on your location, you may have the right to:</p>
              <div class="takeaway-points">
                <ul>
                  <li>
                    <span class="diamond"></span>
                    Request access to any personal data you have provided
                  </li>
                  <li>
                    <span class="diamond"></span>
                    Request deletion of your data (such as email communications)
                  </li>
                  <li>
                    <span class="diamond"></span>
                    Object to or restrict certain uses of your data
                  </li>
                  <li>
                    <span class="diamond"></span>
                    Contact us regarding any privacy concern
                  </li>
                </ul>
              </div>
              <p>
                Since AstroAnimate does not maintain user accounts, personal
                data associated with individuals is minimal.
              </p>
              <p>
                To exercise any of these rights, contact:
                <p>
                  <a href="mailto:privacy@astroanimate.com" class="content-link"
                    >support@astroanimate.com</a
                  >
                </p>
              </p>

              <div class="content-row">
                <h2>Children's Privacy</h2>
                <p>
                  AstroAnimate is not intended for use by children under the age
                  of 13. We do not knowingly collect data from children.
                </p>
                <p>
                  If you believe a child has provided personal information,
                  contact us and it will be deleted.
                </p>
              </div>

              <div class="content-row">
                <h2>Changes to This Policy</h2>
                <p>This Privacy Policy may be updated over time.</p>
                <div class="takeaway-points">
                  <ul>
                    <li>
                      <span class="diamond"></span>
                      Updates will be reflected on this page
                    </li>
                    <li>
                      <span class="diamond"></span>
                      The effective date will be revised
                    </li>
                    <li>
                      <span class="diamond"></span>
                      Continued use of the website indicates acceptance of the updated
                      policy
                    </li>
                  </ul>
                </div>
                <p>
                  Any disputes arising from these terms shall be subject to the
                  jurisdiction of the courts located in Kottayam, Kerala, India.
                </p>
              </div>

              <div class="content-row">
                <h2>Contact</h2>
                <p>For privacy-related questions or requests, contact:</p>
                <p>
                  <a href="mailto:support@astroanimate.com" class="content-link"
                    >support@astroanimate.com</a
                  >
                </p>
              </div>
            </div>
          </div>

          <Footer />
        </div>
      </div>
    </section>
  </main></Layout
>
