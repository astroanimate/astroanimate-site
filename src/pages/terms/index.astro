---
import Layout from "../../layouts/Layout.astro";
import NavBar from "../../components/NavBar.astro";
import Footer from "../../components/Footer.astro";
import "../../styles/Global.css";
---

<Layout title="Terms of Service - AstroAnimate">
    <NavBar />

    <main class="page-container">
        <!-- HEADER -->
        <header class="standard-header">
            <!-- <div class="badge-border"></div> -->
            <div class="header-overlay"></div>
            <div class="badge-top">TERMS OF SERVICE</div>
            <!-- <div class="corner t-l"></div> -->
            <!-- <div class="corner t-r"></div> -->
        </header>

        <!-- CONTENT -->            <div class="page-separator-line"></div>

        <section class="page-content">

            <div class="terms-header">
                
                <span class="content-meta">// Effective date: March 27, 2026</span
                >
                <p>
                    These Terms of Service govern your access to and use of
                    AstroAnimate, including the library, website, documentation,
                    and repository. By accessing or using any of these
                    resources, you agree to be bound by these terms.
                </p>
            </div>

            <div class="content-row">
                <h2>Use of the Library</h2>
                <p>
                    AstroAnimate is an open-source animation library for the
                    Astro framework.
                </p>
                <div class="takeaway-points">
                    <ul>
                        <li>
                            <span class="diamond"></span>
                            The core library is available under the MIT License
                        </li>
                        <li>
                            <span class="diamond"></span>
                            You may use, modify, and integrate the library into personal
                            and commercial projects
                        </li>
                        <li>
                            <span class="diamond"></span>
                            You are responsible for how AstroAnimate is used within
                            your applications
                        </li>
                    </ul>
                </div>

                <p>
                    Use of the website, documentation, and repository must
                    comply with these terms.
                </p>
            </div>

            <div class="content-row">
                <h2>Open Source License</h2>
                <p>
                    The AstroAnimate core library is licensed under the MIT
                    License.
                </p>
                <a href="#" class="content-link"
                    >View the MIT License → opensource.org/licenses/MIT</a
                >
                <p>Under this license, you may:</p>
                <div class="takeaway-points">
                    <ul>
                        <li>
                            <span class="diamond"></span>
                            Use the software for personal and commercial purposes
                        </li>
                        <li>
                            <span class="diamond"></span>
                            Modify and distribute the code
                        </li>
                        <li>
                            <span class="diamond"></span>
                            Include it in proprietary projects
                        </li>
                    </ul>
                    <div class="highlight-wrap">
                        <p class="highlight-text">
                            The library is provided "as is" — without warranties
                            of any kind. This means no guarantees are made about
                            uptime, output quality, or compatibility. This is
                            standard for open-source software under the MIT
                            License.
                        </p>
                    </div>
                </div>
            </div>

            <div class="content-row">
                <h2>Paid Plans</h2>
                <p>
                    AstroAnimate does not currently offer paid plans. If
                    optional paid plans are introduced in the future:
                </p>
                <div class="takeaway-points">
                    <ul>
                        <li>
                            <span class="diamond"></span>
                            They will provide additional services such as priority
                            support, integrations, or enterprise features
                        </li>
                        <li>
                            <span class="diamond"></span>
                            They will not restrict access to the open-source core
                            library
                        </li>
                        <li>
                            <span class="diamond"></span>
                            Their use will be subject to separate terms, published
                            at that time
                        </li>
                    </ul>
                    <p>
                        The core library remains available under the MIT License
                        regardless of any future commercial offerings.
                    </p>
                </div>
            </div>

            <div class="content-row">
                <h2>Acceptable Use</h2>
                <p>You agree not to use AstroAnimate in ways that:</p>
                <div class="takeaway-points">
                    <ul>
                        <li>
                            <span class="diamond"></span>
                            Violate laws or regulations
                        </li>
                        <li>
                            <span class="diamond"></span>
                            Attempt to misuse or disrupt any related infrastructure
                        </li>
                        <li>
                            <span class="diamond"></span>
                            Misrepresent the AstroAnimate project, branding, or identity
                            as your own
                        </li>
                    </ul>
                </div>
            </div>

            <div class="content-row">
                <h2>Termination</h2>
                <p>
                    We reserve the right to restrict or terminate your access to
                    AstroAnimate's website, documentation, or associated
                    services if these terms are violated.
                </p>
                <p>This includes, but is not limited to:</p>
                <div class="takeaway-points">
                    <ul>
                        <li>
                            <span class="diamond"></span>
                            Misuse of infrastructure or related services
                        </li>
                        <li>
                            <span class="diamond"></span>
                            Violation of the Acceptable Use conditions above
                        </li>
                        <li>
                            <span class="diamond"></span>
                            Actions that harm the project, its maintainers, or its
                            community
                        </li>
                    </ul>
                </div>
                <p>
                    Termination does not affect your rights under the MIT
                    License to use code already obtained from the repository.
                    Access to publicly available open-source code on GitHub
                    cannot be restricted in the same way, as it is governed by
                    GitHub's own terms and the MIT License.
                </p>
            </div>

            <div class="content-row">
                <h2>Intellectual Property</h2>
                <p>
                    The AstroAnimate codebase is open-source under the MIT
                    License.
                </p>
                <p>
                    However, the following are not covered by the MIT License:
                </p>

                <div class="takeaway-points">
                    <ul>
                        <li>
                            <span class="diamond"></span>
                            The AstroAnimate name, branding, and logo remain the property
                            of the project maintainers
                        </li>
                        <li>
                            <span class="diamond"></span>
                            You may not use the branding in any way that implies endorsement
                            or ownership without explicit written permission
                        </li>
                    </ul>
                </div>
                <p>
                    To request permission for branding use — such as partnership
                    pages, tutorials, or integrations — contact: <a
                        href="mailto:support@astroanimate.com"
                        class="content-link">support@astroanimate.com</a
                    >
                </p>
            </div>

            <div class="content-row">
                <h2>Disclaimer of Warranties</h2>
                <p>
                    AstroAnimate is provided "as is" without warranties of any
                    kind, including but not limited to:
                </p>
                <div class="takeaway-points">
                    <ul>
                        <li>
                            <span class="diamond"></span>
                            Performance or reliability
                        </li>
                        <li>
                            <span class="diamond"></span>
                            Fitness for a particular purpose
                        </li>
                        <li>
                            <span class="diamond"></span>
                            Compatibility with all environments or Astro versions
                        </li>
                    </ul>
                </div>
                <p>
                    AstroAnimate does not guarantee support, maintenance, or
                    updates of any kind.
                </p>
                <div class="highlight-wrap">
                    <p class="highlight-text">
                        Use of the software is at your own risk. This disclaimer
                        is consistent with the MIT License under which the
                        library is distributed.
                    </p>
                </div>
            </div>

            <div class="content-row">
                <h2>Limitation of Liability</h2>
                <p>
                    To the extent permitted under applicable Indian law,
                    including the Information Technology Act, 2000:
                </p>
                <div class="takeaway-points">
                    <ul>
                        <li>
                            <span class="diamond"></span>
                            The maintainers of AstroAnimate are not liable for any
                            damages resulting from the use or inability to use the
                            software
                        </li>
                        <li>
                            <span class="diamond"></span>
                            This includes direct, indirect, incidental, or consequential
                            damages
                        </li>
                    </ul>
                </div>
                <p>
                    You assume full responsibility for how the library is used
                    in your projects.
                </p>
            </div>

            <div class="content-row">
                <h2>Indemnification</h2>
                <p>
                    You agree to indemnify and hold harmless the maintainers of
                    AstroAnimate from any claims, damages, losses, or expenses —
                    including legal fees — arising from:
                </p>

                <div class="takeaway-points">
                    <ul>
                        <li>
                            <span class="diamond"></span>
                            Your use of the library or associated services
                        </li>
                        <li>
                            <span class="diamond"></span>
                            Your violation of these Terms of Service
                        </li>
                        <li>
                            <span class="diamond"></span>
                            Any third-party claims resulting from your application
                            or product
                        </li>
                    </ul>
                </div>
                <p>
                    This clause applies to the maximum extent permitted under
                    applicable law, including applicable Indian law.
                </p>
            </div>

            <div class="content-row">
                <h2>Third-Party Services</h2>
                <p>
                    AstroAnimate relies on or integrates with the following
                    third-party services:
                </p>
                <div class="takeaway-points">
                    <ul>
                        <li>
                            <span class="diamond"></span>
                            GitHub — repository hosting, issue tracking, and contributions
                        </li>
                        <li>
                            <span class="diamond"></span>
                            Cloudflare Pages — website and documentation hosting
                        </li>
                    </ul>
                </div>
                <p>
                    Each of these services operates under its own terms of
                    service and privacy policy. AstroAnimate does not control
                    their data practices. Review their terms independently
                    before use.
                </p>
            </div>

            <div class="content-row">
                <h2>Changes to These Terms</h2>
                <p>
                    These Terms of Service may be updated from time to time.
                    When material changes are made:
                </p>
                <div class="takeaway-points">
                    <ul>
                        <li>
                            <span class="diamond"></span>
                            The updated terms will be published on this page
                        </li>
                        <li>
                            <span class="diamond"></span>
                            The effective date at the top of this document will be
                            revised
                        </li>
                        <li>
                            <span class="diamond"></span>
                            Continued use of AstroAnimate after the effective date
                            constitutes acceptance of the updated terms
                        </li>
                    </ul>
                </div>
                <div class="highlight-wrap">
                    <p class="highlight-text">
                        If you disagree with a material change, discontinue use
                        of the library and associated services before the
                        updated terms take effect.
                    </p>
                </div>
            </div>

            <div class="content-row">
                <h2>Governing Law</h2>
                <p>
                    These Terms of Service are governed by and construed in
                    accordance with the laws of India, specifically:
                </p>
                <div class="takeaway-points">
                    <ul>
                        <li>
                            <span class="diamond"></span>
                            The Information Technology Act, 2000
                        </li>
                        <li>
                            <span class="diamond"></span>
                            The Consumer Protection Act, 2019, where applicable
                        </li>
                    </ul>
                </div>
                <p>
                    Any disputes arising from these terms shall be subject to
                    the jurisdiction of the courts located in Kottayam, Kerala,
                    India.
                </p>
            </div>

            <div class="content-row">
                <h2>Contact</h2>
                <p>For questions about these terms, contact:</p>
                <p>
                    <a href="mailto:support@astroanimate.com" class="content-link"
                        >support@astroanimate.com</a>
                </p>
