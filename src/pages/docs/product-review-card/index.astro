---
import DocLayout from "../../../layouts/DocLayout.astro";
import RelatedComponents from "../../../components/RelatedComponents.astro";
import "../../../styles/Global.css";
import ProductReviewCard from "@astroanimate/core/ProductReviewCard";
---

<DocLayout title="ProductReviewCard">
    <section id="product-review-card">
        <h1 class="docs-title">
            ProductReviewCard <span class="docs-new-pill">NEW</span>
            <button
                type="button"
                class="docs-title-share"
                aria-label="Copy page link"
                ><img
                    src="/images/share-link.png"
                    alt=""
                    width="16"
                    height="16"
                /></button
            >
        </h1>

        <div class="docs-intro-section">
            <p class="docs-paragraph">
                A clean, responsive, CSS-only product review card featuring a
                subtle ambient glow and hover scale effect.
            </p>
        </div>

        <!-- PREVIEW/PLAYGROUND SECTION -->
        <div class="docs-intro-section" id="preview-playground">
            <div
                style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px;"
            >
                <h2 class="docs-subtitle" style="margin: 0;">
                    Preview/Playground
                </h2>
            </div><div class="created-by">
                <span class="created-by-label">Created by</span><div
                    class="created-by-avatar"
                >
                    <img src="/images/prashanth.png" alt="Creator" />
                </div><span class="created-by-name">Prashanth</span>
            </div><div class="playground-container">
                <div class="playground-preview">
                    <button
                        type="button"
                        class="preview-reload-btn"
                        onclick="location.reload()"
                        aria-label="Refresh preview"
                        ><svg
                            width="14"
                            height="14"
                            viewBox="0 0 24 24"
                            fill="none"
                            aria-hidden="true"
                            ><path
                                d="M21 12a9 9 0 1 1-2.64-6.36"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"></path><path
                                d="M21 4v6h-6"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"></path></svg
                        ></button
                    ><div
                        class="component-preview-stage product-review-preview-stage"
                    >
                        <ProductReviewCard
                            title="Wireless Headphones"
                            description="Incredible sound quality and battery life. Best purchase of the year."
                            rating={4.9}
                            reviews={128}
                        />
                    </div>
                </div><div class="playground-code">
                    <div class="code-header">
                        <div class="code-header-left">
                            <img
                                src="/images/astro.png"
                                alt="Astro"
                                width="14"
                                height="18"
                            /><span class="code-header-text">Astro</span>
                        </div>
                    </div><div class="code-content">
                        <pre><code><span class="comment">---</span>
<span class="keyword">import</span> <span class="component-name">ProductReviewCard</span> <span class="keyword">from</span> <span class="string">"@astroanimate/core/ProductReviewCard"</span>;
<span class="comment">---</span>

&lt;<span class="component">ProductReviewCard</span>
  <span class="prop">title</span>=<span class="string">"Wireless Headphones"</span>
  <span class="prop">description</span>=<span class="string">"Incredible sound quality and battery life. Best purchase of the year."</span>
  <span class="prop">rating</span>=&#123;4.9&#125;
  <span class="prop">reviews</span>=&#123;128&#125;
/&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>

        <!-- INSTALLATION SECTION -->
        <div class="docs-intro-section" id="installation">
            <h2 class="docs-subtitle">Installation</h2><div
                class="installation-block"
            >
                <div class="installation-header">
                    <span class="bash-label">bash</span><svg
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="copy-icon"
                        ><rect x="9" y="9" width="13" height="13" rx="2" ry="2"
                        ></rect><path
                            d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
                        ></path></svg
                    >
                </div><pre><code><span class="keyword">npm</span> install @astroanimate/core</code></pre>
            </div>
        </div>

        <!-- QUICK START SECTION -->
        <div class="docs-intro-section" id="usage">
            <h2 class="docs-subtitle">Usage</h2><div class="docs-code-block">
                <pre><code><span class="comment">---</span>
<span class="keyword">import</span> ProductReviewCard <span class="keyword">from</span> <span class="string">"@astroanimate/core/ProductReviewCard"</span>;
<span class="comment">---</span>

&lt;<span class="component">ProductReviewCard</span> /&gt;</code></pre>
            </div><p class="docs-paragraph">
                Renders the ProductReviewCard component with AstroAnimate
                defaults.
            </p>
        </div>

        <!-- PROPS SECTION -->
        <div class="docs-intro-section" id="props">
            <h2 class="docs-subtitle">Props</h2><div class="table-wrapper">
                <table class="docs-table">
                    <thead
                        ><tr
                            ><th>Prop</th><th>Type</th><th>Default</th><th
                                >Description</th
                            ></tr
                        ></thead
                    ><tbody>
                        <tr>
                            <td><code>title</code></td>
                            <td><code>string</code></td>
                            <td><code>Required</code></td>
                            <td>The product name or review headline</td>
                        </tr>
                        <tr>
                            <td><code>description</code></td>
                            <td><code>string</code></td>
                            <td><code>Required</code></td>
                            <td>The review body or product summary</td>
                        </tr>
                        <tr>
                            <td><code>rating</code></td>
                            <td><code>number</code></td>
                            <td><code>4.8</code></td>
                            <td>Numerical rating score (typically out of 5)</td>
                        </tr>
                        <tr>
                            <td><code>reviews</code></td>
                            <td><code>number</code></td>
                            <td><code>24</code></td>
                            <td>Total number of reviews</td>
                        </tr>
                        <tr>
                            <td><code>class</code></td>
                            <td><code>string</code></td>
                            <td><code>""</code></td>
                            <td
                                >Additional CSS classes for the root <code
                                    >&lt;article&gt;</code
                                ></td
                            >
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- USE WHEN SECTION -->
        <div class="docs-intro-section" id="use-when">
            <h2 class="docs-subtitle">Use When</h2><ul class="docs-list">
                <li>Building e-commerce product grids and category pages</li>
                <li>
                    Highlighting featured user reviews or top-rated items on a
                    landing page
                </li>
                <li>
                    Needing a clean, visually appealing summary card without
                    JavaScript overhead
                </li>
            </ul>
        </div>

        <!-- AVOID WHEN SECTION -->
        <div class="docs-intro-section" id="avoid-when">
            <h2 class="docs-subtitle">Avoid When</h2><ul class="docs-list">
                <li>
                    Displaying long, multi-paragraph review essays (the card
                    width is constrained for grid usage)
                </li>
                <li>
                    Building complex interactive cards that require internal
                    scrolling or multiple distinct call-to-action buttons
                </li>
            </ul>
        </div>

        <!-- ACCESSIBILITY SECTION -->
        <div class="docs-intro-section" id="accessibility">
            <h2 class="docs-subtitle">Accessibility</h2><ul class="docs-list">
                <li>
                    Uses <code class="docs-code">focus-within</code> to trigger hover
                    styles and outline rendering when a user tabs into the card via
                    keyboard
                </li>
                <li>
                    Hides decorative elements (the background glow and the star
                    icon) from screen readers using <code class="docs-code"
                        >aria-hidden="true"</code
                    >
                </li>
                <li>
                    Respects <code class="docs-code"
                        >prefers-reduced-motion: reduce</code
                    > by instantly rendering the final hover state and disabling scaling
                    and glow opacity transitions
                </li>
            </ul>
        </div>

        <!-- PERFORMANCE SECTION -->
        <div class="docs-intro-section" id="performance">
            <h2 class="docs-subtitle">Performance</h2><ul class="docs-list">
                <li>
                    Zero Hydration: Operates completely independently of
                    JavaScript frameworks
                </li>
                <li>
                    Hardware Accelerated: Uses <code class="docs-code"
                        >transform: scale()</code
                    > and <code class="docs-code">opacity</code> for the hover interactions,
                    preventing expensive layout repaints
                </li>
            </ul>
        </div>

        <!-- CREDITS SECTION -->
        <div class="docs-intro-section" id="credits">
            <h2 class="docs-subtitle">Credits</h2>
            <ul class="docs-list">
                <li>
                    Credit to <a
                        href="https://github.com/iamprashanthks"
                        target="_blank"
                        class="credits-link">@Prashanth</a
                    >
                </li>
            </ul>
        </div>

        <RelatedComponents
            items={[
                {
                    name: "AnimatedCard",
                    href: "/docs/animated-card",
                    image: "/images/animatedcard.png",
                },
            ]}
        />

        <div class="docs-footer-nav" style="justify-content: space-between;">
            <a href="/docs/job-card/" class="prev-link">
                <span class="label">PREVIOUS</span>
                <span class="title">
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        style="transform: rotate(180deg);"
                        ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
                            points="12 5 19 12 12 19"></polyline></svg
                    >
                    Job Card
                </span>
            </a>
            <a href="/docs/article-card/" class="next-link">
                <span class="label">NEXT</span>
                <span class="title">
                    ArticleCard
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
                            points="12 5 19 12 12 19"></polyline></svg
                    >
                </span>
            </a>
        </div>
    </section>

    <Fragment slot="toc"
        ><div class="toc-header">IN THIS PAGE</div><nav class="toc-nav">
            <a href="#product-review-card" class="active">ProductReviewCard</a
            ><a href="#preview-playground">Preview/Playground</a><a
                href="#installation">Installation</a
            ><a href="#usage">Usage</a><a href="#props">Props</a><a
                href="#use-when">Use When</a
            ><a href="#avoid-when">Avoid When</a><a href="#accessibility"
                >Accessibility</a
            ><a href="#performance">Performance</a><a href="#credits">Credits</a
            >
        </nav></Fragment
    >
</DocLayout>
<style>
    .created-by {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 20px;
        padding: 0;
        justify-content: right;
        border-radius: 8px;
    }

    .created-by-avatar {
        width: 24px;
        height: 24px;
        border-radius: 4px;
        overflow: hidden;
        flex-shrink: 0;
    }

    .created-by-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .created-by-info {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .created-by-label {
        font-family: "Inter", sans-serif;
        font-size: 14px;
        color: #4b5563;
    }

    .created-by-name {
        font-family: "Inter", sans-serif;
        font-size: 14px;
        font-weight: 500;
        color: #f9fafb;
    }

    .playground-container {
        display: grid;
        /* grid-template-columns: 1fr 1fr; */
        border: 1px solid #1f2937;
        background: #050505;
        border-radius: 12px;
        overflow: hidden;
        width: 100%;
        max-width: 100%;
        min-width: 0;
    }

    .playground-preview {
        padding: 12px 16px;
        background: #fff;
        border-right: 1px solid #1f2937;
        display: flex;
        align-items: center;
        justify-content: center;
        min-width: 0;
        overflow: hidden;
        box-sizing: border-box;
    }

    .playground-code {
        background: #0d0d0d;
        padding: 0;
        display: flex;
        flex-direction: column;
        min-width: 0;
        max-width: 100%;
        overflow: hidden;
    }

    .code-header {
        background: #15191e;
        padding: 12px 16px;
        border-bottom: 1px solid #2a2a2a;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .code-header-left {
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: "JetBrains Mono", monospace;
        font-size: 13px;
        color: #fff;
    }

    .astro-logo {
        color: #ff5d01;
    }

    .code-content {
        padding: 20px;
        font-family: "JetBrains Mono", monospace;
        font-size: 13px;
        line-height: 1.6;
        overflow-x: auto;
    }

    .code-content pre {
        margin: 0;
        color: #e0e0e0;
    }

    .code-selector {
        color: #9cdcfe;
    }

    .code-property {
        color: #9cdcfe;
    }

    .code-value {
        color: #ce9178;
    }

    .installation-block {
        background: transparent;
        border: 1px solid #1f2937;
        border-radius: 8px;
        overflow: hidden;
    }

    .installation-header {
        background: #0b0d10;
        padding: 8px 16px;
        border-bottom: 1px solid #2a2a2a;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .bash-label {
        font-family: "JetBrains Mono", monospace;
        font-size: 12px;
