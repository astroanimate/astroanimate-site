        margin: 0;
        padding: 16px;
        background: transparent;
        font-family: "JetBrains Mono", monospace;
        font-size: 14px;
        color: #e0e0e0;
    }

    .string {
        color: #ce9178;
    }

    .comment {
        color: #6a9955;
    }

    .component-name {
        color: #4ec9b0;
    }

    .component {
        color: #dcdcaa;
    }

    .prop {
        color: #9cdcfe;
    }

    .tag {
        color: #569cd6;
    }

    .docs-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        background: transparent;
        border-radius: 8px;
        overflow: hidden;
    }

    .docs-table th,
    .docs-table td {
        padding: 12px 16px;
        text-align: left;
        border-right: 1px solid #1f2937;
        font-family: "Inter", sans-serif;
    }

    .docs-table th:last-child,
    .docs-table td:last-child {
        border-right: none;
    }

    .docs-table th {
        background: #0b0d10;
        font-weight: 500;
        font-size: 14px;
        border-bottom: 1px solid #1f2937;
    }

    .docs-table td {
        color: #9ca3af;
        font-size: 14px;
        border-bottom: 1px solid #1f2937;
        background: transparent;
    }

