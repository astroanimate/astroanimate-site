---
import DocLayout from "../../layouts/DocLayout.astro";
import "../../styles/Global.css";
import RevealImage from "@astroanimate/core/RevealImage";
---

<DocLayout title="Reveal Image">
    <section id="reveal-image">
        <h1 class="docs-title">RevealImage – Astro animation component</h1>

        <div class="docs-intro-section">
            <p class="docs-paragraph">
                Displays text with two images that reveal on hover. Uses pure
                CSS for animation with no JavaScript required.
            </p>
        </div>

        <!-- PREVIEW/PLAYGROUND SECTION -->
        <div class="docs-intro-section" id="preview-playground">
            <h2 class="docs-subtitle">Preview/Playground</h2>
            <div class="created-by">
                <span class="created-by-label">Created by</span>
                <div class="created-by-avatar">
                    <img src="/images/barsan.jpeg" alt="Creator" />
                </div>
                <span class="created-by-name">Barsan</span>
            </div>
            <div class="playground-container">
                <div class="playground-preview">
                    <div
                        class="reveal-showcase"
                        style="padding: 40px; min-height: 200px; display: flex; align-items: center; justify-content: center;"
                    >
                        <RevealImage
                            text="Hover me"
                            image1="/images/barsan.jpeg"
                            image2="/images/barsan.jpeg"
                            alt="Preview Image"
                        />
                    </div>
                </div>
                <div class="playground-code">
                    <div class="code-header">
                        <div class="code-header-left">
                            <img
                                src="/images/astro.png"
                                alt="Astro"
                                width="14"
                                height="18"
                            />
                            <span class="code-header-text">Astro</span>
                        </div>
                    </div>
                    <div class="code-content">
                        <pre><code><span class="keyword">import</span> <span class="component-name">RevealImage</span> <span class="keyword">from</span> <span class="string">'@astroanimate/core/RevealImage'</span>;

&lt;<span class="component">RevealImage</span>
  <span class="prop">text</span>=<span class="string">"Hover me"</span>
  <span class="prop">image1</span>=<span class="string">"/path/to/image1.jpg"</span>
  <span class="prop">image2</span>=<span class="string">"/path/to/image2.jpg"</span>
  <span class="prop">alt</span>=<span class="string">"Description"</span>
/&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>

        <!-- INSTALLATION SECTION -->
        <div class="docs-intro-section" id="installation">
            <h2 class="docs-subtitle">Installation</h2>
            <div class="installation-block">
                <div class="installation-header">
                    <span class="bash-label">bash</span>
                    <svg
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="copy-icon"
                    >
                        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"
                        ></rect>
                        <path
                            d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
                        ></path>
                    </svg>
                </div>
                <pre><code><span class="keyword">npm</span> install <span class="string">@astroanimate/core</span></code></pre>
            </div>
        </div>

        <!-- QUICK START SECTION -->
        <div class="docs-intro-section" id="usage">
            <h2 class="docs-subtitle">Usage</h2>
            <div class="docs-code-block">
                <pre><code><span class="keyword">import</span> <span class="component-name">RevealImage</span> <span class="keyword">from</span> <span class="string">'@astroanimate/core/RevealImage'</span>;

&lt;<span class="component">RevealImage</span>
  <span class="prop">text</span>=<span class="string">"Hover me"</span>
  <span class="prop">image1</span>=<span class="string">"/path/to/image1.jpg"</span>
  <span class="prop">image2</span>=<span class="string">"/path/to/image2.jpg"</span>
  <span class="prop">alt</span>=<span class="string">"Description"</span>
/&gt;</code></pre>
            </div>
        </div>

        <!-- PROPS SECTION -->
        <div class="docs-intro-section" id="props">
            <h2 class="docs-subtitle">Props</h2>
            <div class="table-wrapper">
                <table class="docs-table">
                    <thead>
                        <tr>
                            <th>Prop</th>
                            <th>Type</th>
                            <th>Default</th>
                            <th>Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><code>text</code></td>
                            <td><code>string</code></td>
                            <td><code>-</code></td>
                            <td>Text to display (required)</td>
                        </tr>
                        <tr>
                            <td><code>image1</code></td>
                            <td><code>string</code></td>
                            <td><code>-</code></td>
                            <td>First image source URL (required)</td>
                        </tr>
                        <tr>
                            <td><code>image2</code></td>
                            <td><code>string</code></td>
                            <td><code>-</code></td>
                            <td>Second image source URL (required)</td>
                        </tr>
                        <tr>
                            <td><code>alt</code></td>
                            <td><code>string</code></td>
                            <td><code>""</code></td>
                            <td>Alt text applied to both images</td>
                        </tr>
                        <tr>
                            <td><code>class</code></td>
                            <td><code>string</code></td>
                            <td><code>-</code></td>
                            <td>Optional class applied to root element</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- HOW IT WORKS SECTION -->
        <div class="docs-intro-section" id="behavior">
            <h2 class="docs-subtitle">Behavior</h2>
            <div class="docs-intro-section" id="how-it-works">
                <h2 class="docs-subtitle">Behavior</h2>
                <ul class="docs-list">
                    <li>Text is always visible and fades slightly on hover</li>
                    <li>Two images are positioned absolutely near the text</li>
                    <li>
                        On hover:
                        <ul
                            class="docs-list"
                            style="margin-left: 20px; margin-top: 8px;"
                        >
                            <li>
                                Images scale from <code class="keyword">0</code> to
                                visible size
                            </li>
                            <li>
                                Opacity transitions from <code class="keyword"
                                    >0</code
                                > to <code class="keyword">1</code>
                            </li>
                            <li>
                                One image shifts position and rotates slightly
                                for depth effect
                            </li>
                        </ul>
                    </li>
                    <li>
                        Images expand within a constrained container, not full
                        viewport size
                    </li>
                    <li>
                        No JavaScript is used; all behavior is handled via CSS
                    </li>
                </ul>
            </div>
        </div>

        <!-- USE WHEN SECTION -->
        <div class="docs-intro-section" id="use-when">
            <h2 class="docs-subtitle">Use When</h2>
            <ul class="docs-list">
                <li>Creating hover-based visual highlights for text</li>
                <li>Adding layered image reveal effects</li>
                <li>
                    Building portfolio or showcase sections with subtle
                    interaction
                </li>
            </ul>
        </div>

        <!-- AVOID WHEN SECTION -->
        <div class="docs-intro-section" id="avoid-when">
            <h2 class="docs-subtitle">Avoid When</h2>
            <ul class="docs-list">
                <li>
                    Touch-only environments (hover interaction is not available)
                </li>
                <li>Content must always be visible without interaction</li>
                <li>
                    Complex animation sequencing or programmatic control is
                    required
                </li>
            </ul>
        </div>

        <!-- ACCESSIBILITY SECTION -->
        <div class="docs-intro-section" id="accessibility">
            <h2 class="docs-subtitle">Accessibility</h2>

            <ul class="docs-list">
                <li>
                    Respects <code class="keyword">prefers-reduced-motion</code> :
                    <ul
                        class="docs-list"
                        style="margin-left: 20px; margin-top: 8px;"
                    >
                        <li>Disables transitions</li>
                        <li>Removes text fade effect</li>
                        <li>Shows images without scaling animation</li>
                    </ul>
                </li>
                <li>
                    Includes <code class="keyword">alt</code> attributes for images
                    (same value applied to both)
                </li>
                <li>
                    Images are decorative unless meaningful alt text is provided
                </li>
            </ul>
        </div>
    </section>

    <!-- PERFORMANCE SECTION -->
    <div class="docs-intro-section" id="performance">
        <h2 class="docs-subtitle">Performance</h2>
        <div class="docs-content">
            <ul class="docs-list">
                <li>Pure CSS animations (no JavaScript overhead)</li>
                <li>Images use <code class="keyword">loading="lazy"</code></li>
                <li>Uses transform-based animations for efficient rendering</li>
            </ul>
        </div>
    </div>

    <!-- CREDITS SECTION -->
    <div class="docs-intro-section" id="credits">
        <h2 class="docs-subtitle">Credits</h2>
        <ul class="docs-list">
            <li>
                Credit to <a
                    href="https://github.com/barsan"
                    class="credits-link">@barsan</a
                >
            </li>
        </ul>
    </div>

    <!-- RELATED COMPONENTS SECTION -->
    <div class="docs-intro-section" id="related-components">
        <h2 class="docs-subtitle">Related Components</h2>
        <div class="related-grid">
            <div class="related-card empty"></div>
            <div class="related-card empty"></div>
            <div class="related-card empty"></div>
            <div class="related-card empty"></div>
        </div>
    </div>

    <div class="docs-footer-nav" style="justify-content: space-between;">
        <a href="/docs/Sec-ScaleIn" class="prev-link">
            <span class="label">PREVIOUS</span>
            <span class="title">
                <svg
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    style="transform: rotate(180deg);"
                    ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
                        points="12 5 19 12 12 19"></polyline></svg
                >
                Scale In
            </span>
        </a>
        <a href="/docs/TypewriterText" class="next-link">
            <span class="label">NEXT</span>
            <span class="title">
                Typewriter Text
                <svg
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
                        points="12 5 19 12 12 19"></polyline></svg
                >
            </span>
        </a>
    </div>

<Fragment slot="toc">
    <div class="toc-header">IN THIS PAGE</div>
    <nav class="toc-nav">
        <a href="#reveal-image" class="active">Reveal Image</a>
        <a href="#preview-playground">Preview/Playground</a>
        <a href="#installation">Installation</a>
        <a href="#usage">Usage</a>
        <a href="#props">Props</a>
        <a href="#behavior">Behavior</a>
        <a href="#use-when">Use When</a>
        <a href="#avoid-when">Avoid When</a>
        <a href="#accessibility">Accessibility</a>
        <a href="#performance">Performance</a>
        <a href="#credits">Credits</a>
    </nav>
</Fragment>
</DocLayout>

<style>
    .created-by {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 20px;
        padding: 12px 16px;
        justify-content: right;
        border-radius: 8px;
    }

    .created-by-avatar {
        width: 24px;
        height: 24px;
        border-radius: 4px;
        overflow: hidden;
        flex-shrink: 0;
    }

    .created-by-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .created-by-info {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .created-by-label {
        font-family: "Inter", sans-serif;
        font-size: 14px;
        color: #4b5563;
    }

    .created-by-name {
        font-family: "Inter", sans-serif;
        font-size: 14px;
        font-weight: 500;
        color: #f9fafb;
    }

    .playground-container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        border: 1px solid #1f2937;
        background: #050505;
        border-radius: 12px;
        overflow: hidden;
    }

    .playground-preview {
        padding: 40px;
        background: #e8e8e8;
        border-right: 1px solid #1f2937;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .playground-code {
        background: #0d0d0d;
        padding: 0;
        display: flex;
        flex-direction: column;
    }

    .code-header {
        background: #15191e;
        padding: 12px 16px;
        border-bottom: 1px solid #2a2a2a;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .code-header-left {
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: "JetBrains Mono", monospace;
        font-size: 13px;
        color: #fff;
    }

    .astro-logo {
        color: #ff5d01;
    }

    .code-content {
        padding: 20px;
        font-family: "JetBrains Mono", monospace;
        font-size: 13px;
        line-height: 1.6;
        overflow-x: auto;
    }

    .code-content pre {
        margin: 0;
        color: #e0e0e0;
    }

    .code-selector {
        color: #9cdcfe;
    }

    .code-property {
        color: #9cdcfe;
    }

    .code-value {
        color: #ce9178;
    }

    .installation-block {
        background: transparent;
        border: 1px solid #1f2937;
        border-radius: 8px;
        overflow: hidden;
    }

    .installation-header {
        background: #0b0d10;
        padding: 8px 16px;
        border-bottom: 1px solid #2a2a2a;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .bash-label {
        font-family: "JetBrains Mono", monospace;
        font-size: 12px;
        color: #9ca3af;
    }

    .copy-icon {
        color: #9ca3af;
        cursor: pointer;
        transition: color 0.2s ease;
    }

    .copy-icon:hover {
        color: #f9fafb;
    }

    .installation-block pre {
        margin: 0;
        padding: 16px;
        background: transparent;
        font-family: "JetBrains Mono", monospace;
        font-size: 14px;
        color: #e0e0e0;
    }

    .code-header-text {
        color: #9ca3af;
        font-size: 12px;
        font-family: "Inter", sans-serif;
    }

    .package-name {
        color: #10b981;
    }

    .docs-code-block {
        background: #0b0d10;
        border: 1px solid #1f2937;
        border-radius: 8px;
        overflow: hidden;
    }

    .docs-code-block pre {
        margin: 0;
        padding: 16px;
        background: transparent;
        font-family: "JetBrains Mono", monospace;
        font-size: 14px;
        color: #e0e0e0;
    }

    .string {
        color: #ce9178;
    }

    .comment {
        color: #6a9955;
    }

    .component-name {
        color: #4ec9b0;
    }

    .component {
        color: #dcdcaa;
    }

    .prop {
        color: #9cdcfe;
    }

    .tag {
        color: #569cd6;
    }

    .docs-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        background: transparent;
        border-radius: 8px;
        overflow: hidden;
    }

    .docs-table th,
    .docs-table td {
        padding: 12px 16px;
        text-align: left;
        border-right: 1px solid #1f2937;
        font-family: "Inter", sans-serif;
    }

    .docs-table th:last-child,
    .docs-table td:last-child {
        border-right: none;
    }

    .docs-table th {
        background: #0b0d10;
        font-weight: 500;
        font-size: 14px;
        border-bottom: 1px solid #1f2937;
    }

    .docs-table td {
        color: #9ca3af;
        font-size: 14px;
        border-bottom: 1px solid #1f2937;
        background: transparent;
    }

    .docs-table tr:last-child td {
        border-bottom: none;
    }

    .docs-table td:first-child code {
        background: transparent;
        padding: 2px 6px;
        border-radius: 4px;
        font-family: "Inter", sans-serif;
        font-size: 14px;
    }

    .docs-table td:not(:first-child) code {
        background: #1f2937;
        padding: 2px 6px;
        border-radius: 4px;
        font-family: "JetBrains Mono", monospace;
        font-size: 12px;
        margin-right: 8px;
        display: inline-block;
        margin-bottom: 6px;
    }

    .docs-table td:not(:first-child) code:last-child {
        margin-right: 0;
    }

    .related-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-top: 24px;
    }

    .related-card {
        aspect-ratio: 16/9;
        border: 1px solid #1f2937;
        background: #050505;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #4b5563;
        font-family: "Inter", sans-serif;
        font-size: 14px;
    }

    .related-card.empty {
        background: #0a0a0a;
    }

    .docs-footer-nav {
        margin-top: 60px;
        padding-top: 40px;
        border-top: 1px solid #1f2937;
    }

    .prev-link,
    .next-link {
        display: flex;
        align-items: center;
        gap: 12px;
        text-decoration: none;
        color: #9ca3af;
        font-family: "Inter", sans-serif;
        transition: color 0.2s ease;
    }

    .prev-link:hover,
    .next-link:hover {
        color: #f9fafb;
    }

    .prev-link svg,
    .next-link svg {
        flex-shrink: 0;
    }

    .label {
        font-family: "JetBrains Mono", monospace;
        font-size: 12px;
        color: #ff7f1f;
    }

    .title {
        font-size: 16px;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .component-link {
        color: #9ca3af;
    }

    .credits-link {
        color: #60a5fa;
    }

    .component-link:hover {
        color: #ff953d;
    }

    @media (max-width: 1024px) {
        .playground-container {
            grid-template-columns: 1fr;
        }

        .playground-preview {
            border-right: none;
            border-bottom: 1px solid #1f2937;
        }

        .related-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
</style>
