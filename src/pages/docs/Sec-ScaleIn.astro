---
import DocLayout from "../../layouts/DocLayout.astro";
import "../../styles/Global.css";
import ScaleIn from "@astroanimate/core/ScaleIn";
---

<DocLayout title="Scale In">
    <section id="scale-in">
        <h1 class="docs-title">ScaleIn – Astro animation component</h1>

        <div class="docs-intro-section">
            <p class="docs-paragraph">
                Scroll-reveal animation that scales content from an initial
                scale to full size when entering the viewport.
            </p>
        </div>

        <!-- PREVIEW/PLAYGROUND SECTION -->
        <div class="docs-intro-section" id="preview-playground">
            <h2 class="docs-subtitle">Preview/Playground</h2>
            <div class="created-by">
                <span class="created-by-label">Created by</span>
                <div class="created-by-avatar">
                    <img src="/images/barsan.jpeg" alt="Creator" />
                </div>

                <span class="created-by-name">Vipin</span>
            </div>
            <div class="playground-container">
                <div class="playground-preview">
                    <div class="scale-showcase">
                        <ScaleIn enhance={true}>
                            <h1>Scale In - Default</h1>
                        </ScaleIn>

                        <ScaleIn enhance={true} duration={2000}>
                            <h1>Scale In - Enhanced</h1>
                        </ScaleIn>

                        <ScaleIn enhance={true}>
                            <h1>Scale In - Enhanced with props</h1>
                        </ScaleIn>
                    </div>
                </div>
                <div class="playground-code">
                    <div class="code-header">
                        <div class="code-header-left">
                            <img
                                src="/images/astro.png"
                                alt="Astro"
                                width="14"
                                height="18"
                            />
                            <span class="code-header-text">Astro</span>
                        </div>
                    </div>
                    <div class="code-content">
                        <pre><code><span class="keyword">import</span> <span class="component-name">ScaleIn</span> <span class="keyword">from</span> <span class="string">'@astroanimate/core/ScaleIn'</span>;

&lt;<span class="component">ScaleIn</span> <span class="prop">enhance</span>=<span class="boolean">&#123;true&#125;</span>&gt;
  <span class="tag">&lt;h1&gt;</span>Your content here<span class="tag">&lt;/h1&gt;</span>
&lt;/<span class="component">ScaleIn</span>&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>

        <!-- INSTALLATION SECTION -->
        <div class="docs-intro-section" id="installation">
            <h2 class="docs-subtitle">Installation</h2>
            <div class="installation-block">
                <div class="installation-header">
                    <span class="bash-label">bash</span>
                    <svg
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="copy-icon"
                    >
                        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"
                        ></rect>
                        <path
                            d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
                        ></path>
                    </svg>
                </div>
                <pre><code><span class="keyword">npm</span> install <span class="string">@astroanimate/core</span></code></pre>
            </div>
        </div>

        <!-- QUICK START SECTION -->
        <div class="docs-intro-section" id="example">
            <h2 class="docs-subtitle">Usage</h2>
            <div class="docs-code-block">
                <pre><code><span class="keyword">import</span> <span class="component-name">ScaleIn</span> <span class="keyword">from</span> <span class="string">'@astroanimate/core/ScaleIn'</span>;

&lt;<span class="component">ScaleIn</span> <span class="prop">enhance</span>=<span class="boolean">&#123;true&#125;</span>&gt;
  <span class="tag">&lt;h1&gt;</span>Your content here<span class="tag">&lt;/h1&gt;</span>
&lt;/<span class="component">ScaleIn</span>&gt;</code></pre>
            </div>
        </div>

        <!-- PROPS SECTION -->
        <div class="docs-intro-section" id="props">
            <h2 class="docs-subtitle">Props</h2>
            <div class="table-wrapper">
                <table class="docs-table">
                    <thead>
                        <tr>
                            <th>Prop</th>
                            <th>Type</th>
                            <th>Default</th>
                            <th>Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><code>enhance</code></td>
                            <td><code>boolean</code></td>
                            <td><code>false</code></td>
                            <td
                                >Opt-in to JS enhancement (Scroll Reveal). If
                                false, renders visible immediately with no
                                animation</td
                            >
                        </tr>
                        <tr>
                            <td><code>initialScale</code></td>
                            <td><code>number</code></td>
                            <td><code>0.9</code></td>
                            <td>Initial scale value to start from</td>
                        </tr>
                        <tr>
                            <td><code>duration</code></td>
                            <td><code>number</code></td>
                            <td><code>600</code></td>
                            <td>Duration of animation in milliseconds</td>
                        </tr>
                        <tr>
                            <td><code>delay</code></td>
                            <td><code>number</code></td>
                            <td><code>0</code></td>
                            <td
                                >Delay before animation starts in milliseconds</td
                            >
                        </tr>
                        <tr>
                            <td><code>easing</code></td>
                            <td><code>string</code></td>
                            <td
                                ><code>cubic-bezier(0.34, 1.56, 0.64, 1)</code
                                ></td
                            >
                            <td>CSS easing function</td>
                        </tr>
                        <tr>
                            <td><code>once</code></td>
                            <td><code>boolean</code></td>
                            <td><code>true</code></td>
                            <td
                                >Whether animation should only play once. If
                                false, reverses when scrolling out</td
                            >
                        </tr>
                        <tr>
                            <td><code>margin</code></td>
                            <td><code>string</code></td>
                            <td><code>0px 0px -10% 0px</code></td>
                            <td>IntersectionObserver margin</td>
                        </tr>
                        <tr>
                            <td><code>class</code></td>
                            <td><code>string</code></td>
                            <td><code>-</code></td>
                            <td>Optional CSS class for the root element</td>
                        </tr>
                        <tr>
                            <td><code>as</code></td>
                            <td><code>ScaleInTag</code></td>
                            <td><code>div</code></td>
                            <td
                                >HTML tag to use for the root element (div,
                                section, article, aside, main, header, footer,
                                nav, span, p, h1-h6, li, ul, ol, a, button)</td
                            >
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- HOW IT WORKS SECTION -->
        <div class="docs-intro-section" id="how-it-works">
            <h2 class="docs-subtitle">How It Works</h2>
            <div class="docs-content">
                <p class="docs-paragraph">
                    ScaleIn uses the IntersectionObserver API to detect when
                    elements enter the viewport and applies a CSS scale
                    animation. The component is designed with performance and
                    accessibility in mind.
                </p>
                <h3 class="docs-subtitle">Animation Process:</h3>
                <ul class="docs-list">
                    <li>
                        Element starts with <code
                            >transform: scale(initialScale)</code
                        > and <code>opacity: 0</code>
                    </li>
                    <li>
                        When element enters viewport (based on margin), scale
                        transitions to <code>1</code> and opacity to <code
                            >1</code
                        >
                    </li>
                    <li>
                        Animation uses CSS transitions for smooth 60fps
                        performance
                    </li>
                    <li>
                        If <code>once</code> is false, animation reverses when scrolling
                        out of viewport
                    </li>
                </ul>
            </div>
        </div>

        <!-- USE WHEN SECTION -->
        <div class="docs-intro-section" id="use-when">
            <h2 class="docs-subtitle">Use When</h2>
            <ul class="docs-list">
                <li>Content should animate when scrolling into view</li>
                <li>Need scale-based entrance animations</li>
                <li>Want progressive disclosure of sections</li>
            </ul>
        </div>

        <!-- AVOID WHEN SECTION -->
        <div class="docs-intro-section" id="avoid-when">
            <h2 class="docs-subtitle">Avoid When</h2>
            <ul class="docs-list">
                <li>Content must be visible immediately without JS</li>
                <li>Need complex multi-stage animations</li>
                <li>Require continuous looping animations</li>
            </ul>
        </div>

        <!-- ACCESSIBILITY SECTION -->
        <div class="docs-intro-section" id="accessibility">
            <h2 class="docs-subtitle">Accessibility</h2>
            <div class="docs-content">
                <p class="docs-paragraph">
                    ScaleIn is built with accessibility as a priority:
                </p>
                <ul class="docs-list">
                    <li>
                        Respects <code class="keyword"
                            >prefers-reduced-motion</code
                        > media query
                    </li>
                    <li>
                        Disables all animations when user prefers reduced motion
                    </li>
                    <li>Renders visible by default without JS</li>
                </ul>
            </div>
        </div>

        <!-- PERFORMANCE SECTION -->
        <div class="docs-intro-section" id="performance-notes">
            <h2 class="docs-subtitle">Performance</h2>
            <div class="docs-content">
                <p class="docs-paragraph">Optimized for maximum performance:</p>
                <ul class="docs-list">
                    <li>
                        Uses IntersectionObserver for efficient scroll detection
                    </li>
                    <li>
                        WeakMap prevents memory leaks with cleanup on DOM
                        removal
                    </li>
                    <li>MutationObserver handles element removal from DOM</li>
                </ul>
            </div>
        </div>

        <!-- CREDITS SECTION -->
        <div class="docs-intro-section" id="credits">
            <h2 class="docs-subtitle">Credits</h2>
            <ul class="docs-list">
                <li>
                    Credit to <a
                        href="https://github.com/vipin"
                        class="credits-link">@vipin</a>
                </li>
            </ul>
        </div>

        <!-- RELATED COMPONENTS SECTION -->
        <div class="docs-intro-section" id="related-components">
            <h2 class="docs-subtitle">Related Components</h2>
            <div class="related-grid">
                <div class="related-card empty"></div>
                <div class="related-card empty"></div>
                <div class="related-card empty"></div>
                <div class="related-card empty"></div>
            </div>
        </div>

        <div class="docs-footer-nav" style="justify-content: space-between;">
            <a href="/docs/AnimatedCard" class="prev-link">
                <span class="label">PREVIOUS</span>
                <span class="title">
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        style="transform: rotate(180deg);"
                        ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
                            points="12 5 19 12 12 19"></polyline></svg
                    >
                    Animated Card
                </span>
            </a>
            <a href="/docs/TypewriterText" class="next-link">
                <span class="label">NEXT</span>
                <span class="title">
                    Typewriter Text
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
                            points="12 5 19 12 12 19"></polyline></svg
                    >
                </span>
            </a>
        </div>
    </section>

    <Fragment slot="toc">
        <div class="toc-header">IN THIS PAGE</div>
        <nav class="toc-nav">
            <a href="#scale-in" class="active">Scale In</a>
            <a href="#preview-playground">Preview/Playground</a>
            <a href="#installation">Installation</a>
            <a href="#props">Props</a>
            <a href="#how-it-works">How It Works</a>
            <a href="#use-when">Use When</a>
            <a href="#avoid-when">Avoid When</a>
            <a href="#accessibility">Accessibility</a>
            <a href="#performance-notes">Performance Notes</a>
            <a href="#credits">Credits</a>
        </nav>
    </Fragment>
</DocLayout>

<style>
    .created-by {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 20px;
        padding: 12px 16px;
        justify-content: right;
        border-radius: 8px;
    }

    .created-by-avatar {
        width: 24px;
        height: 24px;
        border-radius: 4px;
        overflow: hidden;
        flex-shrink: 0;
    }

    .created-by-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .created-by-info {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .created-by-label {
        font-family: "Inter", sans-serif;
        font-size: 14px;
        color: #4b5563;
    }

    .created-by-name {
        font-family: "Inter", sans-serif;
        font-size: 14px;
        font-weight: 500;
        color: #f9fafb;
    }

    .playground-container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        border: 1px solid #1f2937;
        background: #050505;
        border-radius: 12px;
        overflow: hidden;
    }

    .playground-preview {
        padding: 40px;
        background: #e8e8e8;
        border-right: 1px solid #1f2937;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .typewriter-showcase {
        display: flex;
        flex-direction: column;
        gap: 20px;
        width: 100%;
        max-width: 300px;
    }

    .demo-typewriter {
        font-family: "JetBrains Mono", monospace;
        font-size: 18px;
        color: #000;
        background: #fff;
        padding: 16px;
        border-radius: 8px;
        border: 1px solid #ddd;
    }

    .playground-code {
        background: #0d0d0d;
        padding: 0;
        display: flex;
        flex-direction: column;
    }

    .code-header {
        background: #15191e;
        padding: 12px 16px;
        border-bottom: 1px solid #2a2a2a;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .code-header-left {
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: "JetBrains Mono", monospace;
        font-size: 13px;
        color: #fff;
    }

    .astro-logo {
        color: #ff5d01;
    }

    .code-content {
        padding: 20px;
        font-family: "JetBrains Mono", monospace;
        font-size: 13px;
        line-height: 1.6;
        overflow-x: auto;
    }

    .code-content pre {
        margin: 0;
        color: #e0e0e0;
    }

    .code-selector {
        color: #9cdcfe;
    }

    .code-property {
        color: #9cdcfe;
    }

    .code-value {
        color: #ce9178;
    }

    .installation-block {
        background: transparent;
        border: 1px solid #1f2937;
        border-radius: 8px;
        overflow: hidden;
    }

    .installation-header {
        background: #0b0d10;
        padding: 8px 16px;
        border-bottom: 1px solid #2a2a2a;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .bash-label {
        font-family: "JetBrains Mono", monospace;
        font-size: 12px;
        color: #9ca3af;
    }

    .copy-icon {
        color: #9ca3af;
        cursor: pointer;
        transition: color 0.2s ease;
    }

    .copy-icon:hover {
        color: #f9fafb;
    }

    .installation-block pre {
        margin: 0;
        padding: 16px;
        background: transparent;
        font-family: "JetBrains Mono", monospace;
        font-size: 14px;
        color: #e0e0e0;
    }

    .code-header-text {
        color: #9ca3af;
        font-size: 12px;
        font-family: "Inter", sans-serif;
    }

    .package-name {
        color: #10b981;
    }

    .docs-code-block {
        background: #0b0d10;
        border: 1px solid #1f2937;
        border-radius: 8px;
        overflow: hidden;
    }

    .docs-code-block pre {
        margin: 0;
        padding: 16px;
        background: transparent;
        font-family: "JetBrains Mono", monospace;
        font-size: 14px;
        color: #e0e0e0;
    }

    .string {
        color: #ce9178;
    }

    .comment {
        color: #6a9955;
    }

    .component-name {
        color: #4ec9b0;
    }

    .component {
        color: #dcdcaa;
    }

    .prop {
        color: #9cdcfe;
    }

    .tag {
        color: #569cd6;
    }

    .docs-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        background: transparent;
        border-radius: 8px;
        overflow: hidden;
    }

    .docs-table th,
    .docs-table td {
        padding: 12px 16px;
        text-align: left;
        border-right: 1px solid #1f2937;
        font-family: "Inter", sans-serif;
    }

    .docs-table th:last-child,
    .docs-table td:last-child {
        border-right: none;
    }

    .docs-table th {
        background: #0b0d10;
        font-weight: 500;
        font-size: 14px;
        border-bottom: 1px solid #1f2937;
    }

    .docs-table td {
        color: #9ca3af;
        font-size: 14px;
        border-bottom: 1px solid #1f2937;
        background: transparent;
    }

    .docs-table tr:last-child td {
        border-bottom: none;
    }

    .docs-table td:first-child code {
        background: transparent;
        padding: 2px 6px;
        border-radius: 4px;
        font-family: "Inter", sans-serif;
        font-size: 14px;
    }

    .docs-table td:not(:first-child) code {
        background: #1f2937;
        padding: 2px 6px;
        border-radius: 4px;
        font-family: "JetBrains Mono", monospace;
        font-size: 12px;
        margin-right: 8px;
        display: inline-block;
        margin-bottom: 6px;
    }

    .docs-table td:not(:first-child) code:last-child {
        margin-right: 0;
    }

    .api-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 20px;
        margin-top: 24px;
    }

    .api-card {
        padding: 24px;
        border: 1px solid #1f2937;
        background: #050505;
        border-radius: 8px;
    }

    .api-card h3 {
        font-size: 18px;
        font-family: "Inter", sans-serif;
        font-weight: 500;
        color: #f9fafb;
        margin-bottom: 8px;
    }

    .api-card p {
        color: #9ca3af;
        font-family: "Inter", sans-serif;
        font-size: 14px;
        margin: 0;
    }

    .related-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-top: 24px;
    }

    .related-card {
        aspect-ratio: 16/9;
        border: 1px solid #1f2937;
        background: #050505;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #4b5563;
        font-family: "Inter", sans-serif;
        font-size: 14px;
    }

    .related-card.empty {
        background: #0a0a0a;
    }

    .docs-footer-nav {
        margin-top: 60px;
        padding-top: 40px;
        border-top: 1px solid #1f2937;
    }

    .prev-link,
    .next-link {
        display: flex;
        align-items: center;
        gap: 12px;
        text-decoration: none;
        color: #9ca3af;
        font-family: "Inter", sans-serif;
        transition: color 0.2s ease;
    }

    .prev-link:hover,
    .next-link:hover {
        color: #f9fafb;
    }

    .prev-link svg,
    .next-link svg {
        flex-shrink: 0;
    }

    .label {
        font-family: "JetBrains Mono", monospace;
        font-size: 12px;
        color: #ff7f1f;
    }

    .title {
        font-size: 16px;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .component-link {
        color: #9ca3af;
    }

    .credits-link {
        color: #60a5fa;
    }

    .component-link:hover {
        color: #ff953d;
    }

    @media (max-width: 1024px) {
        .playground-container {
            grid-template-columns: 1fr;
        }

        .playground-preview {
            border-right: none;
            border-bottom: 1px solid #1f2937;
        }

        .related-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
</style>
