---
import DocLayout from "../../../layouts/DocLayout.astro";
import RelatedComponents from "../../../components/RelatedComponents.astro";
import "../../../styles/Global.css";
import ProgressBar from "@astroanimate/core/ProgressBar";
---

<DocLayout title="ProgressBar">
    <section id="progressbar">
        <h1 class="docs-title">ProgressBar <button type="button" class="docs-title-share" aria-label="Copy page link"><img src="/images/share-link.png" alt="" width="16" height="16" /></button></h1>

        <div class="docs-intro-section">
            <p class="docs-paragraph">
                Renders a customizable progress bar with size variants, color
                options, and built-in accessibility support. Uses CSS
                transitions for smooth updates with no JavaScript required.
            </p>
        </div>

        <!-- PREVIEW/PLAYGROUND SECTION -->
        <div class="docs-intro-section" id="preview-playground">
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px;">
                <h2 class="docs-subtitle" style="margin: 0;">Preview/Playground</h2>
                <button onclick="location.reload()" style="width: 32px; height: 32px; display: inline-flex; align-items: center; justify-content: center; border: 1px solid #FF7F1F; border-radius: 6px; background: #15191E; color: #FF7F1F; cursor: pointer; transition: all 0.2s;" onmouseover="this.style.background='#FF7F1F'; this.style.color='#15191E'" onmouseout="this.style.background='#15191E'; this.style.color='#FF7F1F'" aria-label="Refresh preview">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M21 12a9 9 0 1 1-2.64-6.36" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M21 4v6h-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </button>
            </div>
            <div class="created-by">
                <span class="created-by-label">Created by</span>
                <div class="created-by-avatar">
                    <img src="/images/barsan.jpeg" alt="Creator" />
                </div>
                <span class="created-by-name">Barsan</span>
            </div>
            <div class="playground-container">
                <div class="playground-preview">
                    <div
                        class="progressbar-showcase"
                        style="padding: 40px; min-height: 200px; display: flex; align-items: center; justify-content: center; width: 100%;"
                    >
                        <div style="width: 100%; max-width: 400px;">
                            <ProgressBar value={65} label="Loading..." />
                        </div>
                    </div>
                </div>
                <div class="playground-code">
                    <div class="code-header">
                        <div class="code-header-left">
                            <img
                                src="/images/astro.png"
                                alt="Astro"
                                width="14"
                                height="18"
                            />
                            <span class="code-header-text">Astro</span>
                        </div>
                    </div>
                    <div class="code-content">
                        <pre><code><span class="keyword">import</span> <span class="component-name">ProgressBar</span> <span class="keyword">from</span> <span class="string">'@astroanimate/core/ProgressBar'</span>;

&lt;<span class="tag">div</span> <span class="prop">style</span>=<span class="string">"width: 100%; max-width: 400px;"</span>&gt;
  &lt;<span class="component">ProgressBar</span> <span class="prop">value</span>=&#123;<span class="string">65</span>&#125; <span class="prop">label</span>=<span class="string">"Loading..."</span> /&gt;
&lt;/<span class="tag">div</span>&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>

        <!-- INSTALLATION SECTION -->
        <div class="docs-intro-section" id="installation">
            <h2 class="docs-subtitle">Installation</h2>
            <div class="installation-block">
                <div class="installation-header">
                    <span class="bash-label">bash</span>
                    <svg
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="copy-icon"
                    >
                        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"
                        ></rect>
                        <path
                            d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
                        ></path>
                    </svg>
                </div>
                <pre><code><span class="keyword">npm</span> install <span class="string">@astroanimate/core</span></code></pre>
            </div>
        </div>

        <!-- QUICK START SECTION -->
        <div class="docs-intro-section" id="usage">
            <h2 class="docs-subtitle">Usage</h2>
            <div class="docs-code-block">
                <pre><code><span class="comment">---</span>
<span class="keyword">import</span> <span class="component-name">ProgressBar</span> <span class="keyword">from</span> <span class="string">"@astroanimate/core/ProgressBar"</span>;
<span class="comment">---</span>

&lt;<span class="component">ProgressBar</span> <span class="prop">value</span>=&#123;<span class="string">65</span>&#125; <span class="prop">label</span>=<span class="string">"Loading..."</span> /&gt;</code></pre>
            </div>
            <p class="docs-paragraph">Displays a progress bar at 65% completion with an optional label.</p>
        </div>

        <!-- PROPS SECTION -->
        <div class="docs-intro-section" id="props">
            <h2 class="docs-subtitle">Props</h2>
            <div class="table-wrapper">
                <table class="docs-table">
                    <thead>
                        <tr>
                            <th>Prop</th>
                            <th>Type</th>
                            <th>Default</th>
                            <th>Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr
                            ><td><code>value</code></td><td
                                ><code>number</code></td
                            ><td><code>-</code></td><td
                                >Progress value (0–max). Required</td
                            ></tr
                        >
                        <tr
                            ><td><code>max</code></td><td
                                ><code>number</code></td
                            ><td><code>100</code></td><td
                                >Maximum value used to compute percentage</td
                            ></tr
                        >
                        <tr
                            ><td><code>label</code></td><td
                                ><code>string</code></td
                            ><td><code>-</code></td><td
                                >Label text displayed above the progress bar</td
                            ></tr
                        >
                        <tr
                            ><td><code>size</code></td><td
                                ><code>"small" | "medium" | "large"</code></td
                            ><td><code>"medium"</code></td><td
                                >Size variant controlling height and label size</td
                            ></tr
                        >
                        <tr
                            ><td><code>color</code></td><td
                                ><code>string</code></td
                            ><td><code>"#3b82f6"</code></td><td
                                >Bar fill color</td
                            ></tr
                        >
                        <tr
                            ><td><code>trackColor</code></td><td
                                ><code>string</code></td
                            ><td><code>"#e5e7eb"</code></td><td
                                >Track background color</td
                            ></tr
                        >
                        <tr
                            ><td><code>class</code></td><td
                                ><code>string</code></td
                            ><td><code>-</code></td><td
                                >Optional class applied to the root element</td
                            ></tr
                        >
                    </tbody>
                </table>
            </div>
        </div>

        <!-- BEHAVIOR SECTION -->
        <div class="docs-intro-section" id="behavior">
            <h2 class="docs-subtitle">Behavior</h2>
            <ul class="docs-list">
                <li>
                    Progress value is clamped between <code class="docs-code"
                        >0</code
                    > and <code class="docs-code">max</code> to prevent invalid states
                </li>
                <li>
                    Percentage width is computed automatically from <code
                        class="docs-code">value / max</code
                    >
                </li>
                <li>
                    Updates to <code class="docs-code">value</code> animate smoothly
                    using CSS transitions
                </li>
                <li>Label is optional and only rendered when provided</li>
                <li>
                    No JavaScript is used — all updates rely on reactive
                    rendering
                </li>
            </ul>
        </div>

        <!-- USE WHEN SECTION -->
        <div class="docs-intro-section" id="use-when">
            <h2 class="docs-subtitle">Use When</h2>
            <ul class="docs-list">
                <li>Displaying file upload or download progress</li>
                <li>Showing form completion status</li>
                <li>Indicating loading states with percentage</li>
                <li>Visualizing linear progress in UI workflows</li>
            </ul>
        </div>

        <!-- AVOID WHEN SECTION -->
        <div class="docs-intro-section" id="avoid-when">
            <h2 class="docs-subtitle">Avoid When</h2>
            <ul class="docs-list">
                <li>
                    Interactive progress control is required (use a slider
                    instead)
                </li>
                <li>
                    Multi-segment or stacked progress visualization is needed
                </li>
                <li>
                    Precise real-time updates faster than transition duration
                    are required
                </li>
            </ul>
        </div>

        <!-- ACCESSIBILITY SECTION -->
        <div class="docs-intro-section" id="accessibility">
            <h2 class="docs-subtitle">Accessibility</h2>
            <div>
                <ul class="docs-list">
                    <li>
                        Uses <code class="docs-code">role="progressbar"</code> with
                        ARIA attributes:
                        <ul
                            class="docs-list"
                            style="margin-left: 20px; margin-top: 8px;"
                        >
                            <li><code class="docs-code">aria-valuenow</code></li>
                            <li><code class="docs-code">aria-valuemin</code></li>
                            <li><code class="docs-code">aria-valuemax</code></li>
                            <li>
                                <code class="docs-code">aria-label</code> (if label
                                provided)
                            </li>
                        </ul>
                    </li>
                    <li>
                        Respects <code class="docs-code"
                            >prefers-reduced-motion</code
                        > by disabling width transitions
                    </li>
                    <li>
                        Supports dark mode via <code class="docs-code"
                            >prefers-color-scheme</code
                        >
                    </li>
                </ul>
            </div>
        </div>

        <!-- PERFORMANCE SECTION -->
        <div class="docs-intro-section" id="performance">
            <h2 class="docs-subtitle">Performance</h2>
            <div>
                <ul class="docs-list">
                    <li>CSS-only width transitions (no JavaScript overhead)</li>
                    <li>Value clamping prevents layout inconsistencies</li>
                    <li>Efficient rendering using inline CSS variables</li>
                </ul>
            </div>
        </div>

        <!-- CREDITS SECTION -->
        <div class="docs-intro-section" id="credits">
            <h2 class="docs-subtitle">Credits</h2>
            <ul class="docs-list">
                <li>
                    Credit to <a
                        href="https://github.com/barsaan"
                        target="_blank"
                        class="credits-link">@barsan</a
                    >
                </li>
            </ul>
        </div>

        <!-- RELATED COMPONENTS SECTION -->
        <RelatedComponents items={[{ name: "Loader", href: "/docs/loader", image: "/images/loader.png" }]} />

        <div class="docs-footer-nav" style="justify-content: space-between;">
            <a href="/docs/loader" class="prev-link">
                <span class="label">PREVIOUS</span>
                <span class="title">
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        style="transform: rotate(180deg);"
                        ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
                            points="12 5 19 12 12 19"></polyline></svg
                    >
                    Loader
                </span>
            </a>
            <a href="/docs/animated-button" class="next-link">
                <span class="label">NEXT</span>
                <span class="title">
                    AnimatedButton
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
                            points="12 5 19 12 12 19"></polyline></svg
                    >
                </span>
            </a>
        </div>
    </section>

    <Fragment slot="toc">
        <div class="toc-header">IN THIS PAGE</div>
        <nav class="toc-nav">
            <a href="#progressbar" class="active">ProgressBar</a>
            <a href="#preview-playground">Preview/Playground</a>
            <a href="#installation">Installation</a>
            <a href="#usage">Usage</a>
            <a href="#props">Props</a>
            <a href="#behavior">Behavior</a>
            <a href="#use-when">Use When</a>
            <a href="#avoid-when">Avoid When</a>
            <a href="#accessibility">Accessibility</a>
            <a href="#performance">Performance</a>
            <a href="#credits">Credits</a>
        </nav>
    </Fragment>
</DocLayout>

<style>
    .created-by {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 20px;
        padding: 12px 16px;
        justify-content: right;
        border-radius: 8px;
    }

    .created-by-avatar {
        width: 24px;
        height: 24px;
        border-radius: 4px;
        overflow: hidden;
        flex-shrink: 0;
    }

    .created-by-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .created-by-info {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .created-by-label {
        font-family: "Inter", sans-serif;
        font-size: 14px;
        color: #4b5563;
    }

    .created-by-name {
        font-family: "Inter", sans-serif;
        font-size: 14px;
        font-weight: 500;
        color: #f9fafb;
    }

    .playground-container {
        display: grid;
        /* grid-template-columns: 1fr 1fr; */
        border: 1px solid #1f2937;
        background: #050505;
        border-radius: 12px;
        overflow: hidden;
        width: 100%;
        max-width: 100%;
        min-width: 0;
    }

    .playground-preview {
        padding: 40px;
        background: #fff;
        border-right: 1px solid #1f2937;
        display: flex;
        align-items: center;
        justify-content: center;
        min-width: 0;
        overflow: hidden;
        box-sizing: border-box;
    }

    .playground-code {
        background: #0d0d0d;
        padding: 0;
        display: flex;
        flex-direction: column;
        min-width: 0;
        max-width: 100%;
        overflow: hidden;
    }

    .code-header {
        background: #15191e;
        padding: 12px 16px;
        border-bottom: 1px solid #2a2a2a;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .code-header-left {
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: "JetBrains Mono", monospace;
        font-size: 13px;
        color: #fff;
    }

    .astro-logo {
        color: #ff5d01;
    }

    .code-content {
        padding: 20px;
        font-family: "JetBrains Mono", monospace;
        font-size: 13px;
        line-height: 1.6;
        overflow-x: auto;
    }

    .code-content pre {
        margin: 0;
        color: #e0e0e0;
    }

    .code-selector {
        color: #9cdcfe;
    }

    .code-property {
        color: #9cdcfe;
    }

    .code-value {
        color: #ce9178;
    }

    .installation-block {
        background: transparent;
        border: 1px solid #1f2937;
        border-radius: 8px;
        overflow: hidden;
    }

    .installation-header {
        background: #0b0d10;
        padding: 8px 16px;
        border-bottom: 1px solid #2a2a2a;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .bash-label {
        font-family: "JetBrains Mono", monospace;
        font-size: 12px;
        color: #9ca3af;
    }

    .copy-icon {
        color: #9ca3af;
        cursor: pointer;
        transition: color 0.2s ease;
    }

    .copy-icon:hover {
        color: #f9fafb;
    }

    .installation-block pre {
        margin: 0;
        padding: 16px;
        background: transparent;
        font-family: "JetBrains Mono", monospace;
        font-size: 14px;
        color: #e0e0e0;
    }

    .code-header-text {
        color: #9ca3af;
        font-size: 12px;
        font-family: "Inter", sans-serif;
    }

    .package-name {
        color: #10b981;
    }

    .docs-code-block {
        background: #0b0d10;
        border: 1px solid #1f2937;
        border-radius: 8px;
        overflow: hidden;
    }

    .docs-code-block pre {
        margin: 0;
        padding: 16px;
        background: transparent;
        font-family: "JetBrains Mono", monospace;
        font-size: 14px;
        color: #e0e0e0;
    }

    /* .keyword {
        color: #569cd6;
    } */

    .string {
        color: #ce9178;
    }

    .comment {
        color: #6a9955;
    }

    .component-name {
        color: #4ec9b0;
    }

    .component {
        color: #dcdcaa;
    }

    .prop {
        color: #9cdcfe;
    }

    .tag {
        color: #569cd6;
    }

    .docs-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        background: transparent;
        border-radius: 8px;
        overflow: hidden;
    }

    .docs-table th,
    .docs-table td {
        padding: 12px 16px;
        text-align: left;
        border-right: 1px solid #1f2937;
        font-family: "Inter", sans-serif;
    }

    .docs-table th:last-child,
    .docs-table td:last-child {
        border-right: none;
    }

    .docs-table th {
        background: #0b0d10;
        font-weight: 500;
        font-size: 14px;
        border-bottom: 1px solid #1f2937;
    }

    .docs-table td {
        color: #9ca3af;
        font-size: 14px;
        border-bottom: 1px solid #1f2937;
        background: transparent;
    }

    .docs-table tr:last-child td {
        border-bottom: none;
    }

    .docs-table td:first-child code {
        background: transparent;
        padding: 2px 6px;
        border-radius: 4px;
        font-family: "Inter", sans-serif;
        font-size: 14px;
    }

    .docs-table td:not(:first-child) code {
        background: #1f2937;
        padding: 2px 6px;
        border-radius: 4px;
        font-family: "JetBrains Mono", monospace;
        font-size: 12px;
        margin-right: 8px;
        display: inline-block;
        margin-bottom: 6px;
    }

    .docs-table td:not(:first-child) code:last-child {
        margin-right: 0;
    }

    .related-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-top: 24px;
    }

    .related-card {
        aspect-ratio: 16/9;
        border: 1px solid #1f2937;
        background: #050505;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #4b5563;
        font-family: "Inter", sans-serif;
        font-size: 14px;
    }

    .related-card.empty {
        background: #0a0a0a;
    }

    .docs-footer-nav {
        margin-top: 60px;
        padding-top: 40px;
        border-top: 1px solid #1f2937;
    }

   

    .component-link {
        color: #9ca3af;
    }

    .credits-link {
        color: #60a5fa;
    }

    .component-link:hover {
        color: #ff953d;
    }

    @media (max-width: 1024px) {
        .playground-container {
            grid-template-columns: 1fr;
            min-height: auto;
        }

        .playground-preview {
            border-right: none;
            border-bottom: 1px solid #1f2937;
        }

        .related-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 640px) {
        .playground-container {
            width: min(100%, calc(100vw - 48px));
            max-width: 100%;
            grid-template-columns: minmax(0, 1fr);
            margin-inline: auto;
        }

        .playground-preview {
            width: 100%;
            max-width: 100%;
            padding: 28px 14px;
            margin-inline: auto;
        }
    }
</style>
