---
import DocLayout from "../../../layouts/DocLayout.astro";
import RelatedComponents from "../../../components/RelatedComponents.astro";
import "../../../styles/Global.css";
import ExpandableCard from "@astroanimate/core/ExpandableCard";
---

<DocLayout title="Expandable Card">
    <section id="expandable-card">
        <h1 class="docs-title">ExpandableCard <button type="button" class="docs-title-share" aria-label="Copy page link"><img src="/images/share-link.png" alt="" width="16" height="16" /></button></h1>

        <div class="docs-intro-section">
            <p class="docs-paragraph">
                Renders an expandable card with image, title, and content. Uses
                a progressive enhancement model where content is fully visible
                by default, and JavaScript enables interactive expand/collapse
                behavior.
            </p>
        </div>

        <!-- PREVIEW/PLAYGROUND SECTION -->
        <div class="docs-intro-section" id="preview-playground">
            <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px;">
                <h2 class="docs-subtitle" style="margin: 0;">Preview/Playground</h2>
                <button onclick="location.reload()" style="width: 32px; height: 32px; display: inline-flex; align-items: center; justify-content: center; border: 1px solid #FF7F1F; border-radius: 6px; background: #15191E; color: #FF7F1F; cursor: pointer; transition: all 0.2s;" onmouseover="this.style.background='#FF7F1F'; this.style.color='#15191E'" onmouseout="this.style.background='#15191E'; this.style.color='#FF7F1F'" aria-label="Refresh preview">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                        <path d="M21 12a9 9 0 1 1-2.64-6.36" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M21 4v6h-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </button>
            </div>
            <div class="created-by">
                <span class="created-by-label">Created by</span>
                <div class="created-by-avatar">
                    <img
                        src="/images/barsan.jpeg"
                        alt="Creator"
                        loading="lazy"
                        decoding="async"
                        width="40"
                        height="40"
                    />
                </div>
                <span class="created-by-name">Barsan</span>
            </div>
            <div class="playground-container">
                <div class="playground-preview">
                    <div class="expandable-showcase">
                        <ExpandableCard
                            title="Embercrest Summit Trail"
                            subtitle="1886 by Helen Rowe & Elas Mendez"
                            image="/images/expandable-card-img.avif"
                            enhance
                            
                        >
                        <div class="expandable-stats">
  <div>
                            <p class="expandable-stat-value">12.4km</p>
                            <p class="expandable-stat-label">Distance</p>
                        </div>

                        <div>
                            <p class="expandable-stat-value">870m</p>
                            <p class="expandable-stat-label">Coverage</p>
                        </div>

                        <div>
                            <p class="expandable-stat-value">4h 45m</p>
                            <p class="expandable-stat-label">Duration</p>
                        </div>
                        </div>
                      
                            <p class="expandable-description">
                                Embercrest Ridge rises boldly from the heart of the Silverpine Mountains, its sun-warmed cliffs glowing with rich crimson and amber tones during golden hour. Towering at 3,274 meters, the ridge is framed by winding alpine trails, rugged rock formations, and sweeping meadows dotted with wildflowers. 
                            </p>
                        </ExpandableCard>
                    </div>
                </div>
                <div class="playground-code">
                    <div class="code-header">
                        <div class="code-header-left">
                            <img
                                src="/images/astro.png"
                                alt="Astro"
                                width="14"
                                height="18"
                                loading="lazy"
                                decoding="async"
                            />
                            <span class="code-header-text">Astro</span>
                        </div>
                    </div>
                    <div class="code-content">
                        <pre><code><span class="keyword">import</span> <span class="component-name">ExpandableCard</span> <span class="keyword">from</span> <span class="string">'@astroanimate/core/ExpandableCard'</span>;

&lt;<span class="component">ExpandableCard</span>
  <span class="prop">title</span>=<span class="string">"Embercrest Summit Trail"</span>
  <span class="prop">subtitle</span>=<span class="string">"1886 by Helen Rowe &amp; Elas Mendez"</span>
  <span class="prop">image</span>=<span class="string">"/images/expandable-card-img.avif"</span>
  <span class="prop">enhance</span>
&gt;
  &lt;<span class="tag">div</span> <span class="prop">style</span>=<span class="string">"display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;"</span>&gt;
    &lt;<span class="tag">div</span>&gt;&lt;<span class="tag">p</span>&gt;12.4km&lt;/<span class="tag">p</span>&gt;&lt;<span class="tag">p</span>&gt;Distance&lt;/<span class="tag">p</span>&gt;&lt;/<span class="tag">div</span>&gt;
    &lt;<span class="tag">div</span>&gt;&lt;<span class="tag">p</span>&gt;870m&lt;/<span class="tag">p</span>&gt;&lt;<span class="tag">p</span>&gt;Coverage&lt;/<span class="tag">p</span>&gt;&lt;/<span class="tag">div</span>&gt;
    &lt;<span class="tag">div</span>&gt;&lt;<span class="tag">p</span>&gt;4h 45m&lt;/<span class="tag">p</span>&gt;&lt;<span class="tag">p</span>&gt;Duration&lt;/<span class="tag">p</span>&gt;&lt;/<span class="tag">div</span>&gt;
  &lt;/<span class="tag">div</span>&gt;

  &lt;<span class="tag">p</span> <span class="prop">style</span>=<span class="string">"color: #666; margin: 0; font-size: 16px;"</span>&gt;
    Embercrest Ridge rises boldly from the heart of the Silverpine Mountains.
  &lt;/<span class="tag">p</span>&gt;
&lt;/<span class="component">ExpandableCard</span>&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>

        <!-- INSTALLATION SECTION -->
        <div class="docs-intro-section" id="installation">
            <h2 class="docs-subtitle">Installation</h2>
            <div class="installation-block">
                <div class="installation-header">
                    <span class="bash-label">bash</span>
                    <svg
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="copy-icon"
                    >
                        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"
                        ></rect>
                        <path
                            d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
                        ></path>
                    </svg>
                </div>
                <pre><code><span class="keyword">npm</span> install <span class="string">@astroanimate/core</span></code></pre>
            </div>
        </div>

        <!-- QUICK START SECTION -->
        <div class="docs-intro-section" id="usage">
            <h2 class="docs-subtitle">Usage</h2>
            <div class="docs-code-block">
                <pre><code><span class="keyword">import</span> <span class="component-name">ExpandableCard</span> <span class="keyword">from</span> <span class="string">'@astroanimate/core/ExpandableCard'</span>;

&lt;<span class="component">ExpandableCard</span>
  <span class="prop">title</span>=<span class="string">"Card Title"</span>
  <span class="prop">subtitle</span>=<span class="string">"Optional subtitle"</span>
  <span class="prop">enhance</span>
&gt;
  <span class="tag">&lt;p&gt;</span>Your content here<span class="tag">&lt;/p&gt;</span>
&lt;/<span class="component">ExpandableCard</span>&gt;</code></pre>
            </div>
            <p class="docs-paragraph">Enables interactive expand/collapse behavior with smooth transitions.</p>
        </div>

        <!-- PROPS SECTION -->
        <div class="docs-intro-section" id="props">
            <h2 class="docs-subtitle">Props</h2>
            <div class="table-wrapper">
                <table class="docs-table">
                    <thead>
                        <tr>
                            <th>Prop</th>
                            <th>Type</th>
                            <th>Default</th>
                            <th>Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><code>title</code></td>
                            <td><code>string</code></td>
                            <td><code>-</code></td>
                            <td
                                >Title text rendered in the card header
                                (required)</td
                            >
                        </tr>
                        <tr>
                            <td><code>subtitle</code></td>
                            <td><code>string</code></td>
                            <td><code>""</code></td>
                            <td>Subtitle text below the title</td>
                        </tr>
                        <tr>
                            <td><code>image</code></td>
                            <td><code>string</code></td>
                            <td><code>Unsplash URL</code></td>
                            <td>Image URL for the card header</td>
                        </tr>
                        <tr>
                            <td><code>imageAlt</code></td>
                            <td><code>string</code></td>
                            <td><code>"Card image"</code></td>
                            <td>Alt text for the image</td>
                        </tr>
                        <tr>
                            <td><code>initialOpen</code></td>
                            <td><code>boolean</code></td>
                            <td><code>false</code></td>
                            <td
                                >Whether the card starts in the expanded state</td
                            >
                        </tr>
                        <tr>
                            <td><code>duration</code></td>
                            <td><code>number</code></td>
                            <td><code>300</code></td>
                            <td>Transition duration in milliseconds</td>
                        </tr>
                        <tr>
                            <td><code>easing</code></td>
                            <td><code>string</code></td>
                            <td><code>"ease"</code></td>
                            <td>CSS easing function for transitions</td>
                        </tr>
                        <tr>
                            <td><code>enhance</code></td>
                            <td><code>boolean</code></td>
                            <td><code>false</code></td>
                            <td
                                >Enable JavaScript-powered expand/collapse
                                interaction (click, keyboard, aria attributes)</td
                            >
                        </tr>
                        <tr>
                            <td><code>class</code></td>
                            <td><code>string</code></td>
                            <td><code>""</code></td>
                            <td>Additional class name for the root element</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- HOW IT WORKS SECTION -->
        <div class="docs-intro-section" id="behavior">
            <h2 class="docs-subtitle">Behavior</h2>
            <div>
                <ul class="docs-list">
                    <li>
                        Content is fully visible by default (no JavaScript
                        required)
                    </li>
                    <li>
                        When <code class="docs-code">enhance=true</code>,
                        JavaScript enables interactive expand/collapse behavior
                    </li>
                    <li>
                        JavaScript sets <code class="docs-code">data-state</code> attributes,
                        while CSS handles all visual transitions
                    </li>
                    <li>
                        Initial state is controlled via <code class="docs-code"
                            >initialOpen</code
                        > and rendered server-side
                    </li>
                    <li>
                        When collapsed, content height is animated using <code
                            class="docs-code"
                        >
                            grid-template-rows</code
                        >
                    </li>
                    <li>
                        Trigger element becomes interactive only after
                        JavaScript initializes
                    </li>
                    <li>
                        Chevron icon is hidden without JS and shown when
                        enhancement is active
                    </li>
                </ul>
            </div>
        </div>
        <!-- USE WHEN SECTION -->
        <div class="docs-intro-section" id="use-when">
            <h2 class="docs-subtitle">Use When</h2>
            <ul class="docs-list">
                <li>
                    Collapsible content sections that should remain accessible
                    without JavaScript
                </li>
                <li>
                    Progressive enhancement scenarios where interactivity is
                    optional
                </li>
                <li>Simple expand/collapse UI with smooth transitions</li>
                <li>When keyboard-accessible toggle behavior is required</li>
            </ul>
        </div>

        <!-- AVOID WHEN SECTION -->
        <div class="docs-intro-section" id="avoid-when">
            <h2 class="docs-subtitle">Avoid When</h2>
            <ul class="docs-list">
                <li>
                    Content must be hidden by default without JavaScript
                    (content is always visible initially)
                </li>
                <li>Complex nested or multi-level accordion structures</li>
                <li>
                    Advanced animation choreography beyond simple
                    expand/collapse
                </li>
            </ul>
        </div>
        <!-- ACCESSIBILITY SECTION -->
        <div class="docs-intro-section" id="accessibility">
            <h2 class="docs-subtitle">Accessibility</h2>
            <div>
                <ul class="docs-list">
                    <li>
                        Respects <code class="docs-code"
                            >prefers-reduced-motion</code
                        > (disables transitions)
                    </li>
                    <li>
                        When <code class="docs-code">enhance=true</code>:
                        <ul
                            class="docs-list"
                            style="margin-left: 20px; margin-top: 8px;"
                        >
                            <li>
                                Adds <code class="docs-code">role="button"</code>, <code
                                    class="docs-code">tabindex="0"</code
                                >, and <code class="docs-code">aria-expanded</code
                                >
                            </li>
                            <li>
                                Supports keyboard interaction (Enter and Space)
                            </li>
                        </ul>
                    </li>
                    <li>Focus-visible styles support keyboard navigation</li>
                    <li>Content remains fully accessible without JavaScript</li>
                </ul>
            </div>
        </div>

        <!-- PERFORMANCE SECTION -->
        <div class="docs-intro-section" id="performance">
            <h2 class="docs-subtitle">Performance</h2>
            <div>
                <ul class="docs-list">
                    <li>
                        CSS-first animation using <code class="docs-code"
                            >grid-template-rows</code
                        > (no layout thrashing)
                    </li>
                    <li>
                        JavaScript only updates attributes (<code
                            class="docs-code">data-state</code
                        >, ARIA)
                    </li>
                    <li>WeakMap prevents duplicate initialization</li>
                    <li>
                        MutationObserver ensures cleanup when element is removed
                        from the DOM
                    </li>
                </ul>
            </div>
        </div>

        <!-- CREDITS SECTION -->
        <div class="docs-intro-section" id="credits">
            <h2 class="docs-subtitle">Credits</h2>
            <ul class="docs-list">
                <li>
                    Credit to <a
                        href="https://github.com/barsaan"
                        target="_blank"
                        class="credits-link">@barsan</a
                    >
                </li>
            </ul>
        </div>

        <!-- RELATED COMPONENTS SECTION -->
        <RelatedComponents items={[{ name: "GlassCard", href: "/docs/glass-card", image: "/images/glasscard.png" }]} />
    </section>

    <div class="docs-footer-nav" style="justify-content: space-between;">
        <a href="/docs/reveal-image" class="prev-link">
            <span class="label">PREVIOUS</span>
            <span class="title">
                <svg
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    style="transform: rotate(180deg);"
                    ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
                        points="12 5 19 12 12 19"></polyline></svg
                >
                RevealImage
            </span>
        </a>
        <a href="/docs/animated-card" class="next-link">
            <span class="label">NEXT</span>
            <span class="title">
               AnimatedCard
                <svg
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
                        points="12 5 19 12 12 19"></polyline></svg
                >
            </span>
        </a>
    </div>

    <Fragment slot="toc">
        <div class="toc-header">IN THIS PAGE</div>
        <nav class="toc-nav">
            <a href="#expandable-card" class="active">Expandable Card</a>
            <a href="#preview-playground">Preview/Playground</a>
            <a href="#installation">Installation</a>
            <a href="#usage">Usage</a>
            <a href="#props">Props</a>
            <a href="#behavior">Behavior</a>
            <a href="#use-when">Use When</a>
            <a href="#avoid-when">Avoid When</a>
            <a href="#accessibility">Accessibility</a>
            <a href="#performance">Performance</a>
            <a href="#credits">Credits</a>
        </nav>
    </Fragment>
</DocLayout>

<style>
    .expandable-showcase {
        padding: 40px;
        min-height: 200px;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        max-width: 100%;
        min-width: 0;
        overflow: hidden;
    }

    .expandable-description {
        color: #666666;
        margin: 0;
        font-size: 16px;
        line-height: 1.45;
    }

    .expandable-stats {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 20px;
        justify-content: space-between;
        width: 100%;
    }

    .expandable-stat-value {
        color: #000;
        font-size: 24px;
        font-weight: 600;
        margin-bottom: 0;
    }

    .expandable-stat-label {
        color: #666666;
        font-size: 14px;
    }
    .created-by {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 20px;
        padding: 12px 16px;
        justify-content: right;
        border-radius: 8px;
    }

    .created-by-avatar {
        width: 24px;
        height: 24px;
        border-radius: 4px;
        overflow: hidden;
        flex-shrink: 0;
    }

    .created-by-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .created-by-info {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .created-by-label {
        font-family: "Inter", sans-serif;
        font-size: 14px;
        color: #4b5563;
    }

    .created-by-name {
        font-family: "Inter", sans-serif;
        font-size: 14px;
        font-weight: 500;
        color: #f9fafb;
    }

    .playground-container {
        display: grid;
        /* grid-template-columns: 1fr 1fr; */
        border: 1px solid #1f2937;
        background: #050505;
        border-radius: 12px;
        overflow: hidden;
        width: 100%;
        max-width: 100%;
        min-width: 0;
    }

    .playground-preview {
        padding: 40px;
        background: #000;
        display: flex;
        align-items: center;
        justify-content: center;
        min-width: 0;
        overflow: hidden;
        box-sizing: border-box;
    }

    .expandable-showcase :global(.astro-expandable-card) {
        width: min(100%, 420px);
        max-width: 100%;
        min-width: 0;
        box-sizing: border-box;
    }

    .expandable-showcase :global(.astro-expandable-card img) {
        max-width: 100%;
        height: auto;
        display: block;
    }

    .playground-code {
        background: #0d0d0d;
        padding: 0;
        display: flex;
        flex-direction: column;
        min-width: 0;
        max-width: 100%;
        overflow: hidden;
    }

    .code-header {
        background: #15191e;
        padding: 12px 16px;
        border-bottom: 1px solid #2a2a2a;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .code-header-left {
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: "JetBrains Mono", monospace;
        font-size: 13px;
        color: #fff;
    }

    .astro-logo {
        color: #ff5d01;
    }

    .code-content {
        padding: 20px;
        font-family: "JetBrains Mono", monospace;
        font-size: 13px;
        line-height: 1.6;
        overflow-x: auto;
        max-width: 100%;
        min-width: 0;
    }

    .code-content pre {
        margin: 0;
        color: #e0e0e0;
    }

    .code-selector {
        color: #9cdcfe;
    }

    .code-property {
        color: #9cdcfe;
    }

    .code-value {
        color: #ce9178;
    }

    .installation-block {
        background: transparent;
        border: 1px solid #1f2937;
        border-radius: 8px;
        overflow: hidden;
    }

    .installation-header {
        background: #0b0d10;
        padding: 8px 16px;
        border-bottom: 1px solid #2a2a2a;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .bash-label {
        font-family: "JetBrains Mono", monospace;
        font-size: 12px;
        color: #9ca3af;
    }

    .copy-icon {
        color: #9ca3af;
        cursor: pointer;
        transition: color 0.2s ease;
    }

    .copy-icon:hover {
        color: #f9fafb;
    }

    .installation-block pre {
        margin: 0;
        padding: 16px;
        background: transparent;
        font-family: "JetBrains Mono", monospace;
        font-size: 14px;
        color: #e0e0e0;
    }

    .code-header-text {
        color: #9ca3af;
        font-size: 12px;
        font-family: "Inter", sans-serif;
    }

    .package-name {
        color: #10b981;
    }

    .docs-code-block {
        background: #0b0d10;
        border: 1px solid #1f2937;
        border-radius: 8px;
        overflow: hidden;
    }

    .docs-code-block pre {
        margin: 0;
        padding: 16px;
        background: transparent;
        font-family: "JetBrains Mono", monospace;
        font-size: 14px;
        color: #e0e0e0;
    }

    .string {
        color: #ce9178;
    }

    .comment {
        color: #6a9955;
    }

    .component-name {
        color: #4ec9b0;
    }

    .component {
        color: #dcdcaa;
    }

    .prop {
        color: #9cdcfe;
    }

    .tag {
        color: #569cd6;
    }

    .docs-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        background: transparent;
        border-radius: 8px;
        overflow: hidden;
    }

    .docs-table th,
    .docs-table td {
        padding: 12px 16px;
        text-align: left;
        border-right: 1px solid #1f2937;
        font-family: "Inter", sans-serif;
    }

    .docs-table th:last-child,
    .docs-table td:last-child {
        border-right: none;
    }

    .docs-table th {
        background: #0b0d10;
        font-weight: 500;
        font-size: 14px;
        border-bottom: 1px solid #1f2937;
    }

    .docs-table td {
        color: #9ca3af;
        font-size: 14px;
        border-bottom: 1px solid #1f2937;
        background: transparent;
    }

    .docs-table tr:last-child td {
        border-bottom: none;
    }

    .docs-table td:first-child code {
        background: transparent;
        padding: 2px 6px;
        border-radius: 4px;
        font-family: "Inter", sans-serif;
        font-size: 14px;
    }

    .docs-table td:not(:first-child) code {
        background: #1f2937;
        padding: 2px 6px;
        border-radius: 4px;
        font-family: "JetBrains Mono", monospace;
        font-size: 12px;
        margin-right: 8px;
        display: inline-block;
        margin-bottom: 6px;
    }

    .docs-table td:not(:first-child) code:last-child {
        margin-right: 0;
    }

    .related-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-top: 24px;
    }

    .related-card {
        aspect-ratio: 16/9;
        border: 1px solid #1f2937;
        background: #050505;
        border-radius: 8px;
        display: flex;
