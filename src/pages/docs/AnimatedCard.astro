<style>
    /* Critical CSS optimizations */
    .created-by {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 20px;
        padding: 12px 16px;
        justify-content: flex-end;
        border-radius: 8px;
    }

    .created-by-avatar {
        width: 24px;
        height: 24px;
        border-radius: 4px;
        overflow: hidden;
