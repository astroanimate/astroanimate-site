---
import DocLayout from "../../layouts/DocLayout.astro";
import "../../styles/Global.css";
import AnimatedCardComponent from "@astroanimate/core/AnimatedCard";
---

<DocLayout title="Animated Card">
    <meta
        name="description"
        content="AnimatedCard - Astro animation component with lift, scale, shine, and flip variants. Complete documentation, props, usage examples, and performance optimization."
    />
    <meta
        name="keywords"
        content="AnimatedCard, Astro, animation, component, lift, scale, shine, flip, documentation, props, usage"
    />
    <meta name="author" content="Barsan" />
    <meta
        property="og:title"
        content="AnimatedCard – Astro animation component"
    />
    <meta
        property="og:description"
        content="Card component with lift, scale, shine, and flip variants. Complete documentation with props, usage examples, and performance optimization."
    />
    <meta property="og:type" content="article" />
    <meta property="og:image" content="/images/barsan.jpeg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta
        name="twitter:title"
        content="AnimatedCard – Astro animation component"
    />
    <meta
        name="twitter:description"
        content="Card component with lift, scale, shine, and flip variants."
    />
    <meta name="twitter:image" content="/images/barsan.jpeg" />
    <link rel="canonical" href="/docs/AnimatedCard" />

    <!-- Structured Data for SEO -->
    <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "TechArticle",
            "headline": "AnimatedCard – Astro animation component",
            "description": "Card component with lift, scale, shine, and flip variants. Complete documentation with props, usage examples, and performance optimization.",
            "author": {
                "@type": "Person",
                "name": "Barsan"
            },
            "datePublished": "2024-04-27",
            "dateModified": "2024-04-27",
            "mainEntityOfPage": {
                "@type": "WebPage",
                "@id": "/docs/AnimatedCard"
            },
            "programmingLanguage": "JavaScript",
            "keywords": [
                "AnimatedCard",
                "Astro",
                "animation",
                "component",
                "lift",
                "scale",
                "shine",
                "flip",
                "documentation"
            ]
        }
    </script>

    <!-- Performance optimizations -->
    <link rel="dns-prefetch" href="//fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <main id="animated-card" role="main">
        <header>
            <h1 class="docs-title">AnimatedCard – Astro animation component</h1>
        </header>

        <section class="docs-intro-section" aria-labelledby="intro-heading">
            <h2 id="intro-heading" class="sr-only">Introduction</h2>
            <p class="docs-paragraph">
                Card component with lift, scale, shine, and flip variants.
            </p>
        </section>

        <!-- PREVIEW/PLAYGROUND SECTION -->
        <section
            class="docs-intro-section"
            id="preview-playground"
            aria-labelledby="preview-heading"
        >
            <h2 id="preview-heading" class="docs-subtitle">
                Preview/Playground
            </h2>
            <div class="created-by" role="contentinfo">
                <span class="created-by-label">Created by</span>
                <div class="created-by-avatar">
                    <img
                        src="/images/barsan.jpeg"
                        alt="Barsan - Creator of AnimatedCard component"
                        width="24"
                        height="24"
                        loading="lazy"
                        decoding="async"
                    />
                </div>
                <span class="created-by-name">Barsan</span>
            </div>
            <div
                class="playground-container"
                role="region"
                aria-label="AnimatedCard component examples"
            >
                <div
                    class="playground-preview"
                    role="region"
                    aria-label="Live preview"
                >
                    <div class="card-showcase">
                        <AnimatedCardComponent
                            title="Feature Name"
                            description="Short description of the feature"
                            variant="lift"
                            color="rose"
                            aria-label="AnimatedCard lift variant example"
                        />

                        <div class="demo-cards">
                            <AnimatedCardComponent
                                title="Scale Card"
                                description="This card scales on hover"
                                variant="scale"
                                color="emerald"
                                aria-label="AnimatedCard scale variant example"
                            />
                            <AnimatedCardComponent
                                title="Shine Effect"
                                description="Beautiful shine animation"
                                variant="shine"
                                color="violet"
                                aria-label="AnimatedCard shine variant example"
                            />
                        </div>
                    </div>
                </div>
                <div
                    class="playground-code"
                    role="region"
                    aria-label="Code examples"
                >
                    <div class="code-header">
                        <div class="code-header-left">
                            <img
                                src="/images/astro.png"
                                alt="Astro framework logo"
                                width="14"
                                height="18"
                                loading="lazy"
                                decoding="async"
                            />
                            <span class="code-header-text">Astro</span>
                        </div>
                    </div>
                    <div class="code-content">
                        <pre><code><span class="keyword">import</span> <span class="component-name">AnimatedCard</span> <span class="keyword">from</span> <span class="string">"@astroanimate/core/AnimatedCard"</span>;

&lt;<span class="component">AnimatedCard</span>
  <span class="prop">title</span>=<span class="string">"Feature Name"</span>
  <span class="prop">description</span>=<span class="string">"Short description of the feature"</span>
  <span class="prop">variant</span>=<span class="string">"lift"</span>
  <span class="prop">color</span>=<span class="string">"rose"</span>
/&gt;

&lt;<span class="component">AnimatedCard</span>
  <span class="prop">title</span>=<span class="string">"Feature Name"</span>
  <span class="prop">description</span>=<span class="string">"Short description of the feature"</span>
  <span class="prop">variant</span>=<span class="string">"scale"</span>
  <span class="prop">color</span>=<span class="string">"rose"</span>
/&gt;

&lt;<span class="component">AnimatedCard</span>
  <span class="prop">title</span>=<span class="string">"Feature Name"</span>
  <span class="prop">description</span>=<span class="string">"Short description of the feature"</span>
  <span class="prop">variant</span>=<span class="string">"shine"</span>
  <span class="prop">color</span>=<span class="string">"rose"</span>
/&gt;


</code></pre>
                    </div>
                </div>
            </div>
        </section>

        <!-- INSTALLATION SECTION -->
        <div class="docs-intro-section" id="installation">
            <h2 class="docs-subtitle">Installation</h2>
            <div class="installation-block">
                <div class="installation-header">
                    <span class="bash-label">bash</span>
                    <svg
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="copy-icon"
                    >
                        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"
                        ></rect>
                        <path
                            d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
                        ></path>
                    </svg>
                </div>
                <pre><code><span class="keyword">npm</span> install <span class="string">@astro-animate/card</span></code></pre>
            </div>
        </div>

        <!-- QUICK START SECTION -->
        <div class="docs-intro-section" id="example">
            <h2 class="docs-subtitle">Quick Start</h2>
            <div class="docs-code-block">
                <pre><code><span class="comment">---</span>
<span class="keyword">import</span> <span class="component-name">AnimatedCard</span> <span class="keyword">from</span> <span class="string">"@astroanimate/core/AnimatedCard"</span>;
<span class="comment">---</span>
&lt;<span class="component">AnimatedCard</span>
  <span class="prop">title</span>=<span class="string">"Feature Name"</span>
  <span class="prop">description</span>=<span class="string">"Short description of the feature"</span>
  <span class="prop">variant</span>=<span class="string">"lift"</span>
  <span class="prop">color</span>=<span class="string">"rose"</span>
/&gt;</code></pre>
            </div>
        </div>

        <!-- PROPS SECTION -->
        <div class="docs-intro-section" id="props">
            <h2 class="docs-subtitle">Props</h2>
            <div class="table-wrapper">
                <table class="docs-table">
                    <thead>
                        <tr>
                            <th>Prop</th>
                            <th>Type</th>
                            <th>Default</th>
                            <th>Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr
                            ><td><code>title</code></td><td
                                ><code>string</code></td
                            ><td><code>-</code></td><td
                                >Card heading (required)</td
                            ></tr
                        >
                        <tr
                            ><td><code>description</code></td><td
                                ><code>string</code></td
                            ><td><code>-</code></td><td
                                >Card body text (required)</td
                            ></tr
                        >
                        <tr
                            ><td><code>variant</code></td><td
                                ><code>"lift" | "scale" | "flip" | "shine"</code
                                ></td
                            ><td><code>"lift"</code></td><td>Animation style</td
                            ></tr
                        >
                        <tr
                            ><td><code>color</code></td><td
                                ><code
                                    >"rose" | "emerald" | "violet" | "amber"</code
                                ></td
                            ><td><code>"rose"</code></td><td>Theme color</td
                            ></tr
                        >
                        <tr
                            ><td><code>selected</code></td><td
                                ><code>boolean</code></td
                            ><td><code>false</code></td><td
                                >Shows "Selected" badge</td
                            ></tr
                        >
                        <tr
                            ><td><code>selectedOnScroll</code></td><td
                                ><code>boolean</code></td
                            ><td><code>false</code></td><td
                                >Shows indicator on scroll (35% visibility
                                threshold, -12% root margin, fires once)</td
                            ></tr
                        >
                        <tr
                            ><td><code>class</code></td><td
                                ><code>string</code></td
                            ><td><code>""</code></td><td
                                >CSS class name (merged with customClass)</td
                            ></tr
                        >
                        <tr
                            ><td><code>customClass</code></td><td
                                ><code>string</code></td
                            ><td><code>""</code></td><td
                                >Additional CSS class (merged with class)</td
                            ></tr
                        >
                        <tr
                            ><td><code>style</code></td><td
                                ><code>string</code></td
                            ><td><code>""</code></td><td>Inline styles</td></tr
                        >
                        <tr
                            ><td><code>href</code></td><td
                                ><code>string</code></td
                            ><td><code>-</code></td><td
                                >Renders as link when provided</td
                            ></tr
                        >
                        <tr
                            ><td><code>target</code></td><td
                                ><code>string</code></td
                            ><td><code>-</code></td><td
                                >Link target attribute</td
                            ></tr
                        >
                        <tr
                            ><td><code>rel</code></td><td
                                ><code>string</code></td
                            ><td><code>-</code></td><td>Link rel attribute</td
                            ></tr
                        >
                        <tr
                            ><td><code>backTitle</code></td><td
                                ><code>string</code></td
                            ><td><code>-</code></td><td
                                >Back face heading (flip variant)</td
                            ></tr
                        >
                        <tr
                            ><td><code>backDescription</code></td><td
                                ><code>string</code></td
                            ><td
                                ><code
                                    >"Tap or click the button below to flip this
                                    card back."</code
                                ></td
                            ><td>Back face description</td></tr
                        >
                        <tr
                            ><td><code>backButtonText</code></td><td
                                ><code>string</code></td
                            ><td><code>"Flip back"</code></td><td
                                >Flip button text</td
                            ></tr
                        >
                        <tr
                            ><td><code>flipHint</code></td><td
                                ><code>string</code></td
                            ><td><code>"Flip to reveal more details"</code></td
                            ><td>Flip instruction text</td></tr
                        >
                        <tr
                            ><td><code>iconLabel</code></td><td
                                ><code>string</code></td
                            ><td><code>"✦"</code></td><td
                                >Fallback icon character</td
                            ></tr
                        >
                        <tr
                            ><td><code>minHeight</code></td><td
                                ><code>string</code></td
                            ><td><code>"18rem"</code></td><td
                                >Minimum card height</td
                            ></tr
                        >
                        <tr
                            ><td><code>ariaLabel</code></td><td
                                ><code>string</code></td
                            ><td><code>-</code></td><td>Custom ARIA label</td
                            ></tr
                        >
                    </tbody>
                </table>
            </div>
        </div>

        <!-- SLOTS SECTION -->
        <div class="docs-intro-section" id="slots">
            <h2 class="docs-subtitle">Slots</h2>
            <div class="table-wrapper">
                <table class="docs-table">
                    <thead>
                        <tr>
                            <th>Slot</th>
                            <th>Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr
                            ><td><code>icon</code></td><td
                                >Custom icon content</td
                            ></tr
                        >
                        <tr
                            ><td><code>back-content</code></td><td
                                >Custom back face content (flip variant). Note:
                                flip-back button always renders after this slot</td
                            ></tr
                        >
                    </tbody>
                </table>
            </div>
        </div>

        <!-- CSS CUSTOM PROPERTIES SECTION -->
        <div class="docs-intro-section" id="css-custom-properties">
            <h2 class="docs-subtitle">CSS Custom Properties</h2>
            <p class="docs-paragraph">
                Override these variables to customize styling:
            </p>
            <div class="table-wrapper">
                <table class="docs-table">
                    <thead>
                        <tr>
                            <th>Property</th>
                            <th>Default</th>
                            <th>Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr
                            ><td><code>--animated-card-radius</code></td><td
                                ><code>1.5rem</code></td
                            ><td>Card border radius</td></tr
                        >
                        <tr
                            ><td><code>--animated-card-padding</code></td><td
                                ><code>1.5rem</code></td
                            ><td>Card padding</td></tr
                        >
                        <tr
                            ><td><code>--animated-card-shadow</code></td><td
                                ><code
                                    >0 14px 30px rgba(2, 6, 23, 0.24), 0 2px
                                    10px rgba(2, 6, 23, 0.2)</code
                                ></td
                            ><td>Default box shadow</td></tr
                        >
                        <tr
                            ><td><code>--animated-card-shadow-active</code></td
                            ><td
                                ><code
                                    >0 28px 52px rgba(2, 6, 23, 0.42), 0 0 0 1px
                                    rgba(255, 255, 255, 0.03)</code
                                ></td
                            ><td>Active state shadow</td></tr
                        >
                        <tr
                            ><td><code>--animated-card-title-size</code></td><td
                                ><code>1.25rem</code></td
                            ><td>Title font size</td></tr
                        >
                        <tr
                            ><td><code>--animated-card-icon-size</code></td><td
                                ><code>3.5rem</code></td
                            ><td>Icon container size</td></tr
                        >
                        <tr
                            ><td><code>--animated-card-accent</code></td><td
                                ><code>(theme-dependent)</code></td
                            ><td>Accent color</td></tr
                        >
                        <tr
                            ><td><code>--animated-card-accent-text</code></td
                            ><td><code>(theme-dependent)</code></td><td
                                >Accent text color</td
                            ></tr
                        >
                        <tr
                            ><td><code>--animated-card-border</code></td><td
                                ><code>(theme-dependent)</code></td
                            ><td>Border color</td></tr
                        >
                        <tr
                            ><td><code>--animated-card-soft</code></td><td
                                ><code>(theme-dependent)</code></td
                            ><td>Soft background color</td></tr
                        >
                        <tr
                            ><td><code>--animated-card-aura</code></td><td
                                ><code>(theme-dependent)</code></td
                            ><td>Ambient glow color</td></tr
                        >
                        <tr
                            ><td><code>--animated-card-surface</code></td><td
                                ><code>(theme-dependent)</code></td
                            ><td>Front face background</td></tr
                        >
                        <tr
                            ><td><code>--animated-card-back-surface</code></td
                            ><td><code>(theme-dependent)</code></td><td
                                >Back face background</td
                            ></tr
                        >
                        <tr
                            ><td><code>--animated-card-inset</code></td><td
                                ><code>(theme-dependent)</code></td
                            ><td>Inner glow color</td></tr
                        >
                    </tbody>
                </table>
            </div>
        </div>

        <!-- RESPONSIVE DESIGN SECTION -->
        <div class="docs-intro-section" id="responsive-design">
            <h2 class="docs-subtitle">Responsive Design</h2>
            <div class="docs-content">
                <p class="docs-paragraph">At <code>max-width: 640px</code>:</p>
                <ul class="docs-list">
                    <li>Padding reduces to <code>1.25rem</code></li>
                    <li>Border radius reduces to <code>1.25rem</code></li>
                    <li>Title font size reduces to 1.12rem</li>
                    <li>Description font size reduces to 0.92rem</li>
                </ul>
            </div>
        </div>

        <!-- USE WHEN SECTION -->
        <div class="docs-intro-section" id="use-when">
            <h2 class="docs-subtitle">Use When</h2>
            <ul class="docs-list">
                <li>Displaying feature cards with hover effects</li>
                <li>Creating interactive product showcases</li>
                <li>Building navigation or selection cards</li>
                <li>Showing expandable content with flip variant</li>
            </ul>
        </div>

        <!-- AVOID WHEN SECTION -->
        <div class="docs-intro-section" id="avoid-when">
            <h2 class="docs-subtitle">Avoid When</h2>
            <ul class="docs-list">
                <li>Simple static cards without animation needs</li>
                <li>Content requiring complex interactive forms</li>
                <li>Scenarios requiring zero JavaScript (flip variant)</li>
                <li>
                    Performance-critical pages with many cards (GPU load from
                    multiple animated elements)
                </li>
            </ul>
        </div>

        <!-- NOTES SECTION -->
        <div class="docs-intro-section" id="notes">
            <h2 class="docs-subtitle">Notes</h2>
            <ul class="docs-list">
                <li>
                    Lift, scale, and shine variants render a meta row at the
                    bottom showing "[variant] interaction" with a colored dot
                </li>
                <li>
                    Flip variant uses CSS 3D transforms for card flipping
                    animation
                </li>
            </ul>
        </div>

        <!-- ACCESSIBILITY SECTION -->
        <div class="docs-intro-section" id="accessibility">
            <h2 class="docs-subtitle">Accessibility</h2>
            <ul class="docs-list">
                <li>
                    Respects <code class="keyword">prefers-reduced-motion</code> media
                    query
                </li>
                <li>Includes ARIA labels and focus-visible states</li>
                <li>Keyboard navigation for flip variant (Enter/Space)</li>
                <li>
                    Decorative elements marked with <code class="keyword"
                        >aria-hidden</code
                    >
                </li>
            </ul>
        </div>

        <!-- PERFORMANCE NOTES SECTION -->
        <div class="docs-intro-section" id="performance-notes">
            <h2 class="docs-subtitle">Performance Notes</h2>
            <ul class="docs-list">
                <li>
                    CSS-driven architecture with zero hydration for non-flip
                    variants
                </li>
                <li>
                    Minimal JavaScript only for flip keyboard interactions and
                    scroll-based selection
                </li>
                <li>
                    Uses IntersectionObserver for scroll-based indicator
                    (passive listener)
                </li>
            </ul>
        </div>

