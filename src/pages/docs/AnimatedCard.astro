            <div class="created-by" role="contentinfo">
                <span class="created-by-label">Created by</span>
                <div class="created-by-avatar">
                    <img 
                    src="/images/barsan.jpeg" 
                    alt="Barsan - Creator of AnimatedCard component" 
                    width="24" 
                    height="24" 
                    loading="lazy"
                    decoding="async"
                />
                </div>
                <span class="created-by-name">Barsan</span>
            </div>
            <div class="playground-container" role="region" aria-label="AnimatedCard component examples">
                <div class="playground-preview" role="region" aria-label="Live preview">
                    <div class="card-showcase">
                      <AnimatedCardComponent
                        title="Feature Name"
                        description="Short description of the feature"
                        variant="lift"
                        color="rose"
                        aria-label="AnimatedCard lift variant example"
                      />

                        <div class="demo-cards">
                            <AnimatedCardComponent
                                title="Scale Card"
                                description="This card scales on hover"
                                variant="scale"
                                color="emerald"
                                aria-label="AnimatedCard scale variant example"
                            />
                            <AnimatedCardComponent
                                title="Shine Effect"
                                description="Beautiful shine animation"
                                variant="shine"
                                color="violet"
                                aria-label="AnimatedCard shine variant example"
                            />
                        </div>
                    </div>
                </div>
                <div class="playground-code" role="region" aria-label="Code examples">
                    <div class="code-header">
                        <div class="code-header-left">
                          <img 
                            src="/images/astro.png" 
                            alt="Astro framework logo" 
                            width="14" 
                            height="18" 
                            loading="lazy"
                            decoding="async"
                          />
                            <span class="code-header-text">Astro</span>
                        </div>
                    </div>
                    <div class="code-content">
                        <pre><code><span class="keyword">import</span> <span class="component-name">AnimatedCard</span> <span class="keyword">from</span> <span class="string">"@astroanimate/core/AnimatedCard"</span>;

&lt;<span class="component">AnimatedCard</span>
  <span class="prop">title</span>=<span class="string">"Feature Name"</span>
  <span class="prop">description</span>=<span class="string">"Short description of the feature"</span>
  <span class="prop">variant</span>=<span class="string">"lift"</span>
  <span class="prop">color</span>=<span class="string">"rose"</span>
/&gt;

&lt;<span class="component">AnimatedCard</span>
  <span class="prop">title</span>=<span class="string">"Feature Name"</span>
  <span class="prop">description</span>=<span class="string">"Short description of the feature"</span>
  <span class="prop">variant</span>=<span class="string">"scale"</span>
  <span class="prop">color</span>=<span class="string">"rose"</span>
/&gt;

&lt;<span class="component">AnimatedCard</span>
  <span class="prop">title</span>=<span class="string">"Feature Name"</span>
  <span class="prop">description</span>=<span class="string">"Short description of the feature"</span>
  <span class="prop">variant</span>=<span class="string">"shine"</span>
  <span class="prop">color</span>=<span class="string">"rose"</span>
/&gt;


</code></pre>
                    </div>
                </div>
            </div>
        </div>

        <!-- INSTALLATION SECTION -->
        <div class="docs-intro-section" id="installation">
            <h2 class="docs-subtitle">Installation</h2>
            <div class="installation-block">
                <div class="installation-header">
                    <span class="bash-label">bash</span>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="copy-icon">
                        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                    </svg>
                </div>
                <pre><code><span class="keyword">npm</span> install <span class="string">@astro-animate/card</span></code></pre>
            </div>
        </div>

        <!-- QUICK START SECTION -->
          <div class="docs-intro-section" id="example">
            <h2 class="docs-subtitle">Quick Start</h2>
            <div class="docs-code-block">
                <pre><code><span class="comment">---</span>
<span class="keyword">import</span> <span class="component-name">AnimatedCard</span> <span class="keyword">from</span> <span class="string">"@astroanimate/core/AnimatedCard"</span>;
<span class="comment">---</span>

&lt;<span class="component">AnimatedCard</span> <span class="prop">variant</span>=<span class="string">"shimmer"</span>&gt;Explore&lt;/<span class="component">AnimatedCard</span>&gt;</code></pre>
            </div>
        </div>

        <!-- PROPS SECTION -->
        <div class="docs-intro-section" id="props">
            <h2 class="docs-subtitle">Props</h2>
            <div class="table-wrapper">
                <table class="docs-table">
                    <thead>
                        <tr>
                            <th>Prop</th>
                            <th>Type</th>
                            <th>Default</th>
                            <th>Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><code>variant</code></td>
                            <td><code>shimmer</code> <code>fill</code> <code>border</code> <code>none</code></td>
                            <td><code>none</code></td>
                            <td>Selects which built-in visual effect classes and decorative spans are rendered.</td>
                        </tr>
                        <tr>
                            <td><code>href</code></td>
                            <td><code>string</code></td>
                            <td>-</td>
                            <td>When provided, the root element is rendered as &lt;a&gt;; otherwise it renders as &lt;div&gt;</td>
                        </tr>
                        <tr>
                            <td><code>class</code></td>
                            <td><code>string</code></td>
                            <td><code>""</code></td>
                            <td>Appends custom classes to the root element alongside internal classes.</td>
                        </tr>
                        <tr>
                            <td><code>shimmer Color</code></td>
                            <td><code>string</code></td>
                            <td><code>"rgba(255, 255, 255, 0.4)"</code></td>
                            <td>Sets --shimmer-color inline when variant="shimmer".</td>
                        </tr>
                          <tr>
                            <td><code>...rest</code></td>
                            <td><code>Record&lt;string, unknown&gt;</code></td>
                            <td>-</td>
                            <td>Additional attributes are forwarded to the root element.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- HOW IT WORKS SECTION -->
        <div class="docs-intro-section" id="how-it-works">
            <h2 class="docs-subtitle">How It Works</h2>
            <p class="docs-paragraph">
                ✅ Use when:
            </p>
            <ul class="docs-list">
                <li>You want animated card visuals without shipping client JS.</li>
                <li>You need SSR-safe markup with visible content before any enhancement.</li>
                <li>You need a single component that can act as link or card.</li>
            </ul>

            <p>❌ Avoid when:</p>
            <ul class="docs-list">
                <li>You need programmable animation timing controls like duration or delay per instance (Not exposed in current implementation.).</li>
                <li>You need non-hover interaction animation triggers such as in-view or click-sequenced timelines (Not exposed in current implementation.).</li>
         <li>You need fully custom variant presets beyond <span class="keyword">none, shimmer, fill, border;</span>  use custom classes/CSS instead.</li>
            </ul>
        </div>

        <!-- ACCESSIBILITY SECTION -->
        <div class="docs-intro-section" id="accessibility">
            <h2 class="docs-subtitle">Accessibility</h2>
           <ul class="docs-list">
                <li>Decorative animation layers are marked <span class="keyword">aria-hidden="true"</span> </li>
                <li>Reduced motion is explicitly handled via @media (prefers-reduced-motion: reduce).</li>
                <li>No additional ARIA role/state management is added by the component.</li>
            </ul>
        </div>

        <!-- PERFORMANCE NOTES SECTION -->
        <div class="docs-intro-section" id="performance-notes">
            <h2 class="docs-subtitle">Performance Notes</h2>
             <ul class="docs-list">
                <li>No hydration directives and no <span class="keyword"> &lt;script&gt; </span> block are present, so runtime JS payload from this component is effectively zero.</li>
                <li>Behavior is CSS-first and SSR-compatible because markup/styles are produced at render time.</li>
                <li>Hover effects rely on extra spans for some variants, which adds small DOM overhead.</li>
            </ul>
        </div>

        <!-- EDGE CASES SECTION -->
        <div class="docs-intro-section" id="edge-cases">
            <h2 class="docs-subtitle">Edge Cases</h2>
            <ul class="docs-list">
                <li>Passing href changes semantics and keyboard behavior to a link element.</li>
                <li><span class="keyword">shimmerColor</span> has no effect unless <span class="keyword">variant="shimmer"</span>.</li>
                <li>Border and fill visuals assume sufficient <span class="keyword">text/background </span> contrast from consumer styling.</li>
                <li>Unknown variant values are typed against in TS, but fallback class resolution becomes empty at runtime.</li>
            </ul>
        </div>

        <!-- COMPONENTS API SECTION -->
        <div class="docs-intro-section" id="components-api">
            <h2 class="docs-subtitle">Components API</h2>
            <ul  class="docs-list">
                <li><a href="#animated-card" class="component-link">&lt;AnimatedCard /&gt;</a></li>
                <li><a href="#popper" class="component-link">&lt;Popper /&gt;</a></li>
                <li><a href="#text-field" class="component-link">&lt;TextField /&gt;</a></li>
            </ul>
        </div>

        <div class="docs-intro-section" id="components-api">
            <h2 class="docs-subtitle">Credits</h2>
            <ul  class="docs-list">
                <li>Credit to <a href="https://github.com/barsan" class="credits-link">@barsan</a></li>
              
            </ul>
        </div>

        <!-- RELATED COMPONENTS SECTION -->
        <div class="docs-intro-section" id="related-components">
            <h2 class="docs-subtitle">Related Components</h2>
            <div class="related-grid">
                <div class="related-card empty"></div>
                <div class="related-card empty"></div>
                <div class="related-card empty"></div>
                <div class="related-card empty"></div>
            </div>
        </div>

        <div class="docs-footer-nav" style="justify-content: space-between;">
            <a href="/docs/AnimatedButton" class="prev-link">
                <span class="label">PREVIOUS</span>
                <span class="title">
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        style="transform: rotate(180deg);"
                        ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
                            points="12 5 19 12 12 19"></polyline></svg
                    >
                    Animated Button
                </span>
            </a>
            <a href="/docs/quick-start" class="next-link">
                <span class="label">NEXT</span>
                <span class="title">
                    Quick Start
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
                            points="12 5 19 12 12 19"></polyline></svg
                    >
                </span>
            </a>
        </div>
    </section>

    <Fragment slot="toc">
        <div class="toc-header">IN THIS PAGE</div>
        <nav class="toc-nav">
            <a href="#animated-card" class="active">Animated Card</a>
            <a href="#preview-playground">Preview/Playground</a>
            <a href="#installation">Installation</a>
