---
import DocLayout from "../../../layouts/DocLayout.astro";
import RelatedComponents from "../../../components/RelatedComponents.astro";
import "../../../styles/Global.css";
import { TypewriterText } from "@astroanimate/core";
---

<DocLayout title="Typewriter Text">
  <section id="typewriter-text">
    <h1 class="docs-title">
      Typewriter text <button
        type="button"
        class="docs-title-share"
        aria-label="Copy page link"
        ><img
          src="/images/share-link.png"
          alt=""
          width="16"
          height="16"
        /></button
      >
    </h1>

    <div class="docs-intro-section">
      <p class="docs-paragraph">
        Renders text with a typewriter-style animation that cycles through an
        array of strings. Uses a JavaScript-driven typing effect with a CSS-only
        static fallback.
      </p>
    </div>

    <!-- PREVIEW/PLAYGROUND SECTION -->
    <div class="docs-intro-section" id="preview-playground">
      <h2 class="docs-subtitle">Preview/Playground</h2>
      <div class="created-by">
        <span class="created-by-label">Created by</span>
        <div class="created-by-avatar">
          <img src="/images/vipin.jpg" alt="Creator" />
        </div>

        <span class="created-by-name">Vipin</span>
      </div>
      <div class="playground-container">
        <div class="playground-preview typewriter-playground">
          <div class="typewriter-showcase">
            <div class="demo-typewriter">
              We build
              <p class="typewritter-text">
<TypewriterText
                texts={["Astro sites", "Animations", "SaaS Projects"]}
                typeSpeed={60}
                eraseSpeed={30}
                pauseAfter={1500}
                enhance
                
              />
              </p>
              
            </div>
            <div class="typewriter-preview-actions">
              <a href="#" class="typewriter-preview-btn typewriter-preview-btn-outline">
                Learn more
              </a>
              <a href="#" class="typewriter-preview-btn typewriter-preview-btn-filled">
                Work with us
              </a>
            </div>
          </div>
        </div>
        <div class="playground-code">
          <div class="code-header">
            <div class="code-header-left">
              <img src="/images/astro.png" alt="Astro" width="14" height="18" />
              <span class="code-header-text">Astro</span>
            </div>
          </div>
          <div class="code-content">
            <pre><code><span class="keyword">import</span> <span class="component-name">TypewriterText</span> <span class="keyword">from</span> <span class="string">"@astroanimate/core/TypewriterText"</span>;

&lt;<span class="component">TypewriterText</span>
  <span class="prop">texts</span>=<span class="string">&#123;["Hello", "World", "Astro"]&#125;</span>
  <span class="prop">enhance</span>
/&gt;</code></pre>
          </div>
        </div>
      </div>
    </div>

    <!-- INSTALLATION SECTION -->
    <div class="docs-intro-section" id="installation">
      <h2 class="docs-subtitle">Installation</h2>
      <div class="installation-block">
        <div class="installation-header">
          <span class="bash-label">bash</span>
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="copy-icon"
          >
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
            ></path>
          </svg>
        </div>
        <pre><code><span class="keyword">npm</span> install <span class="string">@astroanimate/core</span></code></pre>
      </div>
    </div>

    <!-- QUICK START SECTION -->
    <div class="docs-intro-section" id="example">
      <h2 class="docs-subtitle">Usage</h2>
      <div class="docs-code-block">
        <pre><code><span class="keyword">import</span> <span class="component-name">TypewriterText</span> <span class="keyword">from</span> <span class="string">"@astroanimate/core/TypewriterText"</span>;

&lt;<span class="component">TypewriterText</span>
  <span class="prop">texts</span>=<span class="string">&#123;["Hello", "World", "Astro"]&#125;</span>
  <span class="prop">enhance</span>
/&gt;</code></pre>
      </div>
      <p class="docs-paragraph">
        Displays animated typing/erasing text when
        <span class="docs-code">enhance=true</span>.
      </p>
      <div class="docs-code-block" style="margin-top: 16px;">
        <pre><code>&lt;<span class="component">TypewriterText</span>
  <span class="prop">texts</span>=<span class="string">&#123;["Fast", "Reliable", "Astro-native"]&#125;</span>
  <span class="prop">typeSpeed</span>=<span class="string">&#123;60&#125;</span>
  <span class="prop">eraseSpeed</span>=<span class="string">&#123;30&#125;</span>
  <span class="prop">pauseAfter</span>=<span class="string">&#123;1500&#125;</span>
  <span class="prop">enhance</span>
/&gt;</code></pre>
      </div>
      <p class="docs-paragraph">Customizes typing speed and timing behavior.</p>
    </div>

    <!-- PROPS SECTION -->
    <div class="docs-intro-section" id="props">
      <h2 class="docs-subtitle">Props</h2>
      <div class="table-wrapper">
        <table class="docs-table">
          <thead>
            <tr>
              <th>Prop</th>
              <th>Type</th>
              <th>Default</th>
              <th>Description</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><code>texts</code></td>
              <td><code>string[]</code></td>
              <td><code>(required)</code></td>
              <td
                >Array of strings to cycle through (first string used as static
                fallback)</td
              >
            </tr>
            <tr>
              <td><code>enhance</code></td>
              <td><code>boolean</code></td>
              <td><code>false</code></td>
              <td
                >Enable JavaScript-powered typing animation (replaces static
                fallback content)</td
              >
            </tr>
            <tr>
              <td><code>typeSpeed</code></td>
              <td><code>number</code></td>
              <td><code>70</code></td>
              <td>Milliseconds per character during typing</td>
            </tr>
            <tr>
              <td><code>eraseSpeed</code></td>
              <td><code>number</code></td>
              <td><code>40</code></td>
              <td>Milliseconds per character during erasing</td>
            </tr>
            <tr>
              <td><code>pauseAfter</code></td>
              <td><code>number</code></td>
              <td><code>1800</code></td>
              <td>Milliseconds to pause after fully typing a string</td>
            </tr>
            <tr>
              <td><code>pauseEmpty</code></td>
              <td><code>number</code></td>
              <td><code>500</code></td>
              <td>Milliseconds to pause when fully erased</td>
            </tr>
            <tr>
              <td><code>showCursor</code></td>
              <td><code>boolean</code></td>
              <td><code>true</code></td>
              <td>Whether to render the cursor element</td>
            </tr>
            <tr>
              <td><code>cursor</code></td>
              <td><code>string</code></td>
              <td><code>"|"</code></td>
              <td>Cursor character</td>
            </tr>
            <tr>
              <td><code>mainClassName</code></td>
              <td><code>string</code></td>
              <td><code>""</code></td>
              <td>Custom class applied to root element</td>
            </tr>
            <tr>
              <td><code>loop</code></td>
              <td><code>boolean</code></td>
              <td><code>true</code></td>
              <td>Whether to loop continuously</td>
            </tr>
            <tr>
              <td><code>erase</code></td>
              <td><code>boolean</code></td>
              <td><code>true</code></td>
              <td>Whether to erase before typing next phrase</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- HOW IT WORKS SECTION -->
    <div class="docs-intro-section" id="how-it-works">
      <h2 class="docs-subtitle">Behavior</h2>
      <ul class="docs-list">
        <li>
          Displays the first string as static content by default (no JavaScript
          required)
        </li>
        <li>
          When <span class="docs-code">enhance=true</span>, JavaScript replaces
          static content with dynamic typing animation
        </li>
        <li>
          Animation progresses through multiple phases:
          <ul class="docs-list" style="margin-left: 20px; margin-top: 8px;">
            <li>Typing characters one by one</li>
            <li>Pausing after the full string is typed</li>
            <li>
              Erasing characters (if <span class="docs-code">erase=true</span>)
            </li>
            <li>Pausing before the next string</li>
          </ul>
        </li>
        <li>
          When <span class="docs-code">loop=false</span>, animation stops after
          one full cycle
        </li>
        <li>
          When <span class="docs-code">erase=false</span>, text accumulates
          instead of being removed
        </li>
        <li>
          Cursor is rendered using CSS and remains visible without JavaScript
        </li>
      </ul>
    </div>

    <!-- USE WHEN SECTION -->
    <div class="docs-intro-section" id="use-when">
      <h2 class="docs-subtitle">Use When</h2>
      <ul class="docs-list">
        <li>Displaying rotating headlines or taglines</li>
        <li>Creating typing effects for hero sections</li>
        <li>
          Showing short, dynamic text content with progressive enhancement
        </li>
      </ul>
    </div>

    <!-- AVOID WHEN SECTION -->
    <div class="docs-intro-section" id="avoid-when">
      <h2 class="docs-subtitle">Avoid When</h2>
      <ul class="docs-list">
        <li>
          Content must always be fully visible without JavaScript (only the
          first string is shown)
        </li>
        <li>Displaying long or complex text blocks</li>
        <li>Precise formatting or rich text rendering is required</li>
      </ul>
    </div>

    <!-- ACCESSIBILITY SECTION -->
    <div class="docs-intro-section" id="accessibility">
      <h2 class="docs-subtitle">Accessibility</h2>
      <ul class="docs-list">
        <li>
          Includes <span class="docs-code">aria-label</span>, <span
            class="docs-code">aria-live="polite"</span
          >, and <span class="docs-code">aria-atomic="true"</span> for screen readers
        </li>
        <li>
          Respects <span class="docs-code">prefers-reduced-motion</span>
        </li>
        <li>
          Typing animation and cursor blinking are disabled when reduced motion
          is preferred
        </li>
        <li>Static fallback ensures meaningful content is always available</li>
      </ul>
    </div>

    <!-- PERFORMANCE SECTION -->
    <div class="docs-intro-section" id="performance">
      <h2 class="docs-subtitle">Performance</h2>
      <ul class="docs-list">
        <li>
          Uses <span class="docs-code">setTimeout</span>-based scheduling for
          precise timing control
        </li>
        <li>WeakMap prevents duplicate initialization</li>
        <li>
          MutationObserver ensures timers are cleaned up when element is removed
          from the DOM
        </li>
        <li>
          No layout shifts — content updates via <span class="docs-code"
            >textContent</span
          > only
        </li>
      </ul>
    </div>

    <!-- COMPONENTS API SECTION -->
    <!-- <div class="docs-intro-section" id="components-api">
            <h2 class="docs-subtitle">Components API</h2>
            <ul class="docs-list">
                <li>
                    <a href="#typewriter-text" class="component-link"
                        >&lt;TypewriterText /&gt;</a>
                </li>
                <li>
                    <a href="#animated-button" class="component-link"
                        >&lt;AnimatedButton /&gt;</a>
                </li>
                <li>
                    <a href="#animated-card" class="component-link"
                        >&lt;AnimatedCard /&gt;</a>
                </li>
            </ul>
        </div> -->

    <div class="docs-intro-section" id="components-api">
      <h2 class="docs-subtitle">Credits</h2>
      <ul class="docs-list">
        <li>
          Credit to <a
            href="https://github.com/Krishvipin"
            target="_blank"
            class="credits-link">@vipin</a
          >
        </li>
      </ul>
    </div>

    <!-- RELATED COMPONENTS SECTION -->
    <RelatedComponents
      items={[
        {
          name: "FadeInText",
          href: "/docs/fade-in-text/",
          image: "/images/fadein.png",
        },
      ]}
    />

    <div class="docs-footer-nav" style="justify-content: space-between;">
      <a href="/docs/fade-in-text/" class="prev-link">
        <span class="label">PREVIOUS</span>
        <span class="title">
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            style="transform: rotate(180deg);"
            ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
              points="12 5 19 12 12 19"></polyline></svg
          >
          FadeInText
        </span>
      </a>
      <a href="/docs/scale-in/" class="next-link">
        <span class="label">NEXT</span>
        <span class="title">
          ScaleIn
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
              points="12 5 19 12 12 19"></polyline></svg
          >
        </span>
      </a>
    </div>
  </section>

  <Fragment slot="toc">
    <div class="toc-header">IN THIS PAGE</div>
    <nav class="toc-nav">
      <a href="#typewriter-text" class="active">Typewriter Text</a>
      <a href="#preview-playground">Preview/Playground</a>
      <a href="#installation">Installation</a>
      <a href="#example">Usage</a>
      <a href="#props">Props</a>
      <a href="#how-it-works">Behavior</a>
      <a href="#use-when">Use When</a>
      <a href="#avoid-when">Avoid When</a>
      <a href="#accessibility">Accessibility</a>
      <a href="#performance">Performance</a>
      <a href="#components-api">Components API</a>
      <a href="#related-components">Related Components</a>
    </nav>
  </Fragment>
</DocLayout>

<style>

  .typewritter-text {
    color: #3B82F6;
    margin: 0;
    min-width: 0;
  }
  .created-by {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
    padding: 12px 16px;
    justify-content: right;
    border-radius: 8px;
  }

  .created-by-avatar {
    width: 24px;
    height: 24px;
    border-radius: 4px;
    overflow: hidden;
    flex-shrink: 0;
  }

  .created-by-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .created-by-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .created-by-label {
    font-family: "Inter", sans-serif;
    font-size: 14px;
    color: #4b5563;
  }

  .created-by-name {
    font-family: "Inter", sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: #f9fafb;
  }

  .playground-container {
    display: grid;
    /* grid-template-columns: 1fr 1fr; */
    border: 1px solid #1f2937;
    background: #050505;
    border-radius: 12px;
    overflow: hidden;
    width: 100%;
    max-width: 100%;
    min-width: 0;
  }

  .playground-preview {
    padding: 40px;
    background: #e8e8e8;
    border-right: 1px solid #1f2937;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 320px;
    min-width: 0;
    box-sizing: border-box;
    overflow: hidden;
  }

  .typewriter-playground {
    background: #fff;
    overflow: hidden;
  }

  .typewriter-showcase {
    display: flex;
    flex-direction: column;
    width: 100%;
    max-width: 100%;
    min-width: 0;
    align-items: center;
    justify-content: center;
    gap: 18px;
    text-align: center;
  }

  .demo-typewriter {
    font-family: Inter, sans-serif;
    font-size: 34px;
    font-weight: 500;
    color: #000;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 15px;
    width: 100%;
    min-width: 0;
    text-align: center;
    line-height: 1.2;
  }

  .typewriter-preview-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 15px;
    width: 100%;
  }

  .typewriter-preview-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    border: 1px solid #111;
    font-family: Inter, sans-serif;
    font-size: 15px;
    font-weight: 400;
    text-decoration: none;
    padding: 8px 10px;
    min-width: 112px;
    min-height: 38px;
    box-sizing: border-box;
  }



  .typewriter-preview-btn-outline {
    background: transparent;
    color: #111;
  }

  .typewriter-preview-btn-outline:hover {
    background: #111;
    color: #fff;
  }

  .typewriter-preview-btn-filled {
    background: #000;
    color: #fff;
  }

  .typewriter-preview-btn-filled:hover {
    background: #ff7f1f;
    border-color: #ff7f1f;
    color: #000;
  }

  .playground-code {
    background: #0d0d0d;
    padding: 0;
    display: flex;
    flex-direction: column;
    min-width: 0;
    max-width: 100%;
    overflow: hidden;
  }

  .code-header {
    background: #15191e;
    padding: 12px 16px;
    border-bottom: 1px solid #2a2a2a;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .code-header-left {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: "JetBrains Mono", monospace;
    font-size: 13px;
    color: #fff;
  }

  .astro-logo {
    color: #ff5d01;
  }

  .code-content {
    padding: 20px;
    font-family: "JetBrains Mono", monospace;
    font-size: 13px;
    line-height: 1.6;
    overflow-x: auto;
    max-width: 100%;
    min-width: 0;
  }

  .code-content pre {
    margin: 0;
    color: #e0e0e0;
    max-width: 100%;
  }

  .code-selector {
    color: #9cdcfe;
  }

  .code-property {
    color: #9cdcfe;
  }

  .code-value {
    color: #ce9178;
  }

  .installation-block {
    background: transparent;
    border: 1px solid #1f2937;
    border-radius: 8px;
    overflow: hidden;
  }

  .installation-header {
    background: #0b0d10;
    padding: 8px 16px;
    border-bottom: 1px solid #2a2a2a;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .bash-label {
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    color: #9ca3af;
  }

  .copy-icon {
    color: #9ca3af;
    cursor: pointer;
    transition: color 0.2s ease;
  }

  .copy-icon:hover {
    color: #f9fafb;
  }

  .installation-block pre {
    margin: 0;
    padding: 16px;
    background: transparent;
    font-family: "JetBrains Mono", monospace;
    font-size: 14px;
    color: #e0e0e0;
  }

  .code-header-text {
    color: #9ca3af;
    font-size: 12px;
    font-family: "Inter", sans-serif;
  }

  .package-name {
    color: #10b981;
  }

  .docs-code-block {
    background: #0b0d10;
    border: 1px solid #1f2937;
    border-radius: 8px;
    overflow: hidden;
  }

  .docs-code-block pre {
    margin: 0;
    padding: 16px;
    background: transparent;
    font-family: "JetBrains Mono", monospace;
    font-size: 14px;
    color: #e0e0e0;
  }

  .string {
    color: #ce9178;
  }

  .comment {
    color: #6a9955;
  }

  .component-name {
    color: #4ec9b0;
  }

  .component {
    color: #dcdcaa;
  }

  .prop {
    color: #9cdcfe;
  }

  .tag {
    color: #569cd6;
  }

  .docs-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    background: transparent;
    border-radius: 8px;
    overflow: hidden;
  }

  .docs-table th,
  .docs-table td {
    padding: 12px 16px;
    text-align: left;
    border-right: 1px solid #1f2937;
    font-family: "Inter", sans-serif;
  }

  .docs-table th:last-child,
  .docs-table td:last-child {
    border-right: none;
  }

  .docs-table th {
    background: #0b0d10;
    font-weight: 500;
    font-size: 14px;
    border-bottom: 1px solid #1f2937;
  }

  .docs-table td {
    color: #9ca3af;
    font-size: 14px;
    border-bottom: 1px solid #1f2937;
    background: transparent;
  }

  .docs-table tr:last-child td {
    border-bottom: none;
  }

  .docs-table td:first-child code {
    background: transparent;
    padding: 2px 6px;
    border-radius: 4px;
    font-family: "Inter", sans-serif;
    font-size: 14px;
  }

  .docs-table td:not(:first-child) code {
    background: #1f2937;
    padding: 2px 6px;
    border-radius: 4px;
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    margin-right: 8px;
    display: inline-block;
    margin-bottom: 6px;
  }

  .docs-table td:not(:first-child) code:last-child {
    margin-right: 0;
  }

  .api-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 20px;
    margin-top: 24px;
  }

  .api-card {
    padding: 24px;
    border: 1px solid #1f2937;
    background: #050505;
    border-radius: 8px;
  }

  .api-card h3 {
    font-size: 18px;
    font-family: "Inter", sans-serif;
    font-weight: 500;
    color: #f9fafb;
    margin-bottom: 8px;
  }

  .api-card p {
    color: #9ca3af;
    font-family: "Inter", sans-serif;
    font-size: 14px;
    margin: 0;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-top: 24px;
  }

  .related-card {
    aspect-ratio: 16/9;
    border: 1px solid #1f2937;
    background: #050505;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #4b5563;
    font-family: "Inter", sans-serif;
    font-size: 14px;
  }

  .related-card.empty {
    background: #0a0a0a;
  }
