---
import DocLayout from "../../../layouts/DocLayout.astro";
import "../../../styles/Global.css";
import { allNewComponentDocs } from "../../../data/newComponentDocs";

const isLatestDocsVersion = Astro.url.searchParams.get("version") !== "0.1.1";
const versionQuery = isLatestDocsVersion ? "" : "?version=0.1.1";
const newComponentImages = {
  "count-up": "/images/countup.png",
  "highlight-text": "/images/highlighttext.png",
  "grid-dots-background": "/images/griddotsbackground.png",
  "animated-tabs": "/images/animatedtabs.png",
  "dropdown": "/images/dropdown.png",
  "card-stack": "/images/cardstack.png",
  "liquid-glass-card": "/images/liquidglasscard.png",
  "product-review-card": "/images/productreviewcard.png",
  "article-card": "/images/articlecard.png",
  "newsletter-popup-card": "/images/newsletterpopupcard.png",
  "animated-border-button": "/images/animatedborderbtn.png",
  "sliding-overlay-button": "/images/slidingoverlaybtn.png",
  "github-shine-button": "/images/githubshinebtn.png",
  "stagger-text-button": "/images/staggertextbtn.png",
  "arrow-cta-button": "/images/arrowctabtn.png",
  "fill-hover-button": "/images/fillhoverbtn.png",
  "infinite-marquee": "/images/infinitemarquee.png",
  "dock": "/images/dock.png",
};

const sections = [
  {
    title: "Text Animations",
    items: [
      {
        name: "Fade In Text",
        href: "/docs/fade-in-text/",
        image: "/images/fadein.png",
        isNew: false,
      },
      {
        name: "Typewriter text",
        href: "/docs/typewriter/",
        image: "/images/typewriter.png",
        isNew: false,
      },
      
    ],
  },
  {
    title: "Core Animations",
    items: [
      {
        name: "Scale In",
        href: "/docs/scale-in/",
        image: "/images/scalein-demo.png",
        isNew: false,
      },
      {
        name: "Reveal Image",
        href: "/docs/reveal-image/",
        image: "/images/revealimage.png",
        isNew: false,
      },
    ],
  },
  {
    title: "Cards",
    items: [
      {
        name: "Expandable Card",
        href: "/docs/expandable-card/",
        image: "/images/expandable-card-black.png",
        isNew: false,
      },
      {
        name: "Animated Card",
        href: "/docs/animated-card/",
        image: "/images/animatedcard.png",
        isNew: false,
      },
      {
        name: "Glass Card",
        href: "/docs/glass-card/",
        image: "/images/glasscard.png",
        isNew: false,
      },
    ],
  },
  {
    title: "Loaders & Feedback",
    items: [
      { name: "Loader", href: "/docs/loader/", image: "/images/loader.png", isNew: false },
      {
        name: "Progress Bar",
        href: "/docs/progress-bar/",
        image: "/images/progressbar.png",
        isNew: false,
      },
    ],
  },
  {
    title: "Buttons",
    items: [
      {
        name: "Animated Button",
        href: "/docs/animated-button/",
        image: "/images/animated-btn.png",
        isNew: false,
      },
    ],
  },
  {
    title: "Overlays & Popovers",
    items: [
      {
        name: "Tool Tip",
        href: "/docs/tooltip/",
        image: "/images/tooltip.png",
        isNew: false,
      },
    ],
  },
].map((section) => ({
  ...section,
  items: [
    ...section.items,
    ...(isLatestDocsVersion
      ? allNewComponentDocs
          .filter((item) => item.section === section.title)
          .map((item) => ({
            name: item.name,
            href: `/docs/${item.slug}/`,
            image: newComponentImages[item.slug] || "",
            isNew: true,
          }))
      : []),
  ],
})).filter((section) => section.items.length > 0);

if (isLatestDocsVersion) {
  for (const component of allNewComponentDocs) {
    if (sections.some((section) => section.items.some((item) => item.name === component.name))) {
      continue;
    }

    let section = sections.find((item) => item.title === component.section);
    if (!section) {
      section = { title: component.section, items: [] };
      sections.push(section);
    }

    section.items.push({
      name: component.name,
      href: `/docs/${component.slug}/`,
      image: newComponentImages[component.slug] || "",
      isNew: true,
    });
  }
}
---

<DocLayout title="All Components">
  <section id="all-components" class="all-components-page">
    <header class="all-components-header">
      <div>
        <h1 class="docs-title all-components-title">
          All Components
          <button
            type="button"
            class="all-components-share"
            aria-label="Copy page link"
          >
            <img src="/images/share-link.png" alt="" width="16" height="16" />
          </button>
        </h1>

        <div
          class="docs-intro-section"
          style="width: 100% !important; max-width: none !important;"
        >
          <p
            class="docs-paragraph"
            style="width: 100% !important; max-width: none !important;"
          >
            AstroAnimate provides a comprehensive collection of animation
            components designed specifically for Astro. Each component delivers
            smooth, performant animations with CSS-first implementation and
            optional JavaScript enhancements.
          </p>
        </div>
      </div>
    </header>

    <div class="all-components-groups">
      {
        sections.map((section, index) => (
          <section
            class="all-components-group"
            data-component-group
            data-search-group={index === 0 ? "true" : "false"}
          >
            <div class="all-components-content">
              <h2>{section.title}</h2>

              {index === 0 && (
                <label class="all-components-search">
                  <img src="/images/search.png" alt="" width="16" height="16" />
                  <input
                    type="search"
                    placeholder="Search"
                    aria-label="Search components"
                  />
                </label>
              )}
            </div>

            <div class="all-components-grid">
              {section.items.map((item) => (
                <a
                  href={`${item.href}${versionQuery}`}
                  class="all-component-card"
                  data-component-card
                  data-new-component={item.isNew ? "true" : undefined}
                  data-has-image={item.image ? "true" : undefined}
                >
                  <span class="all-component-preview">
                    {item.image ? (
                      <img src={item.image} alt="" loading="lazy" />
                    ) : null}
                  </span>
                  <span class="all-component-name">
                    {item.name}
                    {item.isNew && <span class="docs-new-pill">NEW</span>}
                  </span>
                </a>
              ))}
            </div>
          </section>
        ))
      }
    </div>

    <p class="all-components-no-results" aria-live="polite">
      No results found.
    </p>

    <div class="docs-footer-nav" style="justify-content: space-between;">
      <a href="/docs/support/" class="prev-link">
        <span class="label">PREVIOUS</span>
        <span class="title">
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            style="transform: rotate(180deg);"
            ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
              points="12 5 19 12 12 19"></polyline></svg
          >
          Support
        </span>
      </a>
      <a href="/docs/fade-in-text/" class="next-link">
        <span class="label">NEXT</span>
        <span class="title">
          Fade In text
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
              points="12 5 19 12 12 19"></polyline></svg
          >
        </span>
      </a>
    </div>
  </section>
  <!-- 
  <Fragment slot="toc">
    <div class="toc-header">IN THIS PAGE</div>
    <nav class="toc-nav">
      <a href="#all-components" class="active">All Components</a>
    </nav>
  </Fragment> -->
</DocLayout>

<style>
  .all-components-page {
    padding-bottom: 12px;
  }

  .all-components-header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 170px;
    align-items: end;
    gap: 28px;
    margin-bottom: 24px;
    border-bottom: 1px solid #1f2937;
  }

  .all-components-title {
    margin: 0 0 12px;
  }

  .all-components-share {
    width: 20px;
    height: 20px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: none;
    background: transparent;
    padding: 0;
    cursor: pointer;
    flex: 0 0 auto;
    margin-left: 2px;
  }

  .all-components-share img {
    width: 16px;
    height: 16px;
    object-fit: contain;
    /* opacity: 0.75; */
  }

  .all-components-share:hover img,
  .all-components-share.copied img {
    opacity: 1;
  }

  .all-components-desc {
    margin: 0;
    max-width: 760px;
    color: #8b93a7;
    font-family: "Inter", sans-serif;
    font-size: 13px;
    line-height: 1.5;
  }

  .all-components-desc span {
    color: #ff7f1f;
  }

  .all-components-search {
    height: 28px;
    display: flex;
    align-items: center;
    gap: 8px;
    border: 1px solid #1f2937;
    padding: 0 9px;
    box-sizing: border-box;
  }

  .all-components-search img {
    width: 13px;
    height: 13px;
  }

  .all-components-search input {
    min-width: 0;
    width: 100%;
    border: none;
    outline: none;
    background: transparent;
    color: #f9fafb;
    font-family: "Inter", sans-serif;
    font-size: 14px;
  }

  .all-components-search input::placeholder {
    color: #4b5563;
  }

  .all-components-groups {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .all-components-no-results {
    display: none;
    margin: 24px 0 0;
    padding: 22px;
    /* border: 1px solid #1F2937; */
    color: #9ca3af;
    font-family: "Inter", sans-serif;
    font-size: 14px;
    text-align: center;
  }

  .all-components-group h2 {
    margin: 0;
    color: #f9fafb;
    font-family: "Inter", sans-serif;
    font-size: 18px;
    font-weight: 400;
    line-height: 28px;
  }

  .all-components-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0;
    width: 100%;
    padding-top: 1px;
    padding-left: 1px;
    background: transparent;
  }

  .all-component-card {
    width: 100%;
    min-height: 220px;
    padding: 19px;
    border: 1px solid #1f2937;
    margin-top: -1px;
    margin-left: -1px;
    text-decoration: none;
    color: #f9fafb;
    background: #000;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
  }

  /* Hide empty grid cells */
  .all-components-grid::after {
    content: "";
    display: none;
  }
  /* 
  .all-component-card:hover {
    background: rgba(255, 127, 31, 0.025);
  } */

  .all-component-preview {
    display: block;
    width: 100%;
    aspect-ratio: 1.15 / 1;
    background: #171b22;
    margin-bottom: 14px;
    overflow: hidden;
  }

  .all-component-preview img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .all-component-card[data-new-component="true"][data-has-image="true"] .all-component-preview {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 18px;
    background: #fff;
    box-sizing: border-box;
  }

  .all-component-card[data-new-component="true"][data-has-image="true"] .all-component-preview img {
    width: auto;
    height: auto;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .all-component-name {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #f9fafb;
    font-family: "Inter", sans-serif;
    font-size: 14px;
    line-height: 1.2;
  }

  .all-components-footer-nav {
    margin-top: 20px;
    padding-top: 20px;
    padding-bottom: 16px;
  }

  .all-components-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
    gap: 16px;
  }

  @media (max-width: 1180px) {
    .all-components-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 980px) {
    .all-components-header {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .all-components-search {
      width: min(260px, 100%);
      margin-bottom: 21px;
    }

    .all-components-content {
      align-items: flex-start;
      flex-direction: column;
      gap: 10px;
    }

    .all-components-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .all-component-card {
      width: 100%;
      padding: 22px;
    }
  }

  @media (max-width: 520px) {
    .all-components-grid {
      grid-template-columns: 1fr;
    }

    .all-component-card {
      width: 100%;
      padding: 18px;
    }
  }
</style>

<script>
  function initAllComponentsPage() {
    const root = document.querySelector(".all-components-page");
    if (!root || root.getAttribute("data-ready") === "true") return;
    root.setAttribute("data-ready", "true");

    const searchInput = root.querySelector<HTMLInputElement>(
      ".all-components-search input",
    );
    const cards = Array.from(
      root.querySelectorAll<HTMLElement>("[data-component-card]"),
    );
    const groups = Array.from(
      root.querySelectorAll<HTMLElement>("[data-component-group]"),
    );
    const noResults = root.querySelector<HTMLElement>(
      ".all-components-no-results",
    );
    const isOldDocsVersion =
      new URLSearchParams(window.location.search).get("version") === "0.1.1";

    const syncVersionGroups = () => {
      if (!isOldDocsVersion) return;
      groups.forEach((group) => {
        const groupCards = Array.from(
          group.querySelectorAll<HTMLElement>("[data-component-card]"),
        );
        const hasVisibleCard = groupCards.some(
          (card) => window.getComputedStyle(card).display !== "none",
        );
        group.style.display = hasVisibleCard ? "" : "none";
      });
    };

    syncVersionGroups();

    searchInput?.addEventListener("input", () => {
      const term = searchInput.value.trim().toLowerCase();
      let totalVisibleCards = 0;

      cards.forEach((card) => {
        const name = card.textContent?.toLowerCase() ?? "";
        const isVisible = !term || name.includes(term);
        card.style.display = isVisible ? "" : "none";
        if (isVisible) totalVisibleCards += 1;
      });

      groups.forEach((group) => {
        const visibleCards = group.querySelectorAll(
          '[data-component-card]:not([style*="display: none"])',
        );
        const grid = group.querySelector<HTMLElement>(".all-components-grid");
        const isSearchGroup = group.dataset.searchGroup === "true";

        if (isSearchGroup) {
          group.style.display = "";
          if (grid) grid.style.display = visibleCards.length ? "" : "none";
          return;
        }

        group.style.display = visibleCards.length ? "" : "none";
      });

      if (noResults) {
        noResults.style.display =
          term && totalVisibleCards === 0 ? "block" : "none";
      }

      syncVersionGroups();
    });
  }

  document.addEventListener("DOMContentLoaded", initAllComponentsPage);
  document.addEventListener("astro:page-load", initAllComponentsPage);
</script>
