---
import DocLayout from "../../../layouts/DocLayout.astro";
import RelatedComponents from "../../../components/RelatedComponents.astro";
import "../../../styles/Global.css";
import Tooltip from "@astroanimate/core/Tooltip";
---

<DocLayout title="Tooltip">
    <section id="tooltip">
        <h1 class="docs-title">Tooltip <button type="button" class="docs-title-share" aria-label="Copy page link"><img src="/images/share-link.png" alt="" width="16" height="16" /></button></h1>

        <div class="docs-intro-section">
            <p class="docs-paragraph">
                Renders an animated tooltip on hover with configurable position
                and easing variants. Uses CSS hover states for visibility, with
                optional JavaScript enhancement for subtle mouse-following
                motion.
            </p>
        </div>

        <!-- PREVIEW/PLAYGROUND SECTION -->
        <div class="docs-intro-section" id="preview-playground">
            <h2 class="docs-subtitle">Preview/Playground</h2>
            <div class="created-by">
                <span class="created-by-label">Created by</span>
                <div class="created-by-avatar">
                    <img
                        src="/images/vipin.jpg"
                        alt="Creator"
                        onerror="this.src='/images/barsan.jpeg'"
                    />
                </div>
                <span class="created-by-name">Vipin</span>
            </div>
            <div class="playground-container">
                <div class="playground-preview">
                    <div
                        class="tooltip-showcase"
                        style="padding: 40px; min-height: 200px; display: flex; align-items: center; justify-content: center; width: 100%;"
                    >
                        <Tooltip content="Tooltip text" position="top">
                            <button
                                style="padding: 12px 24px; border: none; border-radius: 6px; background: #3b82f6; color: white; cursor: pointer; font-family: 'Inter', sans-serif;"
                                >Hover me</button
                            >
                        </Tooltip>
                    </div>
                </div>
                <div class="playground-code">
                    <div class="code-header">
                        <div class="code-header-left">
                            <img
                                src="/images/astro.png"
                                alt="Astro"
                                width="14"
                                height="18"
                            />
                            <span class="code-header-text">Astro</span>
                        </div>
                    </div>
                    <div class="code-content">
                        <pre><code><span class="keyword">import</span> <span class="component-name">Tooltip</span> <span class="keyword">from</span> <span class="string">'@astroanimate/core/Tooltip'</span>;

&lt;<span class="component">Tooltip</span> <span class="prop">content</span>=<span class="string">"Tooltip text"</span> <span class="prop">position</span>=<span class="string">"top"</span>&gt;
  <span class="tag">&lt;button&gt;</span>Hover me<span class="tag">&lt;/button&gt;</span>
&lt;/<span class="component">Tooltip</span>&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>

        <!-- INSTALLATION SECTION -->
        <div class="docs-intro-section" id="installation">
            <h2 class="docs-subtitle">Installation</h2>
            <div class="installation-block">
                <div class="installation-header">
                    <span class="bash-label">bash</span>
                    <svg
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="copy-icon"
                    >
                        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"
                        ></rect>
                        <path
                            d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
                        ></path>
                    </svg>
                </div>
                <pre><code><span class="keyword">npm</span> install <span class="string">@astroanimate/core</span></code></pre>
            </div>
        </div>

        <!-- QUICK START SECTION -->
        <div class="docs-intro-section" id="usage">
            <h2 class="docs-subtitle">Usage</h2>
            <!-- <p
                class="docs-paragraph"
                style="margin-bottom: 12px; color: #9ca3af; font-size: 14px;"
            >
                Wraps any element to show a tooltip on hover.
            </p> -->
            <div class="docs-code-block" style="margin-bottom: 24px;">
                <pre><code><span class="comment">---</span>
<span class="keyword">import</span> <span class="component-name">Tooltip</span> <span class="keyword">from</span> <span class="string">"@astroanimate/core/Tooltip"</span>;
<span class="comment">---</span>

&lt;<span class="component">Tooltip</span> <span class="prop">content</span>=<span class="string">"Tooltip text"</span> <span class="prop">position</span>=<span class="string">"top"</span>&gt;
  <span class="tag">&lt;button&gt;</span>Hover me<span class="tag">&lt;/button&gt;</span>
&lt;/<span class="component">Tooltip</span>&gt;</code></pre>
            </div>
         <p class="docs-paragraph">Wraps any element to show a tooltip on hover.</p>

            <!-- <p class="docs-paragraph" style="margin-bottom: 12px; color: #9ca3af; font-size: 14px;">Enables cursor-based motion enhancement while hovering.</p> -->
            <div class="docs-code-block">
                <pre><code>&lt;<span class="component">Tooltip</span> <span class="prop">content</span>=<span class="string">"Tooltip text"</span> <span class="prop">enhance</span>&gt;
  <span class="tag">&lt;button&gt;</span>Hover me<span class="tag">&lt;/button&gt;</span>
&lt;/<span class="component">Tooltip</span>&gt;</code></pre>
            </div>
            <p class="docs-paragraph">Enables cursor-based motion enhancement while hovering.</p>
        </div>

        <!-- PROPS SECTION -->
        <div class="docs-intro-section" id="props">
            <h2 class="docs-subtitle">Props</h2>
            <div class="table-wrapper">
                <table class="docs-table">
                    <thead>
                        <tr>
                            <th>Prop</th>
                            <th>Type</th>
                            <th>Default</th>
                            <th>Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr
                            ><td><code>content</code></td><td
                                ><code>string</code></td
                            ><td><code>-</code></td><td
                                >Tooltip content text (required)</td
                            ></tr
                        >
                        <tr
                            ><td><code>position</code></td><td
                                ><code>"top" | "bottom" | "left" | "right"</code
                                ></td
                            ><td><code>"top"</code></td><td
                                >Tooltip position relative to wrapped element</td
                            ></tr
                        >
                        <tr
                            ><td><code>variant</code></td><td
                                ><code>"fade" | "spring" | "float"</code></td
                            ><td><code>"spring"</code></td><td
                                >Animation easing variant (controls how tooltip
                                enters)</td
                            ></tr
                        >
                        <tr
                            ><td><code>enhance</code></td><td
                                ><code>boolean</code></td
                            ><td><code>false</code></td><td
                                >Opt-in to JS-enhanced mouse-following behavior</td
                            ></tr
                        >
                        <tr
                            ><td><code>duration</code></td><td
                                ><code>number</code></td
                            ><td><code>200</code></td><td
                                >Transition duration in milliseconds</td
                            ></tr
                        >
                        <tr
                            ><td><code>class</code></td><td
                                ><code>string</code></td
                            ><td><code>""</code></td><td
                                >Additional CSS classes for wrapper</td
                            ></tr
                        >
                    </tbody>
                </table>
            </div>
        </div>

        <!-- BEHAVIOR SECTION -->
        <div class="docs-intro-section" id="behavior">
            <h2 class="docs-subtitle">Behavior</h2>
            <ul class="docs-list">
                <li>
                    Tooltip visibility is controlled entirely by CSS hover
                    states
                </li>
                <li>JavaScript enhancement does not control visibility</li>
                <li>
                    When <code class="docs-code">enhance=true</code>, JavaScript
                    adds dynamic cursor-following motion by adjusting transform
                    values
                </li>
                <li>
                    Without enhancement, all animations are handled purely via
                    CSS transitions
                </li>
            </ul>
        </div>

        <!-- USE WHEN SECTION -->
        <div class="docs-intro-section" id="use-when">
            <h2 class="docs-subtitle">Use When</h2>
            <ul class="docs-list">
                <li>Displaying contextual help or hints on hover</li>
                <li>Showing additional information without cluttering UI</li>
                <li>
                    Needing lightweight, animated tooltips with position control
                </li>
                <li>
                    Adding subtle motion polish with optional cursor-following
                    effects
                </li>
            </ul>
        </div>

        <!-- AVOID WHEN SECTION -->
        <div class="docs-intro-section" id="avoid-when">
            <h2 class="docs-subtitle">Avoid When</h2>
            <ul class="docs-list">
                <li>Content is critical and must always be visible</li>
                <li>
                    Tooltip needs to contain interactive elements (it is
                    non-interactive)
                </li>
                <li>Users may have difficulty with hover-based interactions</li>
                <li>
                    Click or focus-based interactions are required instead of
                    hover
                </li>
            </ul>
        </div>

        <!-- ACCESSIBILITY SECTION -->
        <div class="docs-intro-section" id="accessibility">
            <h2 class="docs-subtitle">Accessibility</h2>
            <div>
                <ul class="docs-list">
                    <li>
                        Includes <code class="docs-code">role="tooltip"</code>
                    </li>
                    <li>
                        Tooltip is non-interactive (<code class="docs-code"
                            >pointer-events: none</code
                        >) and cannot contain clickable or focusable elements
                    </li>
                    <li>
                        Respects <code class="docs-code"
                            >prefers-reduced-motion</code
                        > media query
                    </li>
                    <li>
                        Movement transforms are disabled under reduced motion,
                        while opacity-based fade is preserved
                    </li>
                    <li>
                        JS enhancement is automatically disabled when reduced
                        motion is preferred
                    </li>
                </ul>
            </div>
        </div>

        <!-- PERFORMANCE SECTION -->
        <div class="docs-intro-section" id="performance">
            <h2 class="docs-subtitle">Performance</h2>
            <div>
                <ul class="docs-list">
                    <li>
                        CSS-first approach (no JavaScript required by default)
                    </li>
                    <li>
                        JS enhancement only adds lightweight mousemove listeners
                    </li>
                    <li>WeakMap prevents duplicate initialization</li>
                    <li>MutationObserver handles cleanup on DOM removal</li>
                </ul>
            </div>
        </div>

        <!-- CREDITS SECTION -->
        <div class="docs-intro-section" id="credits">
            <h2 class="docs-subtitle">Credits</h2>
            <ul class="docs-list">
                <li>
                    Credit to <a href="https://github.com/Krishvipin" target="_blank" class="credits-link">@Vipin</a>
                </li>
            </ul>
        </div>

        <!-- RELATED COMPONENTS SECTION -->
        <RelatedComponents items={[
            { name: "AnimatedButton", href: "/docs/animated-button", image: "/images/animated-btn.png" },
            { name: "AnimatedCard", href: "/docs/animated-card", image: "/images/animatedcard.png" },
        ]} />

        <div class="docs-footer-nav" style="justify-content: space-between;">
            <a href="/docs/animated-button" class="prev-link">
                <span class="label">PREVIOUS</span>
                <span class="title">
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        style="transform: rotate(180deg);"
                        ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
                            points="12 5 19 12 12 19"></polyline></svg
                    >
                   Animated Button
                </span>
            </a>
            <!-- <a href="/docs/Sec-AnimatedButton" class="next-link">
                <span class="label">NEXT</span>
                <span class="title">
                    Animated Button
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
                            points="12 5 19 12 12 19"></polyline></svg
                    >
                </span>
            </a> -->
        </div>
    </section>

    <Fragment slot="toc">
        <div class="toc-header">IN THIS PAGE</div>
        <nav class="toc-nav">
            <a href="#tooltip" class="active">Tooltip</a>
            <a href="#preview-playground">Preview/Playground</a>
            <a href="#installation">Installation</a>
            <a href="#usage">Usage</a>
            <a href="#props">Props</a>
            <a href="#behavior">Behavior</a>
            <a href="#use-when">Use When</a>
            <a href="#avoid-when">Avoid When</a>
            <a href="#accessibility">Accessibility</a>
            <a href="#performance">Performance</a>
            <a href="#credits">Credits</a>
        </nav>
    </Fragment>
</DocLayout>

<style>
    .created-by {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 20px;
        padding: 12px 16px;
        justify-content: right;
        border-radius: 8px;
    }

    .created-by-avatar {
        width: 24px;
        height: 24px;
        border-radius: 4px;
        overflow: hidden;
        flex-shrink: 0;
    }

    .created-by-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .created-by-info {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .created-by-label {
        font-family: "Inter", sans-serif;
        font-size: 14px;
        color: #4b5563;
    }

    .created-by-name {
        font-family: "Inter", sans-serif;
        font-size: 14px;
        font-weight: 500;
        color: #f9fafb;
    }

    .playground-container {
        display: grid;
        /* grid-template-columns: 1fr 1fr; */
        border: 1px solid #1f2937;
        background: #050505;
        border-radius: 12px;
        overflow: hidden;
    }

    .playground-preview {
        padding: 40px;
        background: #e8e8e8;
        border-right: 1px solid #1f2937;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .playground-code {
        background: #0d0d0d;
        padding: 0;
        display: flex;
        flex-direction: column;
    }

    .code-header {
        background: #15191e;
        padding: 12px 16px;
        border-bottom: 1px solid #2a2a2a;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .code-header-left {
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: "JetBrains Mono", monospace;
        font-size: 13px;
        color: #fff;
    }

    .astro-logo {
        color: #ff5d01;
    }

    .code-content {
        padding: 20px;
        font-family: "JetBrains Mono", monospace;
        font-size: 13px;
        line-height: 1.6;
        overflow-x: auto;
    }

    .code-content pre {
        margin: 0;
        color: #e0e0e0;
    }

    .code-selector {
        color: #9cdcfe;
    }

    .code-property {
        color: #9cdcfe;
    }

    .code-value {
        color: #ce9178;
    }

    .installation-block {
        background: transparent;
        border: 1px solid #1f2937;
        border-radius: 8px;
        overflow: hidden;
    }

    .installation-header {
        background: #0b0d10;
        padding: 8px 16px;
        border-bottom: 1px solid #2a2a2a;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .bash-label {
        font-family: "JetBrains Mono", monospace;
        font-size: 12px;
        color: #9ca3af;
    }

    .copy-icon {
        color: #9ca3af;
        cursor: pointer;
        transition: color 0.2s ease;
    }

    .copy-icon:hover {
        color: #f9fafb;
    }

    .installation-block pre {
        margin: 0;
        padding: 16px;
        background: transparent;
        font-family: "JetBrains Mono", monospace;
        font-size: 14px;
        color: #e0e0e0;
    }

    .code-header-text {
        color: #9ca3af;
        font-size: 12px;
        font-family: "Inter", sans-serif;
    }

    .package-name {
        color: #10b981;
    }

    .docs-code-block {
        background: #0b0d10;
        border: 1px solid #1f2937;
        border-radius: 8px;
        overflow: hidden;
    }

    .docs-code-block pre {
        margin: 0;
        padding: 16px;
        background: transparent;
        font-family: "JetBrains Mono", monospace;
        font-size: 14px;
        color: #e0e0e0;
    }

    /* .keyword {
        color: #569cd6;
    } */

    .string {
        color: #ce9178;
    }

    .comment {
        color: #6a9955;
    }

    .component-name {
        color: #4ec9b0;
    }

    .component {
        color: #dcdcaa;
    }

    .prop {
        color: #9cdcfe;
    }

    .tag {
        color: #569cd6;
    }

    .docs-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        background: transparent;
        border-radius: 8px;
        overflow: hidden;
    }

    .docs-table th,
    .docs-table td {
        padding: 12px 16px;
        text-align: left;
        border-right: 1px solid #1f2937;
        font-family: "Inter", sans-serif;
    }

    .docs-table th:last-child,
    .docs-table td:last-child {
        border-right: none;
    }

    .docs-table th {
        background: #0b0d10;
        font-weight: 500;
        font-size: 14px;
        border-bottom: 1px solid #1f2937;
    }

    .docs-table td {
        color: #9ca3af;
        font-size: 14px;
        border-bottom: 1px solid #1f2937;
        background: transparent;
    }

    .docs-table tr:last-child td {
        border-bottom: none;
    }

    .docs-table td:first-child code {
        background: transparent;
        padding: 2px 6px;
        border-radius: 4px;
        font-family: "Inter", sans-serif;
        font-size: 14px;
    }

    .docs-table td:not(:first-child) code {
        background: #1f2937;
        padding: 2px 6px;
        border-radius: 4px;
        font-family: "JetBrains Mono", monospace;
        font-size: 12px;
        margin-right: 8px;
        display: inline-block;
        margin-bottom: 6px;
    }

    .docs-table td:not(:first-child) code:last-child {
        margin-right: 0;
    }

    .related-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-top: 24px;
    }

    .related-card {
        aspect-ratio: 16/9;
        border: 1px solid #1f2937;
        background: #050505;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #4b5563;
        font-family: "Inter", sans-serif;
        font-size: 14px;
    }

    .related-card.empty {
        background: #0a0a0a;
    }

    .docs-footer-nav {
        margin-top: 60px;
        padding-top: 40px;
        border-top: 1px solid #1f2937;
    }

    .component-link {
        color: #9ca3af;
    }

    .credits-link {
        color: #60a5fa;
    }

    .component-link:hover {
        color: #ff953d;
    }

    @media (max-width: 1024px) {
        .playground-container {
            grid-template-columns: 1fr;
        }

        .playground-preview {
            border-right: none;
            border-bottom: 1px solid #1f2937;
        }

        .related-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
</style>
