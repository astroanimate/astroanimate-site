---
import DocLayout from "../../layouts/DocLayout.astro";
import "../../styles/Global.css";
import FadeInText from "@astroanimate/core/FadeInText";
---

<DocLayout title="FadeInText">
    <section id="fade-in-text">
       
            <h1 class="docs-title">FadeIn</h1>
            
        <div class="docs-intro-section">
            <p class="docs-paragraph">
                Fades in text with blur effect and vertical translate animation.
                Supports CSS-only mode and scroll-triggered JS enhancement.
            </p>
        </div>

        <!-- PREVIEW/PLAYGROUND SECTION -->
        <div class="docs-intro-section" id="preview-playground">
            <h2 class="docs-subtitle">Preview/Playground</h2>
            <div class="created-by">
                <span class="created-by-label">Created by</span>
                <div class="created-by-avatar">
                    <img src="/images/barsan.jpeg" alt="Creator" />
                </div>

                <span class="created-by-name">Vipin</span>
            </div>
            <div class="playground-container">
                <div class="playground-preview">
                    <div class="typewriter-showcase">
                        <FadeInText>
                            <h1 style="margin: 0; color: #000;">
                                Welcome to my site
                            </h1>
                        </FadeInText>

                        <div class="demo-typewriter">
                            <FadeInText
                                enhance={true}
                                duration={0.8}
                                yOffset={30}
                            >
                                <p style="margin: 0; color: #000;">
                                    Scroll-triggered animation
                                </p>
                            </FadeInText>
                        </div>
                    </div>
                </div>
                <div class="playground-code">
                    <div class="code-header">
                        <div class="code-header-left">
                            <img
                                src="/images/astro.png"
                                alt="Astro"
                                width="14"
                                height="18"
                            />
                            <span class="code-header-text">Astro</span>
                        </div>
                    </div>
                    <div class="code-content">
                        <pre><code><span class="keyword">import</span> <span class="component-name">FadeInText</span> <span class="keyword">from</span> <span class="string">"@astroanimate/core/FadeInText"</span>;

&lt;<span class="component">FadeInText</span>&gt;
  &lt;<span class="tag">h1</span>&gt;Welcome to my site&lt;/<span class="tag">h1</span>&gt;
&lt;/<span class="component">FadeInText</span>&gt;

&lt;<span class="component">FadeInText</span>
  <span class="prop">enhance</span>={<span class="boolean">true</span>}
  <span class="prop">duration</span>={<span class="number">0.8</span>}
  <span class="prop">yOffset</span>={<span class="number">30</span>}
&gt;
  &lt;<span class="tag">p</span>&gt;Scroll-triggered animation&lt;/<span class="tag">p</span>&gt;
&lt;/<span class="component">FadeInText</span>&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>

        <!-- INSTALLATION SECTION -->
        <div class="docs-intro-section" id="installation">
            <h2 class="docs-subtitle">Installation</h2>
            <div class="installation-block">
                <div class="installation-header">
                    <span class="bash-label">bash</span>
                    <svg
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="copy-icon"
                    >
                        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"
                        ></rect>
                        <path
                            d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
                        ></path>
                    </svg>
                </div>
                <pre><code><span class="keyword">npm</span> install <span class="string">@astroanimate/core</span></code></pre>
            </div>
        </div>

        <!-- PROPS SECTION -->
        <div class="docs-intro-section" id="props">
            <h2 class="docs-subtitle">Props</h2>
            <div class="table-wrapper">
                <table class="docs-table">
                    <thead>
                        <tr>
                            <th>Prop</th>
                            <th>Type</th>
                            <th>Default</th>
                            <th>Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><code>enhance</code></td>
                            <td><code>boolean</code></td>
                            <td><code>false</code></td>
                            <td
                                >Enable JS-powered scroll-triggered animation
                                via IntersectionObserver</td
                            >
                        </tr>
                        <tr>
                            <td><code>duration</code></td>
                            <td><code>number</code></td>
                            <td><code>0.6</code></td>
                            <td>Animation duration in seconds</td>
                        </tr>
                        <tr>
                            <td><code>delay</code></td>
                            <td><code>number</code></td>
                            <td><code>0</code></td>
                            <td>Delay before animation starts in seconds</td>
                        </tr>
                        <tr>
                            <td><code>easing</code></td>
                            <td><code>string</code></td>
                            <td><code>cubic-bezier(0.4, 0, 0.2, 1)</code></td>
                            <td>CSS easing/timing function</td>
                        </tr>
                        <tr>
                            <td><code>blur</code></td>
                            <td><code>string</code></td>
                            <td><code>"6px"</code></td>
                            <td>Initial blur amount (must include CSS unit)</td>
                        </tr>
                        <tr>
                            <td><code>yOffset</code></td>
                            <td><code>number</code></td>
                            <td><code>20</code></td>
                            <td
                                >Vertical distance (px) element travels upward
                                during animation</td
                            >
                        </tr>
                        <tr>
                            <td><code>once</code></td>
                            <td><code>boolean</code></td>
                            <td><code>true</code></td>
                            <td>Play animation only once (enhance=true only)</td
                            >
                        </tr>
                        <tr>
                            <td><code>inViewMargin</code></td>
                            <td><code>string</code></td>
                            <td><code>"-50px"</code></td>
                            <td
                                >IntersectionObserver bottom rootMargin
                                (enhance=true only)</td
                            >
                        </tr>
                        <tr>
                            <td><code>class</code></td>
                            <td><code>string</code></td>
                            <td><code>""</code></td>
                            <td>CSS class name applied to root element</td>
                        </tr>
                        <tr>
                            <td><code>as</code></td>
                            <td><code>string</code></td>
                            <td><code>"div"</code></td>
                            <td>HTML element rendered as root wrapper</td>
                        </tr>
                        <tr>
                            <td><code>...rest</code></td>
                            <td><code>unknown</code></td>
                            <td><code>-</code></td>
                            <td
                                >Additional HTML attributes (id, aria-label,
                                role, etc.)</td
                            >
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- USE WHEN SECTION -->
        <div class="docs-intro-section" id="use-when">
            <h2 class="docs-subtitle">Use When</h2>
            <ul class="docs-list">
                <li>Page load text reveals with CSS-only animation</li>
                <li>Scroll-triggered text reveals on long pages</li>
                <li>Hero sections, headlines, or feature descriptions</li>
                <li>Content that needs smooth entrance animation</li>
            </ul>
        </div>

        <!-- AVOID WHEN SECTION -->
        <div class="docs-intro-section" id="avoid-when">
            <h2 class="docs-subtitle">Avoid When</h2>
            <ul class="docs-list">
                <li>Content must be visible immediately without animation</li>
                <li>Complex animation sequences beyond simple fade-in</li>
                <li>
                    When JS is disabled and enhance=true (content remains hidden
                    with 2s fallback)
                </li>
            </ul>
        </div>

        <!-- ACCESSIBILITY SECTION -->
        <div class="docs-intro-section" id="accessibility">
            <h2 class="docs-subtitle">Accessibility</h2>
            <div>
                <ul class="docs-list">
                    <li>
                        Respects <code>prefers-reduced-motion</code> media query -
                        all motion neutralized
                    </li>
                    <li>
                        Content remains visible when reduced motion is preferred
                    </li>
                    <li>
                        Works with JS disabled in CSS-only mode (enhance=false)
                    </li>
                </ul>
            </div>
        </div>

        <!-- PERFORMANCE SECTION -->
        <div class="docs-intro-section" id="performance">
            <h2 class="docs-subtitle">Performance</h2>
            <div>
                <ul class="docs-list">
                    <li>
                        CSS-only by default (enhance=false) - zero JavaScript
                        overhead
                    </li>
                    <li>
                        JS-enhanced mode uses IntersectionObserver with WeakMap
                        cleanup
                    </li>
                    <li>
                        MutationObserver ensures observer disconnection on DOM
                        removal
                    </li>
                </ul>
            </div>
        </div>

        <!-- CREDITS SECTION -->
        <div class="docs-intro-section" id="credits">
            <h2 class="docs-subtitle">Credits</h2>
            <ul class="docs-list">
                <li>
                    Credit to <a
                        href="https://github.com/barsan"
                        class="credits-link">@Vipin</a
                    >
                </li>
            </ul>
        </div>

        <!-- RELATED COMPONENTS SECTION -->
        <div class="docs-intro-section" id="related-components">
            <h2 class="docs-subtitle">Related Components</h2>
            <div class="related-grid">
                <div class="related-card empty"></div>
                <div class="related-card empty"></div>
                <div class="related-card empty"></div>
                <div class="related-card empty"></div>
            </div>
        </div>

        <div class="docs-footer-nav" style="justify-content: space-between;">
            <a href="/docs/All-Components" class="prev-link">
                <span class="label">PREVIOUS</span>
                <span class="title">
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        style="transform: rotate(180deg);"
                        ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
                            points="12 5 19 12 12 19"></polyline></svg
                    >
                    All Components
                </span>
            </a>
            <a href="/docs/Sec-ScaleIn" class="next-link">
                <span class="label">NEXT</span>
                <span class="title">
                    Typewriter Text
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
                            points="12 5 19 12 12 19"></polyline></svg
                    >
                </span>
            </a>
        </div>
    </section>
    <Fragment slot="toc">
        <div class="toc-header">IN THIS PAGE</div>
        <nav class="toc-nav">
            <a href="#fade-in-text" class="active">Fade In Text</a>
            <a href="#preview-playground">Preview/Playground</a>
            <a href="#installation">Installation</a>
            <a href="#props">Props</a>
            <a href="#use-when">Use When</a>
            <a href="#avoid-when">Avoid When</a>
            <a href="#accessibility">Accessibility</a>
            <a href="#performance">Performance</a>
            <a href="#credits">Credits</a>
            <a href="#related-components">Related Components</a>
        </nav>
    </Fragment>
</DocLayout>

<style>
    .created-by {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 20px;
        padding: 12px 16px;
        justify-content: right;
        border-radius: 8px;
    }

    .created-by-avatar {
        width: 24px;
        height: 24px;
        border-radius: 4px;
        overflow: hidden;
        flex-shrink: 0;
    }

    .created-by-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .created-by-info {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .created-by-label {
        font-family: "Inter", sans-serif;
        font-size: 14px;
        color: #4b5563;
    }

    .created-by-name {
        font-family: "Inter", sans-serif;
        font-size: 14px;
        font-weight: 500;
        color: #f9fafb;
    }

    .playground-container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        border: 1px solid #1f2937;
        background: #050505;
        border-radius: 12px;
        overflow: hidden;
    }

    .playground-preview {
        padding: 40px;
        background: #e8e8e8;
        border-right: 1px solid #1f2937;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .typewriter-showcase {
        display: flex;
        flex-direction: column;
        gap: 20px;
        width: 100%;
        max-width: 300px;
    }

    .demo-typewriter {
        font-family: "JetBrains Mono", monospace;
        font-size: 18px;
        color: #000;
        background: #fff;
        padding: 16px;
        border-radius: 8px;
        border: 1px solid #ddd;
    }

    .playground-code {
        background: #0d0d0d;
        padding: 0;
        display: flex;
        flex-direction: column;
    }

    .code-header {
        background: #15191e;
        padding: 12px 16px;
        border-bottom: 1px solid #2a2a2a;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .code-header-left {
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: "JetBrains Mono", monospace;
        font-size: 13px;
        color: #fff;
    }

    .astro-logo {
        color: #ff5d01;
    }

    .code-content {
        padding: 20px;
        font-family: "JetBrains Mono", monospace;
        font-size: 13px;
        line-height: 1.6;
        overflow-x: auto;
    }

    .code-content pre {
        margin: 0;
        color: #e0e0e0;
    }

    .code-selector {
        color: #9cdcfe;
    }

    .code-property {
        color: #9cdcfe;
    }

    .code-value {
        color: #ce9178;
    }

    .installation-block {
        background: transparent;
        border: 1px solid #1f2937;
        border-radius: 8px;
        overflow: hidden;
    }

    .installation-header {
        background: #0b0d10;
        padding: 8px 16px;
        border-bottom: 1px solid #2a2a2a;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .bash-label {
        font-family: "JetBrains Mono", monospace;
        font-size: 12px;
        color: #9ca3af;
    }

    .copy-icon {
        color: #9ca3af;
        cursor: pointer;
        transition: color 0.2s ease;
    }

    .copy-icon:hover {
        color: #f9fafb;
    }

    .installation-block pre {
        margin: 0;
        padding: 16px;
        background: transparent;
        font-family: "JetBrains Mono", monospace;
        font-size: 14px;
        color: #e0e0e0;
    }

    .code-header-text {
        color: #9ca3af;
        font-size: 12px;
        font-family: "Inter", sans-serif;
    }

    .package-name {
        color: #10b981;
    }

    .docs-code-block {
        background: #0b0d10;
        border: 1px solid #1f2937;
        border-radius: 8px;
        overflow: hidden;
    }

    .docs-code-block pre {
        margin: 0;
        padding: 16px;
        background: transparent;
        font-family: "JetBrains Mono", monospace;
        font-size: 14px;
        color: #e0e0e0;
    }

    .string {
        color: #ce9178;
    }

    .comment {
        color: #6a9955;
    }

    .component-name {
        color: #4ec9b0;
    }

    .component {
        color: #dcdcaa;
    }

    .prop {
        color: #9cdcfe;
    }

    .tag {
        color: #569cd6;
    }

    .keyword {
        color: #c586c0;
    }

    .boolean {
        color: #569cd6;
    }

    .number {
        color: #b5cea8;
    }

    .docs-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        background: transparent;
        border-radius: 8px;
        overflow: hidden;
    }

    .docs-table th,
    .docs-table td {
        padding: 12px 16px;
        text-align: left;
        border-right: 1px solid #1f2937;
        font-family: "Inter", sans-serif;
    }

    .docs-table th:last-child,
    .docs-table td:last-child {
        border-right: none;
    }

    .docs-table th {
        background: #0b0d10;
        font-weight: 500;
        font-size: 14px;
        border-bottom: 1px solid #1f2937;
    }

    .docs-table td {
        color: #9ca3af;
        font-size: 14px;
        border-bottom: 1px solid #1f2937;
        background: transparent;
    }

    .docs-table tr:last-child td {
        border-bottom: none;
    }

    .docs-table td:first-child code {
        background: transparent;
        padding: 2px 6px;
        border-radius: 4px;
        font-family: "Inter", sans-serif;
        font-size: 14px;
    }

    .docs-table td:not(:first-child) code {
        background: #1f2937;
        padding: 2px 6px;
        border-radius: 4px;
        font-family: "JetBrains Mono", monospace;
        font-size: 12px;
        margin-right: 8px;
        display: inline-block;
        margin-bottom: 6px;
    }

    .docs-table td:not(:first-child) code:last-child {
        margin-right: 0;
    }

    .api-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 20px;
        margin-top: 24px;
    }

    .api-card {
        padding: 24px;
        border: 1px solid #1f2937;
        background: #050505;
        border-radius: 8px;
    }

    .api-card h3 {
        font-size: 18px;
        font-family: "Inter", sans-serif;
        font-weight: 500;
        color: #f9fafb;
        margin-bottom: 8px;
    }

    .api-card p {
        color: #9ca3af;
        font-family: "Inter", sans-serif;
        font-size: 14px;
        margin: 0;
    }

    .related-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-top: 24px;
    }

    .related-card {
        aspect-ratio: 16/9;
        border: 1px solid #1f2937;
        background: #050505;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #4b5563;
        font-family: "Inter", sans-serif;
        font-size: 14px;
    }

    .related-card.empty {
        background: #0a0a0a;
    }

    .component-link {
        color: #9ca3af;
    }

    .credits-link {
        color: #60a5fa;
    }

    .component-link:hover {
        color: #ff953d;
    }

    @media (max-width: 1024px) {
        .playground-container {
            grid-template-columns: 1fr;
        }

        .playground-preview {
            border-right: none;
            border-bottom: 1px solid #1f2937;
        }

        .related-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
</style>
