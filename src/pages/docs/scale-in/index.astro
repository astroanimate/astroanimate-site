  .component-link {
    color: #9ca3af;
  }

  .credits-link {
    color: #60a5fa;
  }

  .component-link:hover {
    color: #ff953d;
  }

  @media (max-width: 1024px) {
    .playground-container {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .playground-preview {
      border-right: none;
      border-bottom: 1px solid #1f2937;
      min-height: 300px;
      padding: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .scale-showcase {
      align-items: center;
      justify-content: center;
    }

    .related-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .playground-preview {
      padding: 20px;
      min-height: 250px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .scale-showcase {
      align-items: center;
      justify-content: center;
    }

    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
