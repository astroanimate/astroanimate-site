---
import DocLayout from "../../../layouts/DocLayout.astro";
import RelatedComponents from "../../../components/RelatedComponents.astro";
import "../../../styles/Global.css";
import InfiniteMarquee from "@astroanimate/core/InfiniteMarquee";
---

<DocLayout title="InfiniteMarquee">
    <section id="infinite-marquee">
        <h1 class="docs-title">
            InfiniteMarquee <span class="docs-new-pill">NEW</span>
            <button
                type="button"
                class="docs-title-share"
                aria-label="Copy page link"
                ><img
                    src="/images/share-link.png"
                    alt=""
                    width="16"
                    height="16"
                /></button>
        </h1>

        <div class="docs-intro-section">
            <p class="docs-paragraph">
                A continuous, high-performance CSS-only scrolling marquee for
                logos, text, or testimonial cards.
            </p>
        </div>

        <!-- PREVIEW/PLAYGROUND SECTION -->
        <div class="docs-intro-section" id="preview-playground">
            <div
                style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px;"
            >
                <h2 class="docs-subtitle" style="margin: 0;">
                    Preview/Playground
                </h2>
            </div><div class="created-by">
                <span class="created-by-label">Created by</span><div
                    class="created-by-avatar"
                >
                    <img src="/images/barsan.jpeg" alt="Creator" />
                </div><span class="created-by-name">Barsan</span>
            </div><div class="playground-container">
                <div class="playground-preview">
                    <button
                        type="button"
                        class="preview-reload-btn"
                        onclick="location.reload()"
                        aria-label="Refresh preview"
                        ><svg
                            width="14"
                            height="14"
                            viewBox="0 0 24 24"
                            fill="none"
                            aria-hidden="true"
                            ><path
                                d="M21 12a9 9 0 1 1-2.64-6.36"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"></path><path
                                d="M21 4v6h-6"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"></path></svg
                        ></button
                    ><div class="component-preview-stage infinite-container">
                      
<!-- Card Mode for Testimonials -->
<InfiniteMarquee
  cardMode={true}
  testimonials={[
    { name: "Alice", handle: "@alice", quote: "This is amazing!", img: "https://x.tax/wp-content/uploads/2026/02/219-150x150.jpg" }
  ]}
  speed="7s"
/>
<InfiniteMarquee
  cardMode={true}
  testimonials={[
    { name: "John Doe", handle: "@johndoe", quote: "This is amazing!", img: "https://encrypted-tbn1.gstatic.com/images?q=tbn:ANd9GcR1ddElrY90Caq7L52GJdQnd4P7HPe5pZgYL4KSOdQvAuPmu4WF" }
  ]}
  speed="6s"
  direction="right"
/>
                    </div>
                </div><div class="playground-code">
                    <div class="code-header">
                        <div class="code-header-left">
                            <img
                                src="/images/astro.png"
                                alt="Astro"
                                width="14"
                                height="18"
                            /><span class="code-header-text">Astro</span>
                        </div>
                    </div><div class="code-content">
                        <pre><code><span class="comment">---</span>
<span class="keyword">import</span> <span class="component-name">InfiniteMarquee</span> <span class="keyword">from</span> <span class="string">"@astroanimate/core/InfiniteMarquee"</span>;
<span class="comment">---</span>

&lt;<span class="component">InfiniteMarquee</span>
  <span class="prop">cardMode</span>=&#123;true&#125;
  <span class="prop">testimonials</span>=&#123;[
    &#123; name: <span class="string">"Alice"</span>, handle: <span class="string">"@alice"</span>, quote: <span class="string">"This is amazing!"</span> &#125;
  ]&#125;
  <span class="prop">speed</span>=<span class="string">"7s"</span>
/&gt;

&lt;<span class="component">InfiniteMarquee</span>
  <span class="prop">cardMode</span>=&#123;true&#125;
  <span class="prop">testimonials</span>=&#123;[
    &#123; name: <span class="string">"John Doe"</span>, handle: <span class="string">"@johndoe"</span>, quote: <span class="string">"This is amazing!"</span> &#125;
  ]&#125;
  <span class="prop">speed</span>=<span class="string">"6s"</span>
  <span class="prop">direction</span>=<span class="string">"right"</span>
/&gt;</code></pre>
                    </div>
                </div>
            </div>
        </div>

        <!-- INSTALLATION SECTION -->
        <div class="docs-intro-section" id="installation">
            <h2 class="docs-subtitle">Installation</h2><div
                class="installation-block"
            >
                <div class="installation-header">
                    <span class="bash-label">bash</span><svg
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="copy-icon"
                        ><rect x="9" y="9" width="13" height="13" rx="2" ry="2"
                        ></rect><path
                            d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
                        ></path></svg>
                </div><pre><code><span class="keyword">npm</span> install @astroanimate/core</code></pre>
            </div>
        </div>

        <!-- QUICK START SECTION -->
        <div class="docs-intro-section" id="usage">
            <h2 class="docs-subtitle">Usage</h2><div class="docs-code-block">
                <pre><code><span class="comment">---</span>
<span class="keyword">import</span> InfiniteMarquee <span class="keyword">from</span> <span class="string">"@astroanimate/core/InfiniteMarquee"</span>;
<span class="comment">---</span>

&lt;<span class="component">InfiniteMarquee</span> <span class="prop">direction</span>=<span class="string">"left"</span> <span class="prop">speed</span>=<span class="string">"40s"</span> <span class="prop">fade</span>=&#123;true&#125;&gt;
  &lt;<span class="tag">div</span> <span class="prop">class</span>=<span class="string">"marquee-item"</span>&gt;Company A&lt;/<span class="tag">div</span>&gt;
  &lt;<span class="tag">div</span> <span class="prop">class</span>=<span class="string">"marquee-item"</span>&gt;Company B&lt;/<span class="tag">div</span>&gt;
  &lt;<span class="tag">div</span> <span class="prop">class</span>=<span class="string">"marquee-item"</span>&gt;Company C&lt;/<span class="tag">div</span>&gt;
&lt;/<span class="component">InfiniteMarquee</span>&gt;</code></pre>
            </div><p class="docs-paragraph">
                Renders a smoothly looping track of content that seamlessly
                wraps around the container.
            </p>
        </div>

        <!-- PROPS SECTION -->
        <div class="docs-intro-section" id="props">
            <h2 class="docs-subtitle">Props</h2><div class="table-wrapper">
                <table class="docs-table">
                    <thead
                        ><tr
                            ><th>Prop</th><th>Type</th><th>Default</th><th
                                >Description</th
                            ></tr
                        ></thead
                    ><tbody>
                        <tr>
                            <td><code>direction</code></td>
                            <td
                                ><code>"left" | "right" | "up" | "down"</code
                                ></td
                            >
                            <td><code>"left"</code></td>
                            <td>Scroll direction</td>
                        </tr>
                        <tr>
                            <td><code>speed</code></td>
                            <td><code>string</code></td>
                            <td><code>"30s"</code></td>
                            <td>Duration of one complete scroll cycle</td>
                        </tr>
                        <tr>
                            <td><code>pauseOnHover</code></td>
                            <td><code>boolean</code></td>
                            <td><code>true</code></td>
                            <td>Pause animation on mouse hover</td>
                        </tr>
                        <tr>
                            <td><code>gap</code></td>
                            <td><code>string</code></td>
                            <td><code>"2rem"</code></td>
                            <td>Spacing between items</td>
                        </tr>
                        <tr>
                            <td><code>fade</code></td>
                            <td><code>boolean</code></td>
                            <td><code>true</code></td>
                            <td>Apply gradient fade masks to the edges</td>
                        </tr>
                        <tr>
                            <td><code>cardMode</code></td>
                            <td><code>boolean</code></td>
                            <td><code>false</code></td>
                            <td>Enable built-in testimonial card renderer</td>
                        </tr>
                        <tr>
                            <td><code>testimonials</code></td>
                            <td><code>Testimonial[]</code></td>
                            <td><code>[]</code></td>
                            <td
                                >Array of data for cards (<code
                                    class="docs-code"
                                    >&#123;name, handle, quote, img?&#125;</code
                                >)</td
                            >
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- USE WHEN SECTION -->
        <div class="docs-intro-section" id="use-when">
            <h2 class="docs-subtitle">Use When</h2><ul class="docs-list">
                <li>
                    Displaying a continuous feed of partner logos, sponsors, or
                    client brands
                </li>
                <li>
                    Showcasing a carousel of bite-sized user reviews or
                    testimonials
                </li>
                <li>Creating dynamic "ticker-tape" announcements</li>
            </ul>
        </div>

        <!-- AVOID WHEN SECTION -->
        <div class="docs-intro-section" id="avoid-when">
            <h2 class="docs-subtitle">Avoid When</h2><ul class="docs-list">
                <li>
                    Presenting dense, long-form reading material (moving text
                    hurts reading comprehension)
                </li>
                <li>
                    Nesting complex interactive elements (like forms or
                    dropdowns) inside the moving track
                </li>
            </ul>
        </div>

        <!-- ACCESSIBILITY SECTION -->
        <div class="docs-intro-section" id="accessibility">
            <h2 class="docs-subtitle">Accessibility</h2><ul class="docs-list">
                <li>
                    Pauses on hover automatically to allow users to read the
                    content comfortably
                </li>
                <li>
                    Hides duplicated trailing track copies from screen readers
                    using <code class="docs-code">aria-hidden="true"</code>
                </li>
                <li>
                    Respects <code class="docs-code"
                        >prefers-reduced-motion: reduce</code
                    > by freezing the animation completely
                </li>
            </ul>
        </div>

        <!-- PERFORMANCE SECTION -->
        <div class="docs-intro-section" id="performance">
            <h2 class="docs-subtitle">Performance</h2><ul class="docs-list">
                <li>
                    <strong>Zero JavaScript:</strong> The scrolling loop is powered
                    entirely by CSS keyframe animations
                </li>
                <li>Server rendered content duplication for seamless loops</li>
                <li>
                    GPU accelerated with <code class="docs-code"
                        >transform</code>
                </li>
            </ul>
        </div>

        <!-- CREDITS SECTION -->
        <div class="docs-intro-section" id="credits">
            <h2 class="docs-subtitle">Credits</h2> <ul class="docs-list">
                <li>
                    Credit to <a
                        href="https://github.com/Barsaan"
                        target="_blank"
                        class="credits-link">@Barsan</a
                    >
                </li>
            </ul>
        </div>

        <RelatedComponents
            items={[
                {
                    name: "AnimatedButton",
                    href: "/docs/animated-button",
                    image: "/images/animated-btn.png",
                },
            ]}
        />

        <div class="docs-footer-nav" style="justify-content: space-between;">
            <a href="/docs/tooltip/" class="prev-link">
                <span class="label">PREVIOUS</span>
                <span class="title">
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        style="transform: rotate(180deg);"
                        ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
                            points="12 5 19 12 12 19"></polyline></svg
                    >
                    Tool Tip
                </span>
            </a>
            <!-- <a href="/docs/scale-in/" class="next-link">
                <span class="label">NEXT</span>
                <span class="title">
                    Scale In
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        ><line x1="5" y1="12" x2="19" y2="12"></line><polyline
                            points="12 5 19 12 12 19"></polyline></svg
                    >
                </span>
            </a> -->
        </div>
    </section>

    <Fragment slot="toc"
        ><div class="toc-header">IN THIS PAGE</div><nav class="toc-nav">
            <a href="#infinite-marquee" class="active">InfiniteMarquee</a><a
                href="#preview-playground">Preview/Playground</a
            ><a href="#installation">Installation</a><a href="#usage">Usage</a
            ><a href="#props">Props</a><a href="#use-when">Use When</a><a
                href="#avoid-when">Avoid When</a
            ><a href="#accessibility">Accessibility</a><a href="#performance"
                >Performance</a
            ><a href="#credits">Credits</a>
        </nav></Fragment
    >
</DocLayout>
<style>
    .created-by {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 20px;
        padding: 0;
        justify-content: right;
        border-radius: 8px;
    }

    .created-by-avatar {
        width: 24px;
        height: 24px;
        border-radius: 4px;
        overflow: hidden;
        flex-shrink: 0;
    }

    .created-by-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .created-by-info {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .created-by-label {
        font-family: "Inter", sans-serif;
        font-size: 14px;
        color: #4b5563;
    }

    .created-by-name {
        font-family: "Inter", sans-serif;
        font-size: 14px;
        font-weight: 500;
        color: #f9fafb;
    }

    .playground-container {
        display: grid;
        /* grid-template-columns: 1fr 1fr; */
        border: 1px solid #1f2937;
        background: #050505;
        border-radius: 12px;
        overflow: hidden;
        width: 100%;
        max-width: 100%;
        min-width: 0;
    }

    .playground-preview {
        padding: 12px 16px;
        background: #fff;
        border-right: 1px solid #1f2937;
        display: flex;
        align-items: center;
        justify-content: center;
        min-width: 0;
        overflow: hidden;
        box-sizing: border-box;
    }

    .playground-code {
        background: #0d0d0d;
        padding: 0;
        display: flex;
        flex-direction: column;
        min-width: 0;
        max-width: 100%;
        overflow: hidden;
    }

    .code-header {
        background: #15191e;
        padding: 12px 16px;
        border-bottom: 1px solid #2a2a2a;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .code-header-left {
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: "JetBrains Mono", monospace;
        font-size: 13px;
        color: #fff;
    }

    .astro-logo {
        color: #ff5d01;
    }

    .code-content {
        padding: 20px;
        font-family: "JetBrains Mono", monospace;
        font-size: 13px;
        line-height: 1.6;
        overflow-x: auto;
    }

    .code-content pre {
        margin: 0;
        color: #e0e0e0;
    }

    .code-selector {
        color: #9cdcfe;
    }

    .code-property {
        color: #9cdcfe;
    }

    .code-value {
        color: #ce9178;
    }

    .installation-block {
        background: transparent;
        border: 1px solid #1f2937;
        border-radius: 8px;
        overflow: hidden;
    }

    .installation-header {
        background: #0b0d10;
        padding: 8px 16px;
        border-bottom: 1px solid #2a2a2a;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .bash-label {
        font-family: "JetBrains Mono", monospace;
        font-size: 12px;
        color: #9ca3af;
    }

    .copy-icon {
        color: #9ca3af;
        cursor: pointer;
        transition: color 0.2s ease;
    }

    .copy-icon:hover {
        color: #f9fafb;
    }

    .installation-block pre {
        margin: 0;
        padding: 16px;
        background: transparent;
        font-family: "JetBrains Mono", monospace;
        font-size: 14px;
        color: #e0e0e0;
    }

    .code-header-text {
        color: #9ca3af;
        font-size: 12px;
        font-family: "Inter", sans-serif;
    }

    .package-name {
        color: #10b981;
    }

    .docs-code-block {
        background: #0b0d10;
        border: 1px solid #1f2937;
        border-radius: 8px;
        overflow: hidden;
    }

    .docs-code-block pre {
        margin: 0;
        padding: 16px;
        background: transparent;
        font-family: "JetBrains Mono", monospace;
        font-size: 14px;
        color: #e0e0e0;
    }

    .string {
        color: #ce9178;
    }

    .comment {
        color: #6a9955;
    }

    .component-name {
        color: #4ec9b0;
    }

    .component {
        color: #dcdcaa;
    }

    .prop {
        color: #9cdcfe;
    }

    .tag {
        color: #569cd6;
    }

    .docs-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        background: transparent;
        border-radius: 8px;
        overflow: hidden;
    }

    .docs-table th,
    .docs-table td {
        padding: 12px 16px;
        text-align: left;
        border-right: 1px solid #1f2937;
        font-family: "Inter", sans-serif;
    }

    .docs-table th:last-child,
    .docs-table td:last-child {
        border-right: none;
    }

    .docs-table th {
        background: #0b0d10;
        font-weight: 500;
        font-size: 14px;
        border-bottom: 1px solid #1f2937;
    }

    .docs-table td {
        color: #9ca3af;
        font-size: 14px;
        border-bottom: 1px solid #1f2937;
        background: transparent;
    }

    .docs-table tr:last-child td {
        border-bottom: none;
    }

    .docs-table td:first-child code {
        background: transparent;
        padding: 2px 6px;
        border-radius: 4px;
        font-family: "Inter", sans-serif;
        font-size: 14px;
    }

    .docs-table td:not(:first-child) code {
        background: #1f2937;
        padding: 2px 6px;
        border-radius: 4px;
        font-family: "JetBrains Mono", monospace;
        font-size: 12px;
        margin-right: 8px;
        display: inline-block;
        margin-bottom: 6px;
    }

    .docs-table td:not(:first-child) code:last-child {
        margin-right: 0;
    }

    .related-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-top: 24px;
    }

    .related-card {
        aspect-ratio: 16/9;
        border: 1px solid #1f2937;
        background: #050505;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #4b5563;
        font-family: "Inter", sans-serif;
        font-size: 14px;
    }

    .related-card.empty {
        background: #0a0a0a;
    }

    .docs-footer-nav {
        margin-top: 60px;
        padding-top: 40px;
        border-top: 1px solid #1f2937;
    }

    /* .prev-link,
    .next-link {
        display: flex;
        align-items: center;
        gap: 12px;
        text-decoration: none;
        color: #9ca3af;
        font-family: "Inter", sans-serif;
        transition: color 0.2s ease;
    }

    .prev-link:hover,
    .next-link:hover {
        color: #f9fafb;
    }

    .prev-link svg,
    .next-link svg {
        flex-shrink: 0;
    }

    .label {
        font-family: "JetBrains Mono", monospace;
        font-size: 12px;
        color: #ff7f1f;
    }

    .title {
        font-size: 16px;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 8px;
    } */

    .component-link {
        color: #9ca3af;
    }

    .credits-link {
        color: #60a5fa;
    }

    .component-link:hover {
        color: #ff953d;
    }

    .highlight-preview-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 18px;
        width: 100%;
        color: #111827;
        font-family: Inter, sans-serif;
    }

    .highlight-preview-item {
        min-height: 150px;
        padding: 22px;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        background: #ffffff;
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 14px;
    }

    .highlight-preview-item span {
        color: #6b7280;
        font-size: 13px;
        font-weight: 500;
    }

    .highlight-preview-item strong {
        color: #111827;
        font-size: 24px;
        line-height: 1.5;
        font-weight: 700;
    }

    .infinite-container {
        display: flex;
        flex-direction: column;
    }

    @media (max-width: 760px) {
        .highlight-preview-grid {
            grid-template-columns: 1fr;
        }
    }

    @media (max-width: 1024px) {
        .playground-container {
            grid-template-columns: 1fr;
            min-height: auto;
        }

        .playground-preview {
            border-right: none;
            border-bottom: 1px solid #1f2937;
            padding: 12px 16px;
        }

        .animated-card-container {
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 16px;
        }

        .related-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 760px) {
        .playground-container {
            width: min(100%, calc(100vw - 48px));
            max-width: 100%;
            grid-template-columns: minmax(0, 1fr);
            margin-inline: auto;
        }

        .playground-preview {
            width: 100%;
            max-width: 100%;
            padding: 12px 16px;
        }

        .animated-card-container {
            grid-template-columns: 1fr;
            width: min(100%, 290px);
            margin-inline: auto;
        }

        .animated-card-container :global([data-animated-card]) {
            min-height: 260px;
        }
    }
</style>
