---
import NavBar from "../components/NavBar.astro";
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import HowItWorks from "../components/HowItWorks.astro";
import Differentiation from "../components/Differentiation.astro";
import UseCases from "../components/UseCases.astro";
import Demo from "../components/Demo.astro";
import Preview from "../components/Preview.astro";
import Comparison from "../components/Comparison.astro";
import Perfomance from "../components/Perfomance.astro";
import Architecture from "../components/Architecture.astro";
import DocStructure from "../components/DocStructure.astro";
import OpenSource from "../components/OpenSource.astro";
import CTA from "../components/CTA.astro";
import Footer from "../components/Footer.astro";
import "../styles/Global.css";

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://www.astroanimate.com",
      name: "AstroAnimate",
      url: "https://www.astroanimate.com",
      logo: "https://www.astroanimate.com/images/Logo.png",
      sameAs: [
        "https://github.com/astroanimate",
        "https://twitter.com/astroanimate",
      ],
    },
    {
      "@type": "WebSite",
      "@id": "https://www.astroanimate.com",
      url: "https://www.astroanimate.com",
      name: "AstroAnimate",
      publisher: {
        "@id": "https://www.astroanimate.com/#organization",
      },
    },
    {
      "@type": "SoftwareApplication",
      "@id": "https://www.astroanimate.com",
      name: "AstroAnimate",
      applicationCategory: "DeveloperApplication",
      operatingSystem: "Web",
      url: "https://www.astroanimate.com",

      description:
        "Add smooth animations to Astro projects with CSS-first motion components, optional JavaScript, and View Transitions support.",
      softwareVersion: "0.1.1",
      license: "https://opensource.org/licenses/MIT",
      programmingLanguage: ["TypeScript", "JavaScript", "CSS"],
      author: {
        "@id": "https://www.astroanimate.com/about",
      },
    },
  ],
};
---

<Layout
  title="AstroAnimate — Animation Library for Astro"
  description="Add smooth animations to Astro projects with CSS-first motion components, optional JavaScript, and View Transitions support."
  schema={schema}
>
  <NavBar />
  <Hero />
  <HowItWorks />
  <Differentiation />
  <UseCases />
  <!-- <Demo /> -->
  <!-- <Preview /> -->
  <Comparison />
  <Perfomance />
  <Architecture />
  <DocStructure />
  <OpenSource />
  <CTA />
  <Footer />
</Layout>
