---
import NavBar from "../components/NavBar.astro";
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import HowItWorks from "../components/HowItWorks.astro";
import Differentiation from "../components/Differentiation.astro";
import UseCases from "../components/UseCases.astro";
import Demo from "../components/Demo.astro";
import Preview from "../components/Preview.astro";
import Comparison from "../components/Comparison.astro";
import Perfomance from "../components/Perfomance.astro";
import Architecture from "../components/Architecture.astro";
import DocStructure from "../components/DocStructure.astro";
import OpenSource from "../components/OpenSource.astro";
import CTA from "../components/CTA.astro";
import Footer from "../components/Footer.astro";
import "../styles/Global.css";

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
const schema = {
	"@context": "https://schema.org",
	"@type": "SoftwareApplication",
	name: "AstroAnimate",
	applicationCategory: "DeveloperApplication",
	operatingSystem: "Web",
	url: "https://www.astroanimate.com",
	description:
		"Add CSS-first animations and motion components to Astro projects with optional JavaScript. Built for Astro’s rendering model and compatible with View Transitions.",
	author: {
		"@type": "Organization",
		name: "AstroAnimate",
	},
};
---

<Layout
	title="AstroAnimate — Animation Library for Astro"
	description="Add CSS-first animations and motion components to Astro projects with optional JavaScript. Built for Astro’s rendering model and compatible with View Transitions."
	schema={schema}
>
	<NavBar />
	<Hero />
	<HowItWorks />
	<Differentiation />
	<UseCases />
	<!-- <Demo /> -->
	<!-- <Preview /> -->
	<Comparison />
	<Perfomance />
	<Architecture />
	<DocStructure />
	<OpenSource />
	<CTA />
	<Footer />
</Layout>
