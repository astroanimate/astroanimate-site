---
import Layout from "../layouts/Layout.astro";
import NavBar from "../components/NavBar.astro";
import Footer from "../components/Footer.astro";
import "../styles/Global.css";
---

<Layout title="404 - Page Not Found | AstroAnimate">
    <NavBar />
    <main class="error-container">
        <div class="star-field star-field-dense star-field-ultra error-stars" aria-hidden="true"></div>
        <div class="error-content">
            <h1 class="error-code">404</h1>
            <p class="error-message">
                “Oops! Looks like you're lost. Let's take you back home.”
            </p>
            <div class="error-actions">
                <a href="/" class="btn-back">Back to Home</a>
            </div>
        </div>
    </main>
    <!-- <Footer /> -->
</Layout>

<style>
    .error-container {
        min-height: 70vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 4rem 2rem;
        background: #000;
        color: #fff;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

    .error-content {
        max-width: 600px;
        position: relative;
        z-index: 1;
    }

    

    .error-code {
        font-size: 280px;
        font-family: 'JetBrains Mono', monospace;
        font-weight: 800;
        margin: 0;
        background: linear-gradient(135deg, #FF7F1F 0%, #e66a15 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        line-height: 1;
    }

    .error-title {
        font-size: 2rem;
        margin: 1rem 0;
        font-family: 'Inter', sans-serif;
    }

    .error-message {
        color: #F9FAFB;
        font-size: 18px;
        font-family: 'Inter', sans-serif;
        line-height: 1.6;
        margin-bottom: 2.5rem;
    }

    .error-actions {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-back {
        background: #F9FAFB;
        color: #000;
        padding: 20px 24px;
        text-decoration: none;
        font-weight: 400;
        font-family: 'JetBrains Mono', monospace;
    }

    .btn-primary:hover {
        background: #e66a15;
    }

    .btn-secondary {
        background: transparent;
        color: white;
        padding: 0.8rem 2rem;
        border-radius: 4px;
        text-decoration: none;
        font-weight: 600;
        border: 1px solid #1F2937;
        transition: border-color 0.2s;
    }

    .btn-secondary:hover {
        border-color: #FF7F1F;
    }

    @media (max-width: 640px) {
        .error-code {
            font-size: 130px;
        }

        .error-message {
            font-size: 16px;
        }
    }
</style>
