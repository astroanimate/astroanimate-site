---
import Layout from "../layouts/Layout.astro";
import NavBar from "../components/NavBar.astro";
import "../styles/Global.css";

const enhance = true; 
---

<Layout title="404 - Page Not Found | AstroAnimate">
    <NavBar />
    <main class="error-container">
        <div 
            data-starry-bg 
            data-enhance={enhance ? "true" : "false"} 
            data-star-count="400" 
            data-drift-speed="0.5" 
            data-drift-direction="145"
            aria-hidden="true"
        >
            <canvas></canvas>
        </div>

        <div class="error-content">
            <h1 class="error-code">404</h1>
            <p class="error-message">
                “Oops! Looks like you're lost. Let's take you back home.”
            </p>
            <div class="error-actions">
                <a href="/" class="btn-back" data-scrambler="BACK TO HOME">BACK TO HOME</a>
            </div>
        </div>
        
        <div class="astronaut-container">
            <img src="/images/astronaut.png" alt="Floating astronaut" class="astronaut" />
        </div>
    </main>
</Layout>

<style>
    [data-starry-bg] {
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        overflow: hidden;
        background-color: #000;
        background-image: 
            radial-gradient(white, rgba(255,255,255,.2) 2px, transparent 10px),
            radial-gradient(white, rgba(255,255,255,.1) 1px, transparent 5px);
        background-size: 550px 550px, 350px 350px;
    }

    [data-starry-bg] canvas {
        display: block;
        width: 100%;
        height: 100%;
        opacity: 0;
        transition: opacity 1s ease-in-out;
    }

    [data-starry-bg][data-state="ready"] canvas {
        opacity: 1;
    }

    [data-starry-bg][data-state="ready"] {
        background-image: none;
    }

    .error-container {
        min-height: 78vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 4rem 2rem;
        background: #000;
        color: #fff;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

    .error-content {
        max-width: 600px;
        position: relative;
        z-index: 1;
    }

    .error-code {
        font-size: 280px;
        font-family: 'JetBrains Mono', monospace;
        font-weight: 800;
        margin: 0;
        background: linear-gradient(135deg, #FF7F1F 0%, #e66a15 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        line-height: 1;
    }

    .error-message {
        color: #F9FAFB;
        font-size: 18px;
        font-family: 'Inter', sans-serif;
        line-height: 1.6;
        margin-bottom: 2.5rem;
    }

    .btn-back {
        background: #F9FAFB;
        color: #000;
        padding: 20px 24px;
        text-decoration: none;
        font-weight: 400;
        font-family: 'JetBrains Mono', monospace;
        transition: transform 0.2s ease;
        min-width: fit-content;
        display: inline-block;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

    .btn-back:hover {
        transform: translateY(-2px);
    }

    .btn-back.scrambling {
        animation: pulse 0.3s ease-in-out;
    }

    @keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.8; }
    }

    .astronaut-container {
        position: absolute;
        bottom: 20px;
        left: 20px;
        z-index: 2;
        pointer-events: none;
    }

    .astronaut {
        width: 380px;
        height: auto;
        animation: float 8s ease-in-out infinite;
        filter: drop-shadow(0 0 20px rgba(255, 255, 255, 0.3));
    }

    @keyframes float {
        0%, 100% {
            transform: translateY(0px) rotate(-1deg);
        }
        25% {
            transform: translateY(-2px) rotate(1deg);
        }
        50% {
            transform: translateY(-1px) rotate(0deg);
        }
        75% {
            transform: translateY(-2px) rotate(1deg);
        }
    }

    @media (max-width: 640px) {
        .error-code { font-size: 130px !important; }
        .error-message { font-size: 16px !important; }
        .astronaut-container { display: none !important; }
    }
</style>

<script>
    const initialized = new WeakMap();

    function enhanceStarryBackground(root) {
        if (initialized.has(root)) return;
        const canvas = root.querySelector('canvas');
        const ctx = canvas?.getContext('2d');
        if (!ctx) return;

        const starCount = parseInt(root.dataset.starCount || "400");
        const driftSpeed = parseFloat(root.dataset.driftSpeed || "1");
        const driftRad = (parseFloat(root.dataset.driftDirection || "145") * Math.PI) / 180;

        let width = 0, height = 0, stars = [], isPlaying = false, animationFrameId;

        const initStars = () => {
            stars = Array.from({ length: starCount }, () => ({
                x: Math.random() * width,
                y: Math.random() * height,
                radius: Math.random() * 1.5 + 0.5,
                alpha: Math.random(),
                alphaChange: (Math.random() * 0.02 + 0.005) * (Math.random() < 0.5 ? 1 : -1),
                speed: driftSpeed * (Math.random() * 0.5 + 0.1),
            }));
        };

        const resize = () => {
            const rect = root.getBoundingClientRect();
            const dpr = window.devicePixelRatio || 1;
            if (width !== rect.width * dpr || height !== rect.height * dpr) {
                width = canvas.width = rect.width * dpr;
                height = canvas.height = rect.height * dpr;
                initStars();
            }
        };

        const draw = () => {
            if (!isPlaying) return;
            ctx.clearRect(0, 0, width, height);
            stars.forEach(s => {
                ctx.beginPath();
                ctx.arc(s.x, s.y, s.radius, 0, Math.PI * 2);
                ctx.fillStyle = `rgba(255, 255, 255, ${Math.max(0, Math.min(1, s.alpha))})`;
                ctx.fill();
                s.alpha += s.alphaChange;
                if (s.alpha <= 0 || s.alpha >= 1) s.alphaChange *= -1;
                s.x += Math.cos(driftRad) * s.speed;
                s.y += Math.sin(driftRad) * s.speed;
                if (s.x > width) s.x = 0; else if (s.x < 0) s.x = width;
                if (s.y > height) s.y = 0; else if (s.y < 0) s.y = height;
            });
            animationFrameId = requestAnimationFrame(draw);
        };

        const ro = new ResizeObserver(resize);
        const io = new IntersectionObserver(([e]) => {
            isPlaying = e.isIntersecting;
            if (isPlaying) draw(); else cancelAnimationFrame(animationFrameId);
        });

        ro.observe(root);
        io.observe(root);
        root.dataset.state = "ready";
        initialized.set(root, true);
    }

    if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        document.querySelectorAll('[data-starry-bg][data-enhance="true"]').forEach(el => {
            enhanceStarryBackground(el);
        });
    }

    // Text scrambler effect
    class TextScrambler {
        constructor(element) {
            this.element = element;
            this.originalText = element.dataset.scrambler || element.textContent;
            this.chars = '!<>-_\/[]{}—=+*^?#________';
            this.isAnimating = false;
            this.queue = [];
            this.frame = 0;
            this.frameRequest = null;
        }

        scramble() {
            if (this.isAnimating) return;
            this.isAnimating = true;
            this.element.classList.add('scrambling');
            
            const duration = 1800;
            const frameRate = 30;
            const totalFrames = Math.floor(duration / (1000 / frameRate));
            
            this.queue = [];
            for (let i = 0; i < this.originalText.length; i++) {
                const startFrame = totalFrames * 0.2;
                const endFrame = totalFrames * 0.8;
                const charFrame = startFrame + (endFrame - startFrame) * (i / this.originalText.length);
                this.queue.push({ char: this.originalText[i], frame: charFrame });
            }
            
            this.frame = 0;
            this.update();
        }

        update() {
            let output = '';
            let complete = true;
            
            for (let i = 0; i < this.queue.length; i++) {
                const { char, frame } = this.queue[i];
                
                if (this.frame >= frame) {
                    output += char;
                } else {
                    complete = false;
                    if (this.frame % 2 === 0) {
                        output += this.chars[Math.floor(Math.random() * this.chars.length)];
                    } else {
                        output += char;
                    }
                }
            }
            
            this.element.textContent = output;
            
            if (!complete) {
                this.frame++;
                this.frameRequest = requestAnimationFrame(() => this.update());
            } else {
                this.isAnimating = false;
                this.element.classList.remove('scrambling');
            }
        }

        reset() {
            if (this.frameRequest) {
                cancelAnimationFrame(this.frameRequest);
            }
            this.isAnimating = false;
            this.element.textContent = this.originalText;
            this.element.classList.remove('scrambling');
        }
    }

    // Initialize scrambler for buttons with data-scrambler attribute
    document.querySelectorAll('[data-scrambler]').forEach(element => {
        const scrambler = new TextScrambler(element);
        
        element.addEventListener('mouseenter', () => {
            scrambler.scramble();
        });
        
        element.addEventListener('mouseleave', () => {
            scrambler.reset();
        });
    });
</script>