  <script is:inline>
    function syncDocsVersionClass() {
      const isOldDocsVersion = new URLSearchParams(window.location.search).get(
        "version",
      ) === "0.1.1";
      document.documentElement.classList.add("docs-sidebar-js");
      document.documentElement.classList.toggle(
        "docs-version-old",
        isOldDocsVersion,
      );
      document.documentElement.classList.toggle(
        "docs-version-latest",
        !isOldDocsVersion,
      );

      window.requestAnimationFrame(() => {
        document.querySelectorAll(".subcategory-list > details").forEach((group) => {
          const links = Array.from(group.querySelectorAll(".sidebar-comp-item"));
          if (!links.length) return;
          const hasVisibleLink = links.some((link) => {
            return window.getComputedStyle(link).display !== "none";
          });
          group.style.display = hasVisibleLink ? "" : "none";
        });

        if (isOldDocsVersion) {
          document.querySelectorAll('a[href^="/docs/"]').forEach((link) => {
            if (link.classList.contains("version-option")) return;
            const url = new URL(link.getAttribute("href"), window.location.origin);
            url.searchParams.set("version", "0.1.1");
            link.setAttribute("href", `${url.pathname}${url.search}${url.hash}`);
          });
        }
      });
    }

    syncDocsVersionClass();
    document.addEventListener("astro:page-load", syncDocsVersionClass);

    document.addEventListener("click", (event) => {
      if (!document.documentElement.classList.contains("docs-version-old")) return;

      const link = event.target.closest?.('a[href^="/docs/"]');
      if (!link || link.classList.contains("version-option")) return;

      const url = new URL(link.getAttribute("href"), window.location.origin);
      url.searchParams.set("version", "0.1.1");
      const nextUrl = `${url.pathname}${url.search}${url.hash}`;

      if (link.getAttribute("href") !== nextUrl) {
        event.preventDefault();
        window.location.href = nextUrl;
      }
    });
  </script>

