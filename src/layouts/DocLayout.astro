  <script>
    function initTocObserver() {
      const tocLinks = document.querySelectorAll(".toc-nav a");
      if (!tocLinks.length) return;

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              // Remove active class from all links
              tocLinks.forEach((link) => link.classList.remove("active"));

              // Add active class to corresponding link
              const activeLink = Array.from(tocLinks).find(
                (link) => link.getAttribute("href") === `#${entry.target.id}`,
              );
              if (activeLink) {
                activeLink.classList.add("active");
              }
            }
          });
        },
        // Trigger earlier: offset for sticky header, and fire when element crosses the middle
        { rootMargin: "-100px 0px -60% 0px" },
      );

      // Observe each target section defined in TOC
      tocLinks.forEach((link) => {
        const href = link.getAttribute("href");
        if (href && href.startsWith("#")) {
          const target = document.getElementById(href.substring(1));
          if (target) {
            observer.observe(target);
          }
        }
      });

      // Optionally handle manual clicks
      tocLinks.forEach((link) => {
        link.addEventListener("click", () => {
          tocLinks.forEach((l) => l.classList.remove("active"));
          link.classList.add("active");
        });
      });
    }

    // Run on standard load
    document.addEventListener("DOMContentLoaded", initTocObserver);
    // Support Astro view transitions if used
    document.addEventListener("astro:page-load", initTocObserver);

    function normalizeDocsPath(path: string) {
      return path.replace(/\/$/, "").toLowerCase() || "/";
    }

    const docsSidebarState = {
      scrollKey: "astroanimate:docs-sidebar-scroll",
      getSidebar() {
        return document.querySelector(".docs-sidebar") as HTMLElement | null;
      },
      save() {
        const sidebar = this.getSidebar();
        if (!sidebar) return;

        sessionStorage.setItem(this.scrollKey, String(sidebar.scrollTop));
      },
      restore() {
        const sidebar = this.getSidebar();
        if (!sidebar) return;

        const savedScroll = sessionStorage.getItem(this.scrollKey);
        const activeLink = sidebar.querySelector(
          ".sidebar-comp-item.active, .sidebar-sub-item.active",
        );

        requestAnimationFrame(() => {
          if (savedScroll !== null) {
            sidebar.scrollTop = Number(savedScroll) || 0;
          } else {
            activeLink?.scrollIntoView({ block: "nearest" });
          }

          sidebar.removeAttribute("data-sidebar-restoring");
        });
      },
    };

    // Fix active state for sidebar navigation
    function updateActiveState() {
      const currentPath = normalizeDocsPath(window.location.pathname);
      const sidebarLinks = document.querySelectorAll(
        ".sidebar-comp-item, .sidebar-sub-item",
      );

      sidebarLinks.forEach((link) => {
        const href = link.getAttribute("href");
        if (!href || href.startsWith("http")) return;

        const linkPath = normalizeDocsPath(
          new URL(href, window.location.origin).pathname,
        );
        if (linkPath === currentPath) {
          link.classList.add("active");
          link.setAttribute("aria-current", "page");
        } else {
          link.classList.remove("active");
          link.removeAttribute("aria-current");
        }
      });
    }

    function initDocsSidebarState() {
      const sidebar = docsSidebarState.getSidebar();
      if (!sidebar || sidebar.dataset.stateReady === "true") return;

      sidebar.dataset.stateReady = "true";

      sidebar.addEventListener("scroll", () => {
        docsSidebarState.save();
      });

      sidebar.querySelectorAll("a[href]").forEach((link) => {
        link.addEventListener("click", () => {
          docsSidebarState.save();
        });
      });
    }

    function initTitleShareButtons() {
      const buttons = document.querySelectorAll(
        ".docs-title-share, .all-components-share",
      );

      buttons.forEach((button) => {
        const shareButton = button as HTMLButtonElement;
        if (shareButton.dataset.shareReady === "true") return;
        shareButton.dataset.shareReady = "true";

        const image = shareButton.querySelector("img");
        const originalSrc =
          image?.getAttribute("src") || "/images/share-link.png";
        let resetTimer: number | undefined;

        shareButton.addEventListener("click", async () => {
          const pageUrl = window.location.href;

          try {
            if (navigator.clipboard?.writeText) {
              await navigator.clipboard.writeText(pageUrl);
            } else {
              throw new Error("Clipboard API unavailable");
            }
          } catch {
            const fallback = document.createElement("input");
            fallback.value = pageUrl;
            fallback.setAttribute("readonly", "");
            fallback.style.position = "fixed";
            fallback.style.opacity = "0";
            document.body.appendChild(fallback);
            fallback.select();
            document.execCommand("copy");
            fallback.remove();
          }

          window.clearTimeout(resetTimer);
          shareButton.classList.add("copied");
          shareButton.setAttribute("aria-label", "Copied page link");

          if (image) {
            image.setAttribute("src", "/images/checkmark.png");
            image.setAttribute("width", image.getAttribute("width") || "16");
            image.setAttribute("height", image.getAttribute("height") || "16");
          }

          shareButton.dataset.tooltip = "Link copied";

          resetTimer = window.setTimeout(() => {
            shareButton.classList.remove("copied");
            shareButton.removeAttribute("data-tooltip");
            shareButton.setAttribute("aria-label", "Copy page link");
            if (image) image.setAttribute("src", originalSrc);
          }, 1400);
        });
      });
    }

    function getCopyTargetText(trigger: Element) {
      const container =
        trigger.closest(".installation-block") ||
        trigger.closest(".docs-code-block") ||
        trigger.closest(".code-wrapper");
      const code = container?.querySelector("pre code");
      return code?.textContent?.trim().replace(/\n{3,}/g, "\n\n") || "";
    }

    async function copyTextToClipboard(text: string) {
      try {
        if (navigator.clipboard?.writeText) {
          await navigator.clipboard.writeText(text);
          return;
        }
        throw new Error("Clipboard API unavailable");
      } catch {
        const fallback = document.createElement("textarea");
        fallback.value = text;
        fallback.setAttribute("readonly", "");
        fallback.style.position = "fixed";
        fallback.style.opacity = "0";
        document.body.appendChild(fallback);
        fallback.select();
        document.execCommand("copy");
        fallback.remove();
      }
    }

    function initCodeCopyButtons() {
      const copyTriggers = document.querySelectorAll(
        ".copy-icon, .copy-btn-icon",
      );

      copyTriggers.forEach((trigger) => {
        const copyTrigger = trigger as HTMLElement;
        if (copyTrigger.dataset.copyReady === "true") return;
        copyTrigger.dataset.copyReady = "true";

        if (copyTrigger.tagName.toLowerCase() === "svg") {
          copyTrigger.setAttribute("role", "button");
          copyTrigger.setAttribute("tabindex", "0");
          copyTrigger.setAttribute("aria-label", "Copy code");
        }

        const icon = copyTrigger.matches("svg")
          ? (copyTrigger as unknown as SVGElement)
          : copyTrigger.querySelector("svg");
        const originalIcon = icon?.innerHTML || "";
        const originalViewBox = icon?.getAttribute("viewBox") || "0 0 24 24";
        let resetTimer: number | undefined;

        const showCheckIcon = () => {
          if (!icon) return;

          while (icon.firstChild) {
            icon.removeChild(icon.firstChild);
          }

          const checkPath = document.createElementNS(
            "http://www.w3.org/2000/svg",
            "path",
          );
          checkPath.setAttribute("d", "M20 6 9 17l-5-5");
          checkPath.setAttribute("fill", "none");
          checkPath.setAttribute("stroke", "currentColor");
          checkPath.setAttribute("stroke-width", "2.8");
          checkPath.setAttribute("stroke-linecap", "round");
          checkPath.setAttribute("stroke-linejoin", "round");

          icon.appendChild(checkPath);
          icon.classList.add("copied");
          icon.setAttribute("viewBox", "0 0 24 24");
          icon.setAttribute("aria-hidden", "true");
        };

        const restoreCopyIcon = () => {
          if (!icon) return;

          icon.classList.remove("copied");
          icon.setAttribute("viewBox", originalViewBox);
          icon.innerHTML = originalIcon;
        };

        const runCopy = async () => {
          const codeText = getCopyTargetText(copyTrigger);
          if (!codeText) return;

          await copyTextToClipboard(codeText);

          window.clearTimeout(resetTimer);
          copyTrigger.classList.add("copied");
          copyTrigger.setAttribute("aria-label", "Copied code");
          showCheckIcon();

          resetTimer = window.setTimeout(() => {
            copyTrigger.classList.remove("copied");
            copyTrigger.setAttribute("aria-label", "Copy code");
            restoreCopyIcon();
          }, 1400);
        };

        copyTrigger.addEventListener("click", runCopy);
        copyTrigger.addEventListener("keydown", (event) => {
          if (event.key !== "Enter" && event.key !== " ") return;
          event.preventDefault();
          runCopy();
        });
      });
    }

    
    // Search functionality for docs sidebar
    function initSearch() {
      const searchInput = document.querySelector(".sidebar-search input");
      const allLinks = document.querySelectorAll(
        ".sidebar-comp-item, .sidebar-sub-item",
      );
      const allCategories = document.querySelectorAll(
        ".sidebar-category, .subcategory-list details",
      );

      if (!searchInput) return;

      // Create no results message
      let noResultsMsg = document.querySelector(".no-results-message");
      if (!noResultsMsg) {
        noResultsMsg = document.createElement("div");
        noResultsMsg.className = "no-results-message";
        noResultsMsg.textContent = "No results found";
        noResultsMsg.style.display = "none";
        noResultsMsg.style.padding = "16px";
        noResultsMsg.style.color = "#9CA3AF";
        noResultsMsg.style.fontSize = "14px";
        noResultsMsg.style.textAlign = "center";
        searchInput.parentElement.parentElement.appendChild(noResultsMsg);
      }

      searchInput.addEventListener("input", (e) => {
        const searchTerm = (e.target as HTMLInputElement).value.toLowerCase();

        if (searchTerm === "") {
          // Show all items and categories when search is empty
          allLinks.forEach((link) => {
            (link as HTMLElement).style.display = "";
          });
          allCategories.forEach((category) => {
            (category as HTMLElement).style.display = "";
          });
          noResultsMsg.style.display = "none";
          return;
        }

        // Hide all categories first
        allCategories.forEach((category) => {
          (category as HTMLElement).style.display = "none";
        });

        let hasResults = false;

        // Show matching items and their parent categories
        allLinks.forEach((link) => {
          const text = link.textContent?.toLowerCase() || "";
          if (text.includes(searchTerm)) {
            (link as HTMLElement).style.display = "";
            hasResults = true;

            // Show parent categories
            let parent = link.closest(
              ".sidebar-category, .subcategory-list details",
            );
            while (parent) {
              (parent as HTMLElement).style.display = "";
              const parentElement = parent.parentElement?.closest(
                ".sidebar-category, .subcategory-list details",
              );
              parent = parentElement || null;
            }
          } else {
            (link as HTMLElement).style.display = "none";
          }
        });

        // Show or hide no results message
        noResultsMsg.style.display = hasResults ? "none" : "block";
      });
    }

    // Update active state on page load
    document.addEventListener("DOMContentLoaded", () => {
      updateActiveState();
      initDocsSidebarState();
      docsSidebarState.restore();
      initTitleShareButtons();
      initCodeCopyButtons();
      initSearch();
    });
    // Update active state on navigation
    document.addEventListener("astro:page-load", () => {
      updateActiveState();
      initDocsSidebarState();
      docsSidebarState.restore();
      initTitleShareButtons();
      initCodeCopyButtons();
      initSearch();
    });
    // Also update on popstate (browser back/forward)
    window.addEventListener("popstate", () => {
      updateActiveState();
      initDocsSidebarState();
      docsSidebarState.restore();
      initTitleShareButtons();
      initCodeCopyButtons();
      initSearch();
    });

    updateActiveState();
    initDocsSidebarState();
    docsSidebarState.restore();
    initTitleShareButtons();
    initCodeCopyButtons();
    initSearch();
  </script>
</Layout>
