---
import Layout from "./Layout.astro";
import NavBar from "../components/NavBar.astro";
import BreadcrumbSchema from "../components/seo/BreadcrumbSchema.astro";
import { allNewComponentDocs } from "../data/newComponentDocs";

interface Props {
  title: string;
}

const { pathname } = Astro.url;
const isDocsLanding = pathname === "/docs" || pathname === "/docs/";
const normalizedPath = pathname.replace(/\/$/, "");
const isLatestDocsVersion = Astro.url.searchParams.get("version") !== "0.1.1";
const versionQuery = isLatestDocsVersion ? "" : "?version=0.1.1";

// Map path to title if needed, or just capitalize the last segment
const pathSegments = pathname.split("/").filter(Boolean);
const currentPage = pathSegments[pathSegments.length - 1] || "docs";

// Format title: e.g., 'introduction' -> 'Introduction'
const pageTitle =
  currentPage.charAt(0).toUpperCase() + currentPage.slice(1).replace(/-/g, " ");
console.log(pageTitle);
const fullTitle = `AstroAnimate Docs — Installation, Components & API`;
const description = `Documentation for AstroAnimate, including installation guides, animation components, API references, examples, and performance considerations for Astro projects.`;
const canonical = `https://www.astroanimate.com${pathname}`;

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "TechArticle",
      headline: "AstroAnimate Documentation",
      description:
        "Documentation for AstroAnimate covering installation, components, API references, and examples.",
      url: "https://www.astroanimate.com/docs",
      author: {
        "@type": "Organization",
        name: "AstroAnimate",
      },
      publisher: {
        "@type": "Organization",
        name: "AstroAnimate",
        logo: {
          "@type": "ImageObject",
          url: "https://www.astroanimate.com/images/Logo.png",
        },
      },
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: "Home",
          item: "https://www.astroanimate.com/",
        },
        {
          "@type": "ListItem",
          position: 2,
          name: "Docs",
          item: "https://www.astroanimate.com/docs",
        },
      ],
    },
  ],
};

const oldComponentSections = [
  {
    title: "Text Animations",
    items: [
      { name: "Fade In Text", slug: "fade-in-text" },
      { name: "Typewriter text", slug: "typewriter" },
    ],
  },
  {
    title: "Core Animations",
    items: [
      { name: "Scale In", slug: "scale-in" },
      { name: "Reveal Image", slug: "reveal-image" },
    ],
  },
  {
    title: "Cards",
    items: [
      { name: "Expandable Card", slug: "expandable-card" },
      { name: "Animated Card", slug: "animated-card" },
      { name: "Glass Card", slug: "glass-card" },
    ],
  },
  {
    title: "Loaders & Feedback",
    items: [
      { name: "Loader", slug: "loader" },
      { name: "Progress Bar", slug: "progress-bar" },
    ],
  },
  {
    title: "Buttons",
    items: [{ name: "Animated Button", slug: "animated-button" }],
  },
  {
    title: "Overlays & Popovers",
    items: [{ name: "Tool Tip", slug: "tooltip" }],
  },
];

const groupedNewComponents = allNewComponentDocs.reduce(
  (groups, component) => {
    if (!groups[component.section]) groups[component.section] = [];
    groups[component.section].push(component);
    return groups;
  },
  {} as Record<string, typeof allNewComponentDocs>,
);

const animationSectionTitles = [
  "Text Animations",
  "Core Animations",
  "Background Effects",
];
const uiSectionTitles = [
  "Navigation",
  "Cards",
  "Forms",
  "Loaders & Feedback",
  "Buttons",
  "Overlays & Popovers",
  "Data Display",
];

const mergedSections = (titles: string[]) =>
  titles
    .map((title) => ({
      title,
      items: [
        ...(oldComponentSections.find((section) => section.title === title)
          ?.items.map((item) => ({ ...item, isNew: false })) ?? []),
        ...(isLatestDocsVersion
          ? groupedNewComponents[title]?.map((item) => ({
              name: item.name,
              slug: item.slug,
              isNew: true,
            })) ?? []
          : []),
      ],
    }))
    .filter((section) => section.items.length > 0);

const animationSections = mergedSections(animationSectionTitles);
const uiSections = mergedSections(uiSectionTitles);
---

<Layout
  title={fullTitle}
  description={description}
  canonical={canonical}
