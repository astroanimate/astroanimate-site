---
import MetaTags from "../components/seo/MetaTags.astro";
import JsonLd from "../components/seo/JsonLd.astro";
import Analytics from "@vercel/analytics/astro";

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  schema?: object;
}

const {
  title,
  description = "AstroAnimate is a CSS and Web Animations API–based animation library built specifically for Astro. Zero runtime JS by default. Supports Islands architecture and View Transitions.",
  canonical = "https://www.astroanimate.com/",
  ogImage = "https://www.astroanimate.com/og-image.png",
  schema,
} = Astro.props;
---

<!doctype html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.ico" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <meta name="generator" content={Astro.generator} />

    <meta name="robots" content="index, follow" />
    <!-- Vercel Analytics -->
    <Analytics />

    <!-- Global CSS -->
    <link rel="stylesheet" href="/styles/Global.css" />

    <!-- SEO Components -->
    <MetaTags
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
    />

    <JsonLd schema={schema || {}} />
    <!-- Google Tag Manager -->
    <script is:inline>
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != "dataLayer" ? "&l=" + l : "";
        j.async = true;
        j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, "script", "dataLayer", "GTM-NTMZ68KG");
    </script>
    <!-- End Google Tag Manager -->

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-XXXXXXXXXX");
    </script>

    <!-- Ghostlyx Analytics -->
    <script defer data-domain="www.astroanimate.com" data-site-id="gx_DsWYKnrVJvbr" src="https://ghostlyx.com/js/script.min.js"></script>

    <!-- Preload Critical Resources -->
    <link rel="preload" href="/styles/Global.css" as="style" />
    <link
      rel="preload"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=optional"
      as="style"
    />
    <link
      rel="preload"
      href="/videos/hole-wb-2.mp4"
      as="video"
      type="video/mp4"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <style>
      /* Prevent layout shifts with aspect-ratio */
      img {
        aspect-ratio: attr(width) / attr(height);
        object-fit: cover;
      }

      /* Font display optimization */
      @font-face {
        font-family: "Inter";
        font-display: optional;
      }

      @font-face {
        font-family: "JetBrains Mono";
        font-display: optional;
      }
    </style>

    <!-- Additional SEO -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title="AstroAnimate RSS Feed"
      href="https://www.astroanimate.com/rss.xml"
    />

    <!-- Performance: preconnect for Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Bai+Jamjuree:ital,wght@0,200;0,300;0,400;0,500;0,600;0,700;1,200;1,300;1,400;1,500;1,600;1,700&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript
      ><link
        href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Bai+Jamjuree:ital,wght@0,200;0,300;0,400;0,500;0,600;0,700;1,200;1,300;1,400;1,500;1,600;1,700&family=Inter:wght@400;500;600;700&display=swap"
        rel="stylesheet"
      /></noscript
    >
  </head>
  <body class="bg-black text-white">
    <!-- Google Tag Manager (noscript) -->
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-NTMZ68KG"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe></noscript
    >
    <!-- End Google Tag Manager (noscript) -->
    <main>
      <slot />
    </main>
  </body>
</html>

<style>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }
  html,
  body {
    margin: 0;
    padding: 0;
    width: 100%;
    background: #000;
    color: #fff;
  }
</style>
